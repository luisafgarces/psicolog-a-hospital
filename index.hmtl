          </div>
          <div class="ic-form-section">
            <div class="ic-form-head slate"><span class="ft">🛠️ Tratamiento — Intervención y plan</span><span class="ic-form-badge">TRATAMIENTO</span></div>
            <div class="ic-form-body">
              <div class="ic-field"><div class="ic-sublabel">Intervención realizada hoy</div><div class="ic-chips"><span class="ic-chip" onclick="icTog(this)">Escucha activa y validación emocional</span><span class="ic-chip" onclick="icTog(this)">Contención emocional</span><span class="ic-chip" onclick="icTog(this)">Psicoeducación sobre respuesta emocional al Dx</span><span class="ic-chip" onclick="icTog(this)">Psicoeducación sobre procesos hospitalarios</span><span class="ic-chip" onclick="icTog(this)">Reestructuración cognitiva</span><span class="ic-chip" onclick="icTog(this)">Técnicas de regulación emocional</span><span class="ic-chip" onclick="icTog(this)">Activación conductual</span><span class="ic-chip" onclick="icTog(this)">Técnicas de respiración / relajación</span><span class="ic-chip" onclick="icTog(this)">Reforzamiento de red de apoyo</span><span class="ic-chip" onclick="icTog(this)">Exploración de recursos y factores protectores</span><span class="ic-chip" onclick="icTog(this)">Orientación familiar</span><span class="ic-chip" onclick="icTog(this)">Evaluación y manejo de riesgo suicida</span></div></div>
              <div class="ic-g2">
                <div class="ic-field"><div class="ic-sublabel">Plan</div><div class="ic-chips"><span class="ic-chip" onclick="icTog(this)">Continúa seguimiento por psicología</span><span class="ic-chip" onclick="icTogR(this)">Remisión a psiquiatría</span><span class="ic-chip" onclick="icTog(this)">Orientación a trabajo social</span><span class="ic-chip on-g" onclick="icTogG(this)">Alta de psicología</span><span class="ic-chip" onclick="icTog(this)">Reinterconsulta si hay cambios</span></div></div>
                <div class="ic-field"><div class="ic-sublabel">Frecuencia de seguimiento</div><div class="ic-chips"><span class="ic-chip" onclick="icTog(this)">Diario</span><span class="ic-chip" onclick="icTog(this)">Cada 2 días</span><span class="ic-chip" onclick="icTog(this)">Interdiario</span><span class="ic-chip" onclick="icTog(this)">Cada 8 días</span><span class="ic-chip" onclick="icTog(this)">Cada 15 días</span><span class="ic-chip" onclick="icTog(this)">Semanal</span><span class="ic-chip" onclick="icTog(this)">Según evolución</span></div></div>
              </div>
              <div class="ic-field"><div class="ic-sublabel">Notas / recomendaciones al equipo</div><textarea id="ic-trat-notas" placeholder="Indicaciones específicas para el equipo médico, enfermería o trabajo social..." rows="2"></textarea></div>
            </div>
          </div>
        </div><!-- end ic-mode-nueva -->
        <!-- MODO ESPECIALES -->
        <div id="ic-mode-esp" style="display:none">
          <div class="ic-form-section">
            <div class="ic-form-head slate"><span class="ft">📋 Notas especiales — Selecciona la situación</span></div>
            <div class="ic-form-body">
              <div class="ic-sublabel">Tipo de nota</div>
              <div class="ic-chips" style="flex-wrap:wrap">
                <span class="ic-chip" onclick="setIcEsp('intubado',this)">🫁 Paciente intubado</span>
                <span class="ic-chip" onclick="setIcEsp('dolor',this)">😣 Dolor / no disponible</span>
                <span class="ic-chip" onclick="setIcEsp('nodisponible',this)">🚪 Paciente no disponible</span>
                <span class="ic-chip" onclick="setIcEsp('fuga',this)">🏃 Fuga hospitalaria</span>
                <span class="ic-chip" onclick="setIcEsp('repetida',this)">🔁 IC reiterada sin justificación</span>
                <span class="ic-chip" onclick="setIcEsp('seguimiento',this)">📋 Paciente en seguimiento</span>
                <span class="ic-chip" onclick="setIcEsp('niega',this)">🚫 Se niega a la atención</span>
                <span class="ic-chip" onclick="setIcEsp('nocolaborativo',this)">😶 Paciente cero cooperativo</span>
                <span class="ic-chip" onclick="setIcEsp('sincapacidad',this)">🧠 Sin capacidad cognitiva para intervención</span>
                <span class="ic-chip" onclick="setIcEsp('somnoliento',this)">😴 Paciente somnoliento / hipoactivo</span>
              </div>
              <div id="ic-esp-preview" style="display:none"><div class="ic-sublabel" style="margin-top:12px">Vista previa de la nota</div><div class="esp-preview" id="ic-esp-text"></div></div>
            </div>
          </div>
        </div>
        <!-- BOTONES -->
        <div style="display:flex;gap:10px;margin-top:16px;flex-wrap:wrap">
          <button class="btn btn-primary" onclick="generarNotaIC()">✨ Generar nota clínica</button>
          <button class="btn btn-secondary" onclick="guardarICFirebase()">💾 Guardar en Firebase</button>
        </div>
        <!-- OUTPUT -->
        <div id="ic-output-wrap" style="display:none;margin-top:16px">
          <div class="out-section">
            <div class="out-section-head"><span>Nota clínica — lista para copiar al sistema</span><button class="btn btn-secondary btn-sm" onclick="copiarTodoIC()">Copiar todo</button></div>
            <div id="ic-out-4campos">
              <div class="out-fields">
                <div class="out-field-ic"><button class="copy-field-btn-ic" onclick="copiarCampoIC('ic-out-sub',this)">Copiar</button><div class="out-field-label-ic">Análisis Subjetivo</div><div class="out-text-ic ph" id="ic-out-sub">Genera la nota para ver el contenido…</div></div>
                <div class="out-field-ic"><button class="copy-field-btn-ic" onclick="copiarCampoIC('ic-out-obj',this)">Copiar</button><div class="out-field-label-ic">Análisis Objetivo</div><div class="out-text-ic ph" id="ic-out-obj">Genera la nota para ver el contenido…</div></div>
                <div class="out-field-ic"><button class="copy-field-btn-ic" onclick="copiarCampoIC('ic-out-resp',this)">Copiar</button><div class="out-field-label-ic">Respuesta</div><div class="out-text-ic ph" id="ic-out-resp">Genera la nota para ver el contenido…</div></div>
                <div class="out-field-ic"><button class="copy-field-btn-ic" onclick="copiarCampoIC('ic-out-trat',this)">Copiar</button><div class="out-field-label-ic">Tratamiento</div><div class="out-text-ic ph" id="ic-out-trat">Genera la nota para ver el contenido…</div></div>

              </div>
            </div>
            <div id="ic-out-seg" style="display:none"><div class="out-seg-wrap"><button class="copy-field-btn-ic" onclick="copiarCampoIC('ic-out-seg-texto',this)">Copiar</button><div class="out-field-label-ic">Nota de seguimiento</div><div class="out-text-ic ph" id="ic-out-seg-texto">Genera la nota para ver el contenido…</div></div></div>
          </div>
        </div>
      </div><!-- end ic-form-view -->
    </div>

    <!-- HISTORIAL IC -->
    <div id="page-historial-ic" class="page">
      <div class="section-header">
        <h2>📋 Historial de Interconsultas</h2>
      </div>
      <div id="lista-ic"><div class="loading"><div class="spinner"></div><br>Cargando…</div></div>
    </div>

    <!-- ANAMNESIS -->
    <div id="page-anamnesis" class="page">
      <div class="section-header">
        <h2 id="anam-page-title">Anamnesis Psicológica</h2>
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
          <select id="anamnesis-paciente-sel" onchange="selectAnamPaciente(this.value)" style="padding:7px 11px;border:1px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:0.85rem;min-width:190px">
            <option value="">— Seleccionar paciente —</option>
          </select>
          <button class="btn btn-secondary" onclick="clearAnamnesis()">Nueva</button>
        </div>
      </div>
      <!-- Tabs -->
      <div id="anam-tabs" style="display:flex;gap:0;border-bottom:2px solid var(--border);margin-bottom:20px">
        <button id="anam-tab-primera" onclick="anamSwitchTab('primera')" style="padding:9px 20px;border:none;background:none;font-family:'DM Sans',sans-serif;font-size:0.85rem;font-weight:600;color:var(--accent);border-bottom:2px solid var(--accent);margin-bottom:-2px;cursor:pointer">📋 Primera vez</button>
        <button id="anam-tab-sesion" onclick="anamSwitchTab('sesion')" style="padding:9px 20px;border:none;background:none;font-family:'DM Sans',sans-serif;font-size:0.85rem;font-weight:500;color:var(--text2);border-bottom:2px solid transparent;margin-bottom:-2px;cursor:pointer">📝 Nota de sesión</button>
        <button id="anam-tab-historial" onclick="anamSwitchTab('historial')" style="padding:9px 20px;border:none;background:none;font-family:'DM Sans',sans-serif;font-size:0.85rem;font-weight:500;color:var(--text2);border-bottom:2px solid transparent;margin-bottom:-2px;cursor:pointer">📂 Sesiones anteriores</button>
      </div>
      <!-- Panel nota de sesión -->
      <div id="anam-panel-sesion" style="display:none">
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:22px 24px;max-width:820px">

          <!-- Cabecera -->
          <div style="text-align:center;margin-bottom:18px;padding-bottom:14px;border-bottom:2px solid var(--accent)">
            <div style="font-family:'DM Serif Display',serif;font-size:1.15rem;font-weight:700;color:var(--accent)">REGISTRO DE EVOLUCIÓN TERAPÉUTICA</div>
          </div>
          <div style="display:grid;grid-template-columns:1fr auto auto;gap:12px;align-items:end;margin-bottom:18px;flex-wrap:wrap">
            <div class="form-group">
              <label>Paciente</label>
              <select id="seg-pac-sel" onchange="anamSegSelectPac(this.value)" style="padding:8px 11px;border:1px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:0.85rem;width:100%">
                <option value="">— Seleccionar paciente —</option>
              </select>
            </div>
            <div class="form-group"><label>Fecha</label><input type="date" id="seg-fecha" style="width:140px"></div>
            <div class="form-group"><label>Sesión #</label><input type="number" id="seg-num" min="1" placeholder="—" style="width:80px;padding:8px 11px;border:1px solid var(--border);border-radius:8px;font-size:0.85rem"></div>
          </div>

          <!-- I. DATOS CLAVES -->
          <div style="background:var(--surface2);border-radius:8px;padding:14px 16px;margin-bottom:14px">
            <div style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--accent);margin-bottom:12px">I. Datos claves de la sesión</div>

            <div style="margin-bottom:12px">
              <div style="font-size:0.8rem;font-weight:600;margin-bottom:6px">1. Estado actual del paciente</div>
              <div style="font-size:0.8rem;color:var(--text2);margin-bottom:6px">Humor predominante:</div>
              <div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:8px">
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-humor-estable"> Estable</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-humor-ansioso"> Ansioso</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-humor-depresivo"> Depresivo</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-humor-irritable"> Irritable</label>
                <span style="font-size:0.82rem;color:var(--text2);display:flex;align-items:center;gap:5px">Escala 1-5: <input type="number" id="seg-humor-escala" min="1" max="5" style="width:50px;padding:3px 7px;border:1px solid var(--border);border-radius:6px;font-size:0.82rem"></span>
              </div>
              <div class="form-group"><label>Eventos relevantes desde última sesión</label><textarea id="seg-eventos" rows="2" placeholder="¿Qué pasó desde la última vez que se vieron?..."></textarea></div>
            </div>

            <div>
              <div style="font-size:0.8rem;font-weight:600;margin-bottom:6px">2. Revisión de tareas asignadas</div>
              <div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:8px">
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-tarea-completa"> Completa</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-tarea-parcial"> Parcial</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-tarea-no"> No realizada</label>
              </div>
              <div class="form-group"><label>Dificultades encontradas</label><textarea id="seg-dificultades" rows="2" placeholder="¿Qué obstáculos encontró para realizar la tarea?..."></textarea></div>
            </div>
          </div>

          <!-- II. PROCESO TERAPÉUTICO -->
          <div style="background:var(--surface2);border-radius:8px;padding:14px 16px;margin-bottom:14px">
            <div style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--accent);margin-bottom:12px">II. Proceso terapéutico — Foco TCC</div>

            <div style="margin-bottom:12px">
              <div style="font-size:0.8rem;font-weight:600;margin-bottom:6px">1. Técnicas aplicadas en sesión</div>
              <div style="display:flex;flex-direction:column;gap:8px">
                <label style="display:flex;align-items:flex-start;gap:7px;font-size:0.82rem;cursor:pointer;line-height:1.4">
                  <input type="checkbox" id="seg-tec-reest" style="margin-top:2px">
                  <span>Reestructuración cognitiva — Efectividad 1-5: <input type="number" id="seg-tec-reest-ef" min="1" max="5" style="width:45px;padding:2px 6px;border:1px solid var(--border);border-radius:5px;font-size:0.8rem"></span>
                </label>
                <label style="display:flex;align-items:flex-start;gap:7px;font-size:0.82rem;cursor:pointer;line-height:1.4">
                  <input type="checkbox" id="seg-tec-expos" style="margin-top:2px">
                  <span>Exposición gradual — Nivel de ansiedad máximo: <input type="number" id="seg-tec-expos-nivel" min="0" max="10" style="width:45px;padding:2px 6px;border:1px solid var(--border);border-radius:5px;font-size:0.8rem">/10</span>
                </label>
                <label style="display:flex;align-items:flex-start;gap:7px;font-size:0.82rem;cursor:pointer;line-height:1.4">
                  <input type="checkbox" id="seg-tec-dbt" style="margin-top:2px">
                  <span>Entrenamiento habilidades DBT (TLP): 
                    <label style="margin-left:8px"><input type="checkbox" id="seg-tec-dbt-tol"> Tolerancia al malestar</label>
                    <label style="margin-left:8px"><input type="checkbox" id="seg-tec-dbt-reg"> Regulación emocional</label>
                  </span>
                </label>
                <label style="display:flex;align-items:flex-start;gap:7px;font-size:0.82rem;cursor:pointer;line-height:1.4">
                  <input type="checkbox" id="seg-tec-psico" style="margin-top:2px">
                  <span>Psicoeducación sobre: <input type="text" id="seg-tec-psico-tema" placeholder="tema..." style="border:none;border-bottom:1px solid var(--border);background:transparent;font-size:0.82rem;outline:none;width:200px;padding:1px 4px"></span>
                </label>
                <label style="display:flex;align-items:flex-start;gap:7px;font-size:0.82rem;cursor:pointer;line-height:1.4">
                  <input type="checkbox" id="seg-tec-otras" style="margin-top:2px">
                  <span>Otra técnica: <input type="text" id="seg-tec-otras-cual" placeholder="especificar..." style="border:none;border-bottom:1px solid var(--border);background:transparent;font-size:0.82rem;outline:none;width:200px;padding:1px 4px"></span>
                </label>
              </div>
            </div>

            <div>
              <div style="font-size:0.8rem;font-weight:600;margin-bottom:8px">2. Cogniciones identificadas</div>
              <div class="form-group" style="margin-bottom:8px"><label>Pensamiento automático clave</label><textarea id="seg-pensamiento" rows="2" placeholder='"Soy un fracasado", "Nunca voy a mejorar"...'></textarea></div>
              <div style="font-size:0.8rem;color:var(--text2);margin-bottom:6px">Distorsión cognitiva:</div>
              <div style="display:flex;gap:10px;flex-wrap:wrap">
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-dist-catas"> Catastrofismo</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-dist-person"> Personalización</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-dist-polar"> Pensamiento polarizado</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-dist-sobre"> Sobregeneralización</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-dist-filtr"> Filtro mental</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-dist-otra"> Otra: <input type="text" id="seg-dist-otra-cual" style="border:none;border-bottom:1px solid var(--border);background:transparent;font-size:0.82rem;outline:none;width:130px;padding:1px 4px"></label>
              </div>
            </div>
          </div>

          <!-- III. PLAN DE ACCIÓN -->
          <div style="background:var(--surface2);border-radius:8px;padding:14px 16px;margin-bottom:14px">
            <div style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--accent);margin-bottom:12px">III. Plan de acción</div>

            <div style="margin-bottom:12px">
              <div style="font-size:0.8rem;font-weight:600;margin-bottom:8px">1. Tareas para próxima sesión</div>
              <div style="display:flex;flex-direction:column;gap:7px">
                <label style="display:flex;align-items:center;gap:7px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-tarea-reg"> Registro de pensamientos (Situación → Emoción → Pensamiento)</label>
                <label style="display:flex;align-items:flex-start;gap:7px;font-size:0.82rem;cursor:pointer;line-height:1.4">
                  <input type="checkbox" id="seg-tarea-dbt2" style="margin-top:2px">
                  <span>Práctica habilidad DBT: <input type="text" id="seg-tarea-dbt2-cual" placeholder="especificar..." style="border:none;border-bottom:1px solid var(--border);background:transparent;font-size:0.82rem;outline:none;width:200px;padding:1px 4px"></span>
                </label>
                <label style="display:flex;align-items:flex-start;gap:7px;font-size:0.82rem;cursor:pointer;line-height:1.4">
                  <input type="checkbox" id="seg-tarea-otra2" style="margin-top:2px">
                  <span>Otra: <input type="text" id="seg-tarea-otra2-cual" placeholder="especificar..." style="border:none;border-bottom:1px solid var(--border);background:transparent;font-size:0.82rem;outline:none;width:260px;padding:1px 4px"></span>
                </label>
              </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
              <div class="form-group"><label>Objetivo corto plazo — próxima sesión</label><textarea id="seg-obj-corto" rows="2" placeholder="Ej: Practicar respiración ante situaciones de ansiedad..."></textarea></div>
              <div class="form-group"><label>Objetivo largo plazo</label><textarea id="seg-obj-largo" rows="2" placeholder="Ej: Reducir evitación social y mejorar autoestima..."></textarea></div>
            </div>
          </div>

          <!-- IV. NOTAS CLÍNICAS -->
          <div style="background:var(--surface2);border-radius:8px;padding:14px 16px;margin-bottom:14px">
            <div style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--accent);margin-bottom:12px">IV. Notas clínicas</div>

            <div style="margin-bottom:12px">
              <div style="font-size:0.8rem;font-weight:600;margin-bottom:8px">1. Observaciones relevantes</div>
              <div style="font-size:0.8rem;color:var(--text2);margin-bottom:6px">Riesgos detectados:</div>
              <div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:10px">
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-riesgo-ideacion"> Ideación suicida</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-riesgo-autolesion"> Autolesiones</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-riesgo-otro"> Otro: <input type="text" id="seg-riesgo-otro-cual" style="border:none;border-bottom:1px solid var(--border);background:transparent;font-size:0.82rem;outline:none;width:140px;padding:1px 4px;margin-left:4px"></label>
              </div>
              <div style="font-size:0.8rem;color:var(--text2);margin-bottom:6px">Recursos del paciente:</div>
              <div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:10px">
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-rec-insight"> Insight</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-rec-motiv"> Motivación</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="checkbox" id="seg-rec-apoyo"> Apoyo social</label>
              </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
              <div class="form-group"><label>Nivel de riesgo suicida</label>
                <select id="seg-riesgo"><option value="">Sin cambios / No aplica</option><option value="SIN RIESGO">SIN RIESGO</option><option value="BAJO">BAJO</option><option value="MEDIO">MEDIO</option><option value="ALTO">ALTO</option></select>
              </div>
              <div class="form-group"><label>Ajustes terapéuticos</label><textarea id="seg-ajustes" rows="2" placeholder='Ej: "Reducir velocidad por crisis actual"...'></textarea></div>
            </div>
          </div>

          <!-- V. ESCALAS -->
          <div style="background:var(--surface2);border-radius:8px;padding:14px 16px;margin-bottom:18px">
            <div style="font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--accent);margin-bottom:12px">V. Escalas de medición <span style="font-weight:400;text-transform:none;letter-spacing:0;color:var(--text3)">(Opcional)</span></div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px">
              <div style="font-size:0.82rem">PHQ-9 (Depresión)<br>
                <span style="color:var(--text3);font-size:0.75rem">Inicial:</span> <input type="number" id="seg-phq-ini" style="width:45px;padding:2px 6px;border:1px solid var(--border);border-radius:5px;font-size:0.8rem">
                <span style="color:var(--text3);font-size:0.75rem;margin-left:6px">Actual:</span> <input type="number" id="seg-phq-act" style="width:45px;padding:2px 6px;border:1px solid var(--border);border-radius:5px;font-size:0.8rem">
              </div>
              <div style="font-size:0.82rem">GAD-7 (Ansiedad)<br>
                <span style="color:var(--text3);font-size:0.75rem">Inicial:</span> <input type="number" id="seg-gad-ini" style="width:45px;padding:2px 6px;border:1px solid var(--border);border-radius:5px;font-size:0.8rem">
                <span style="color:var(--text3);font-size:0.75rem;margin-left:6px">Actual:</span> <input type="number" id="seg-gad-act" style="width:45px;padding:2px 6px;border:1px solid var(--border);border-radius:5px;font-size:0.8rem">
              </div>
              <div style="font-size:0.82rem">Impulsividad (TLP)<br>
                <input type="number" id="seg-impuls" min="0" max="10" style="width:45px;padding:2px 6px;border:1px solid var(--border);border-radius:5px;font-size:0.8rem"> / 10
              </div>
            </div>
          </div>

          <!-- Próxima cita + botones -->
          <div style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;padding-top:14px;border-top:1px solid var(--border)">
            <div class="form-group"><label>Próxima cita</label><input type="date" id="seg-proxcita" style="padding:8px 11px;border:1px solid var(--border);border-radius:8px;font-size:0.85rem"></div>
            <div class="form-group"><label>Modalidad</label>
              <div style="display:flex;gap:12px;padding:9px 0">
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="radio" name="seg-modalidad" value="Presencial" id="seg-mod-pres"> Presencial</label>
                <label style="display:flex;align-items:center;gap:5px;font-size:0.82rem;cursor:pointer"><input type="radio" name="seg-modalidad" value="Online" id="seg-mod-online"> Online</label>
              </div>
            </div>
            <div style="margin-left:auto;display:flex;gap:10px">
              <button class="btn btn-secondary" onclick="anamSegLimpiar()">🗑 Limpiar</button>
              <button class="btn btn-primary" onclick="anamSegGuardar()">💾 Guardar nota de sesión</button>
            </div>
          </div>
        </div>
      </div>
      <!-- Panel historial sesiones -->
      <div id="anam-panel-historial" style="display:none">
        <div style="margin-bottom:14px;display:flex;gap:10px;align-items:center;flex-wrap:wrap">
          <select id="seg-historial-pac-sel" onchange="anamHistorialRender(this.value)" style="padding:8px 11px;border:1px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:0.85rem;min-width:220px">
            <option value="">— Seleccionar paciente —</option>
          </select>
          <span id="seg-historial-count" style="font-size:0.8rem;color:var(--text3)"></span>
        </div>
        <div id="seg-historial-lista"></div>
      </div>
      <div class="timer-bar">
        <div class="timer-step"><div class="ts-time">0–5 min</div>Escucha / motivo</div>
        <div class="timer-step"><div class="ts-time">5–15 min</div>Historia</div>
        <div class="timer-step"><div class="ts-time">15–20 min</div>Examen mental</div>
        <div class="timer-step"><div class="ts-time">20–25 min</div>Diagnóstico</div>
        <div class="timer-step"><div class="ts-time">25–30 min</div>Plan</div>
      </div>
      <form id="form-anamnesis">
        <div class="anamnesis-section">
          <div class="anamnesis-section-header open" onclick="toggleSection(this)"><span>🪪</span><h4>Datos de identificación</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body open"><div class="form-grid">
            <div class="form-group"><label>Fecha</label><input type="date" id="an-fecha"></div>
            <div class="form-group"><label>Nombre completo</label><input type="text" id="an-nombre"></div>
            <div class="form-group"><label>Edad</label><input type="number" id="an-edad" min="0" max="120"></div>
            <div class="form-group"><label>Cédula</label><input type="text" id="an-cedula"></div>
            <div class="form-group"><label>Estado civil</label><select id="an-ecivil"><option value="">Seleccionar...</option><option>Soltero/a</option><option>Casado/a</option><option>Unión libre</option><option>Separado/a</option><option>Divorciado/a</option><option>Viudo/a</option></select></div>
            <div class="form-group"><label>Escolaridad</label><select id="an-esc"><option value="">Seleccionar...</option><option>Ninguna</option><option>Primaria</option><option>Secundaria</option><option>Técnico/Tecnólogo</option><option>Universitario</option><option>Posgrado</option></select></div>
            <div class="form-group"><label>Ocupación</label><input type="text" id="an-ocupacion"></div>
            <div class="form-group"><label>Remitido por</label><input type="text" id="an-remitido"></div>
          </div></div>
        </div>
        <div class="anamnesis-section">
          <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>💬</span><h4>Motivo de consulta</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body"><div class="form-group"><label>En palabras del paciente</label><textarea id="an-motivo" placeholder='"¿Qué le trae por aquí hoy?"'></textarea></div></div>
        </div>
        <div class="anamnesis-section">
          <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>📖</span><h4>Historia del problema actual</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body"><div class="form-grid">
            <div class="form-group"><label>Inicio</label><div class="checkgroup"><label><input type="radio" name="an-inicio" value="Repentino"><span>Repentino</span></label><label><input type="radio" name="an-inicio" value="Gradual"><span>Gradual</span></label></div></div>
            <div class="form-group"><label>Tiempo de evolución</label><input type="text" id="an-evolucion" placeholder="Ej: 3 meses"></div>
            <div class="form-group full"><label>Desencadenantes</label><div class="checkgroup" id="an-desenc"><label><input type="checkbox" value="Laboral"><span>Laboral</span></label><label><input type="checkbox" value="Familiar"><span>Familiar</span></label><label><input type="checkbox" value="Pareja"><span>Pareja</span></label><label><input type="checkbox" value="Académico"><span>Académico</span></label><label><input type="checkbox" value="Duelo"><span>Duelo</span></label><label><input type="checkbox" value="Salud propia"><span>Salud propia</span></label><label><input type="checkbox" value="Económico"><span>Económico</span></label><label><input type="checkbox" value="Otro"><span>Otro</span></label></div></div>
            <div class="form-group full"><label>Síntomas principales</label><div class="checkgroup" id="an-sint"><label><input type="checkbox" value="Tristeza"><span>Tristeza</span></label><label><input type="checkbox" value="Ansiedad"><span>Ansiedad</span></label><label><input type="checkbox" value="Miedo"><span>Miedo</span></label><label><input type="checkbox" value="Irritabilidad"><span>Irritabilidad</span></label><label><input type="checkbox" value="Insomnio"><span>Insomnio</span></label><label><input type="checkbox" value="Apatía"><span>Apatía</span></label><label><input type="checkbox" value="Anhedonia"><span>Anhedonia</span></label><label><input type="checkbox" value="Desesperanza"><span>Desesperanza</span></label><label><input type="checkbox" value="Ataques de pánico"><span>Ataques de pánico</span></label><label><input type="checkbox" value="Alucinaciones"><span>Alucinaciones</span></label></div></div>
            <div class="form-group"><label>Intensidad (1–10): <strong id="an-intens-val">5</strong></label><input type="range" id="an-intens" min="1" max="10" value="5" oninput="document.getElementById('an-intens-val').textContent=this.value" style="margin-top:8px"></div>
            <div class="form-group full"><label>Impacto funcional</label><div class="checkgroup" id="an-impacto"><label><input type="checkbox" value="Laboral"><span>Laboral</span></label><label><input type="checkbox" value="Familiar"><span>Familiar</span></label><label><input type="checkbox" value="Social"><span>Social</span></label><label><input type="checkbox" value="Pareja"><span>Pareja</span></label><label><input type="checkbox" value="Autocuidado"><span>Autocuidado</span></label></div></div>
            <div class="form-group full"><label>Descripción</label><textarea id="an-descripcion" rows="3"></textarea></div>
          </div></div>
        </div>
        <div class="anamnesis-section">
          <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>🗂️</span><h4>Antecedentes de salud mental</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body"><div class="form-grid">
            <div class="form-group"><label>Tto. psicológico previo</label><div class="checkgroup"><label><input type="radio" name="an-tpsi" value="No"><span>No</span></label><label><input type="radio" name="an-tpsi" value="Sí"><span>Sí</span></label></div></div>
            <div class="form-group"><label>¿Cuándo? / ¿Dónde?</label><input type="text" id="an-tpsi-cuando" placeholder="Ej: 2022, Hospital X"></div>
            <div class="form-group"><label>Tto. psiquiátrico previo</label><div class="checkgroup"><label><input type="radio" name="an-tpsiq" value="No"><span>No</span></label><label><input type="radio" name="an-tpsiq" value="Sí"><span>Sí</span></label></div></div>
            <div class="form-group"><label>¿Cuándo? / Diagnóstico previo</label><input type="text" id="an-tpsiq-dx" placeholder="Ej: 2021, depresión mayor"></div>
            <div class="form-group full"><label>Diagnósticos psiquiátricos previos conocidos</label><div class="checkgroup" id="an-dx-previos"><label><input type="checkbox" value="Trastorno depresivo mayor"><span>Depresión mayor</span></label><label><input type="checkbox" value="Trastorno de ansiedad generalizada"><span>TAG</span></label><label><input type="checkbox" value="Trastorno bipolar"><span>Trastorno bipolar</span></label><label><input type="checkbox" value="TEPT"><span>TEPT</span></label><label><input type="checkbox" value="Trastorno de pánico"><span>Pánico</span></label><label><input type="checkbox" value="TOC"><span>TOC</span></label><label><input type="checkbox" value="Trastorno de personalidad"><span>T. personalidad</span></label><label><input type="checkbox" value="Esquizofrenia / Psicosis"><span>Psicosis</span></label><label><input type="checkbox" value="TDAH"><span>TDAH</span></label><label><input type="checkbox" value="Otro"><span>Otro</span></label><label><input type="checkbox" value="Ninguno conocido"><span>Ninguno conocido</span></label></div></div>
            <div class="form-group"><label>Hospitalizaciones psiquiátricas</label><div class="checkgroup"><label><input type="radio" name="an-hosp-psiq" value="No"><span>No</span></label><label><input type="radio" name="an-hosp-psiq" value="Sí"><span>Sí</span></label></div></div>
            <div class="form-group"><label>N° de hospitalizaciones / ¿Cuándo?</label><input type="text" id="an-hosp-psiq-det" placeholder="Ej: 2 veces, última en 2023"></div>
            <div class="form-group"><label>Ideación suicida previa</label><div class="checkgroup"><label><input type="radio" name="an-is-prev" value="No"><span>No</span></label><label><input type="radio" name="an-is-prev" value="Sí — pasiva"><span>Sí — pasiva</span></label><label><input type="radio" name="an-is-prev" value="Sí — activa"><span>Sí — activa</span></label></div></div>
            <div class="form-group"><label>Intentos de suicidio previos</label><div class="checkgroup"><label><input type="radio" name="an-is" value="No"><span>No</span></label><label><input type="radio" name="an-is" value="Sí"><span>Sí</span></label></div></div>
            <div class="form-group"><label>N° intentos / ¿Cuándo?</label><input type="text" id="an-is-det" placeholder="Ej: 1 vez, hace 2 años"></div>
            <div class="form-group"><label>Medicamentos actuales (psiquiátricos)</label><input type="text" id="an-meds" placeholder="Ej: Sertralina 50mg, Clonazepam 0.5mg"></div>
            <div class="form-group"><label>Medicamentos previos relevantes</label><input type="text" id="an-meds-prev" placeholder="Ej: Fluoxetina (suspendida por efectos secundarios)"></div>
            <div class="form-group"><label>Enfermedades médicas</label><input type="text" id="an-enf"></div>
            <div class="form-group full"><label>Autolesiones sin intención suicida</label><div class="checkgroup" id="an-autolesion"><label><input type="checkbox" value="Ninguna"><span>Ninguna</span></label><label><input type="checkbox" value="Cortes / rasguños"><span>Cortes / rasguños</span></label><label><input type="checkbox" value="Golpes a sí mismo/a"><span>Golpes a sí mismo/a</span></label><label><input type="checkbox" value="Quemaduras"><span>Quemaduras</span></label><label><input type="checkbox" value="Otro"><span>Otro</span></label></div></div>
            <div class="form-group full"><label>Red de apoyo</label><div class="checkgroup"><label><input type="radio" name="an-red" value="Adecuada"><span>Adecuada</span></label><label><input type="radio" name="an-red" value="Escasa"><span>Escasa</span></label><label><input type="radio" name="an-red" value="Ausente"><span>Ausente</span></label><label><input type="radio" name="an-red" value="Conflictiva"><span>Conflictiva</span></label></div></div>
          </div></div>
        </div>
        <!-- HISTORIA PERSONAL Y SOCIAL -->
        <div class="anamnesis-section">
          <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>🏠</span><h4>Historia personal y social</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body"><div class="form-grid">
            <div class="form-group full"><label>¿Con quién vive?</label><input type="text" id="an-convive" placeholder="Ej: Esposo/a e hijos, solo/a, familia de origen"></div>
            <div class="form-group full"><label>Dinámica familiar</label><div class="checkgroup" id="an-dinamica"><label><input type="checkbox" value="Funcional"><span>Funcional</span></label><label><input type="checkbox" value="Conflictiva"><span>Conflictiva</span></label><label><input type="checkbox" value="Ausente"><span>Ausente</span></label><label><input type="checkbox" value="Sobreprotectora"><span>Sobreprotectora</span></label></div></div>
            <div class="form-group full"><label>Relaciones interpersonales</label><div class="checkgroup"><label><input type="radio" name="an-relaciones" value="Adecuadas"><span>Adecuadas</span></label><label><input type="radio" name="an-relaciones" value="Escasas"><span>Escasas</span></label><label><input type="radio" name="an-relaciones" value="Conflictivas"><span>Conflictivas</span></label><label><input type="radio" name="an-relaciones" value="Aislamiento"><span>Aislamiento</span></label></div></div>
            <div class="form-group full"><label>Situación de pareja</label><div class="checkgroup"><label><input type="radio" name="an-pareja" value="Estable"><span>Estable</span></label><label><input type="radio" name="an-pareja" value="Inestable"><span>Inestable</span></label><label><input type="radio" name="an-pareja" value="Sin pareja"><span>Sin pareja</span></label></div></div>
            <div class="form-group full"><label>Historia de violencia — tamizaje (marcar si aplica)</label><div class="checkgroup" id="an-violencia"><label><input type="checkbox" value="Ninguna reportada"><span>Ninguna reportada</span></label><label><input type="checkbox" value="Maltrato infantil físico"><span>Maltrato físico infantil</span></label><label><input type="checkbox" value="Maltrato infantil psicológico"><span>Maltrato psicológico infantil</span></label><label><input type="checkbox" value="Abuso sexual en la infancia"><span>Abuso sexual infantil</span></label><label><input type="checkbox" value="Abuso sexual en la adultez"><span>Abuso sexual adultez</span></label><label><input type="checkbox" value="Violencia de pareja — física"><span>VIF física</span></label><label><input type="checkbox" value="Violencia de pareja — psicológica"><span>VIF psicológica</span></label><label><input type="checkbox" value="Violencia de pareja — sexual"><span>VIF sexual</span></label><label><input type="checkbox" value="Conflicto armado / desplazamiento"><span>Conflicto armado / desplazamiento</span></label><label><input type="checkbox" value="Testigo de violencia intrafamiliar"><span>Testigo de violencia familiar</span></label><label><input type="checkbox" value="Acoso escolar (bullying)"><span>Bullying</span></label><label><input type="checkbox" value="Acoso laboral (mobbing)"><span>Acoso laboral</span></label></div></div>
            <div class="form-group full"><label>Observaciones de violencia / contexto adicional</label><textarea id="an-violencia-obs" rows="2" placeholder="Solo detectar, no elaborar. Ej: refiere VIF actual, pareja controladora. Remitir a trabajo social si es necesario."></textarea></div>
            <div class="form-group full"><label>Rendimiento escolar / laboral</label><div class="checkgroup"><label><input type="radio" name="an-rendimiento" value="Bueno"><span>Bueno</span></label><label><input type="radio" name="an-rendimiento" value="Regular"><span>Regular</span></label><label><input type="radio" name="an-rendimiento" value="Malo"><span>Malo</span></label></div></div>
          </div></div>
        </div>
        <!-- HÁBITOS DE ALIMENTACIÓN Y SUEÑO -->
        <div class="anamnesis-section">
          <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>🍽️</span><h4>Hábitos de alimentación, sueño y sustancias</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body"><div class="form-grid">
            <div class="form-group full"><label>Alimentación</label><div class="checkgroup" id="an-alimentacion"><label><input type="checkbox" value="Adecuada"><span>Adecuada</span></label><label><input type="checkbox" value="Apetito reducido"><span>Apetito reducido</span></label><label><input type="checkbox" value="Apetito aumentado"><span>Apetito aumentado</span></label><label><input type="checkbox" value="Pérdida de peso significativa"><span>Pérdida de peso significativa</span></label><label><input type="checkbox" value="Atracones / restricción"><span>Atracones / restricción</span></label><label><input type="checkbox" value="Dieta restrictiva">  <span>Dieta restrictiva</span></label></div></div>
            <div class="form-group full"><label>Sueño</label><div class="checkgroup" id="an-sueno"><label><input type="checkbox" value="Conservado"><span>Conservado</span></label><label><input type="checkbox" value="Insomnio de conciliación"><span>Insomnio de conciliación</span></label><label><input type="checkbox" value="Insomnio de mantenimiento"><span>Insomnio de mantenimiento</span></label><label><input type="checkbox" value="Despertar temprano"><span>Despertar temprano</span></label><label><input type="checkbox" value="Pesadillas"><span>Pesadillas</span></label><label><input type="checkbox" value="Hipersomnia"><span>Hipersomnia</span></label><label><input type="checkbox" value="Insomnio severo"><span>Insomnio severo</span></label></div></div>
            <div class="form-group"><label>Horas promedio de sueño</label><input type="text" id="an-horas-sueno" placeholder="Ej: 4–5 horas"></div>
            <div class="form-group"><label>Calidad del sueño (1-10)</label><input type="number" id="an-calidad-sueno" min="1" max="10" placeholder="1=pésima, 10=excelente"></div>
            <div class="form-group full"><label>Consumo de sustancias</label><div class="checkgroup" id="an-sustancias"><label><input type="checkbox" value="Niega consumo"><span>Niega consumo</span></label><label><input type="checkbox" value="Alcohol ocasional"><span>Alcohol ocasional</span></label><label><input type="checkbox" value="Alcohol problemático"><span>Alcohol problemático</span></label><label><input type="checkbox" value="Tabaco"><span>Tabaco</span></label><label><input type="checkbox" value="Marihuana"><span>Marihuana</span></label><label><input type="checkbox" value="Cocaína"><span>Cocaína</span></label><label><input type="checkbox" value="Benzodiacepinas sin Rx"><span>Benzodiacepinas sin Rx</span></label></div></div>
            <div class="form-group full"><label>Frecuencia / descripción consumo</label><div class="checkgroup"><label><input type="radio" name="an-freq-sust" value="Diario"><span>Diario</span></label><label><input type="radio" name="an-freq-sust" value="Semanal"><span>Semanal</span></label><label><input type="radio" name="an-freq-sust" value="Quincenal"><span>Quincenal</span></label><label><input type="radio" name="an-freq-sust" value="Ocasional"><span>Ocasional</span></label><label><input type="radio" name="an-freq-sust" value="N/A"><span>N/A</span></label></div></div>
          </div></div>
        </div>
        <!-- ANTECEDENTES FAMILIARES -->
        <div class="anamnesis-section">
          <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>👨‍👩‍👧</span><h4>Antecedentes familiares</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body"><div class="form-grid">
            <div class="form-group full"><label>Trastorno mental en familiares</label><div class="checkgroup"><label><input type="radio" name="an-fam-tmh" value="No"><span>No</span></label><label><input type="radio" name="an-fam-tmh" value="Sí"><span>Sí</span></label></div></div>
            <div class="form-group"><label>¿Quién? y ¿Diagnóstico?</label><input type="text" id="an-fam-quien" placeholder="Ej: Madre — depresión"></div>
            <div class="form-group"><label>Suicidio en familiares</label><div class="checkgroup"><label><input type="radio" name="an-fam-suicidio" value="No"><span>No</span></label><label><input type="radio" name="an-fam-suicidio" value="Sí"><span>Sí</span></label></div></div>
            <div class="form-group"><label>¿Quién?</label><input type="text" id="an-fam-suicidio-quien" placeholder="Ej: Hermano"></div>
          </div></div>
        </div>
        <div class="anamnesis-section">
          <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>🧠</span><h4>Examen mental</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body"><div class="form-grid">
            <div class="form-group full"><label>Orientación</label><div class="checkgroup" id="an-orient"><label><input type="checkbox" value="Tiempo"><span>Tiempo</span></label><label><input type="checkbox" value="Espacio"><span>Espacio</span></label><label><input type="checkbox" value="Persona"><span>Persona</span></label><label><input type="checkbox" value="Desorientado/a"><span>Desorientado/a</span></label></div></div>
            <div class="form-group full"><label>Afecto</label><div class="checkgroup" id="an-afecto"><label><input type="checkbox" value="Eutímico"><span>Eutímico</span></label><label><input type="checkbox" value="Depresivo"><span>Depresivo</span></label><label><input type="checkbox" value="Ansioso"><span>Ansioso</span></label><label><input type="checkbox" value="Lábil"><span>Lábil</span></label><label><input type="checkbox" value="Aplanado"><span>Aplanado</span></label></div></div>
            <div class="form-group full"><label>Pensamiento — Curso</label><div class="checkgroup"><label><input type="radio" name="an-pcurso" value="Lógico"><span>Lógico</span></label><label><input type="radio" name="an-pcurso" value="Bradipsiquia"><span>Bradipsiquia</span></label><label><input type="radio" name="an-pcurso" value="Taquipsiquia"><span>Taquipsiquia</span></label><label><input type="radio" name="an-pcurso" value="Bloqueo"><span>Bloqueo</span></label></div></div>
            <div class="form-group full"><label>Insight</label><div class="checkgroup" id="an-insight"><label><input type="checkbox" value="Conservado"><span>Conservado</span></label><label><input type="checkbox" value="Parcial"><span>Parcial</span></label><label><input type="checkbox" value="Sin insight"><span>Sin insight</span></label></div></div>
            <div class="form-group full"><label>Memoria y atención</label><div class="checkgroup"><label><input type="radio" name="an-mem" value="Conservadas"><span>Conservadas</span></label><label><input type="radio" name="an-mem" value="Atención deteriorada"><span>Atención deteriorada</span></label><label><input type="radio" name="an-mem" value="Memoria deteriorada"><span>Memoria deteriorada</span></label><label><input type="radio" name="an-mem" value="Ambas deterioradas"><span>Ambas deterioradas</span></label></div></div>
          </div></div>
        </div>
        <div class="anamnesis-section">
          <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>🧠</span><h4>Distorsiones cognitivas</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body"><div class="form-grid">
            <div class="form-group full"><div class="checkgroup" id="an-distorsiones"><label><input type="checkbox" value="Pensamiento todo o nada"><span>Pensamiento todo o nada</span></label><label><input type="checkbox" value="Sobregeneralización"><span>Sobregeneralización</span></label><label><input type="checkbox" value="Filtro mental"><span>Filtro mental</span></label><label><input type="checkbox" value="Descalificar lo positivo"><span>Descalificar lo positivo</span></label><label><input type="checkbox" value="Lectura de mente"><span>Lectura de mente</span></label><label><input type="checkbox" value="Error del adivino"><span>Error del adivino</span></label><label><input type="checkbox" value="Catastrofismo / Minimización"><span>Catastrofismo / Minimización</span></label><label><input type="checkbox" value="Razonamiento emocional"><span>Razonamiento emocional</span></label><label><input type="checkbox" value="Deberías (Imperativos)"><span>Deberías</span></label><label><input type="checkbox" value="Etiquetado"><span>Etiquetado</span></label><label><input type="checkbox" value="Personalización"><span>Personalización</span></label><label><input type="checkbox" value="Falacia de justicia"><span>Falacia de justicia</span></label><label><input type="checkbox" value="Ninguna"><span>Ninguna</span></label></div></div>
          </div></div>
        </div>
        <div class="anamnesis-section">
          <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>💭</span><h4>Ideas irracionales</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body"><div class="form-grid">
            <div class="form-group full"><div class="checkgroup" id="an-irracionales"><label><input type="checkbox" value="Necesidad de aprobación"><span>Necesidad de aprobación</span></label><label><input type="checkbox" value="Exigencia de competencia"><span>Exigencia de competencia</span></label><label><input type="checkbox" value="Culpar y castigar"><span>Culpar y castigar</span></label><label><input type="checkbox" value="Catastrofismo"><span>Catastrofismo</span></label><label><input type="checkbox" value="Victimismo"><span>Victimismo</span></label><label><input type="checkbox" value="Preocupación por peligros"><span>Preocupación por peligros</span></label><label><input type="checkbox" value="Evitación de problemas"><span>Evitación de problemas</span></label><label><input type="checkbox" value="Dependencia"><span>Dependencia</span></label><label><input type="checkbox" value="Determinismo"><span>Determinismo</span></label><label><input type="checkbox" value="Preocupación por problemas ajenos"><span>Preoc. problemas ajenos</span></label><label><input type="checkbox" value="Perfeccionismo"><span>Perfeccionismo</span></label><label><input type="checkbox" value="Falacia de la recompensa"><span>Falacia de la recompensa</span></label><label><input type="checkbox" value="Ninguna"><span>Ninguna</span></label></div></div>
          </div></div>
        </div>
        <div class="anamnesis-section">
          <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>🔴</span><h4>Riesgo suicida — NUNCA OMITIR</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body"><div class="form-grid">
            <div class="form-group full"><label>Ideación actual</label><div class="checkgroup"><label><input type="radio" name="an-ideacion" value="Ninguna"><span>Ninguna</span></label><label><input type="radio" name="an-ideacion" value="Pasiva"><span>Pasiva</span></label><label><input type="radio" name="an-ideacion" value="Activa"><span>Activa</span></label><label><input type="radio" name="an-ideacion" value="Con plan"><span>Con plan</span></label></div></div>
            <div class="form-group full"><label>Clasificación de riesgo</label>
              <div class="risk-selector"><div class="risk-btn" style="color:var(--text2)" onclick="setRisk('SIN RIESGO',this)">SIN RIESGO</div><div class="risk-btn low" onclick="setRisk('BAJO',this)">BAJO</div><div class="risk-btn med" onclick="setRisk('MEDIO',this)">MEDIO</div><div class="risk-btn high" onclick="setRisk('ALTO',this)">ALTO</div></div>
              <input type="hidden" id="an-riesgo" value="">
            </div>
            <div class="form-group full"><label>Notas riesgo</label><textarea id="an-riesgo-notas"></textarea></div>
          </div></div>
        </div>
        <div class="anamnesis-section">
          <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>🎯</span><h4>Impresión diagnóstica y plan</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body"><div class="form-grid">
            <div class="form-group full"><label>Diagnóstico</label><div class="checkgroup" id="an-dx"><label><input type="checkbox" value="Trastorno adaptativo"><span>T. adaptativo</span></label><label><input type="checkbox" value="Trastorno depresivo leve"><span>Dep. leve</span></label><label><input type="checkbox" value="Trastorno depresivo moderado"><span>Dep. moderado</span></label><label><input type="checkbox" value="Trastorno depresivo grave"><span>Dep. grave</span></label><label><input type="checkbox" value="TAG"><span>TAG</span></label><label><input type="checkbox" value="Trastorno de pánico"><span>Pánico</span></label><label><input type="checkbox" value="TEPT"><span>TEPT</span></label><label><input type="checkbox" value="TOC"><span>TOC</span></label></div></div>
            <div class="form-group"><label>CIE-11</label><input type="text" id="an-cie"></div>
            <div class="form-group full"><label>Observaciones</label><textarea id="an-dx-obs"></textarea></div>
            <div class="form-group full"><label>Plan terapéutico</label><div class="checkgroup" id="an-enfoque"><label><input type="checkbox" value="TCC"><span>TCC</span></label><label><input type="checkbox" value="Terapia de apoyo"><span>Apoyo</span></label><label><input type="checkbox" value="Psicoeducación"><span>Psicoeducación</span></label><label><input type="checkbox" value="Relajación"><span>Relajación</span></label></div></div>
            <div class="form-group full"><label>Remisiones</label><div class="checkgroup" id="an-remisiones"><label><input type="checkbox" value="Ninguna"><span>Ninguna</span></label><label><input type="checkbox" value="Psiquiatría"><span>Psiquiatría</span></label><label><input type="checkbox" value="Trabajo social"><span>Trabajo social</span></label></div></div>
            <div class="form-group"><label>Próxima cita</label><input type="date" id="an-proxcita"></div>
          </div></div>
        </div>
        <div class="anamnesis-section">
          <div class="anamnesis-section-header open" onclick="toggleSection(this)"><span>📄</span><h4>Nota clínica generada</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
          <div class="anamnesis-section-body open">
            <div id="nota-output" class="nota-output">Completa los campos y presiona "Generar nota clínica"…</div>
            <div class="flex gap-2 mt-4" style="flex-wrap:wrap">
              <button type="button" class="btn btn-primary" onclick="generarNota()">✨ Generar nota</button>
              <button type="button" class="btn btn-secondary" onclick="copiarNota()">Copiar</button>
              <button type="button" class="btn btn-primary" onclick="guardarAnamnesis()" style="margin-left:auto">💾 Guardar en Firebase</button>
            </div>
          </div>
        </div>
      </form>
    </div>

    <!-- TESTS -->
    <div id="page-tests" class="page">
      <!-- Selector de paciente SIEMPRE visible -->
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:12px 16px;margin-bottom:14px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
        <label style="font-size:0.78rem;font-weight:600;color:var(--text2);flex-shrink:0">👤 Paciente para este test</label>
        <select id="test-pac-sel" onchange="selectTestPaciente(this.value)" style="flex:1;min-width:200px;padding:7px 10px;border:1px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:0.85rem">
          <option value="">— Seleccionar paciente —</option>
        </select>
        <input type="text" id="test-pac-nombre" placeholder="O escribe nombre manualmente" style="flex:1;min-width:160px;padding:7px 10px;border:1px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:0.85rem">
        <input type="number" id="test-pac-edad" placeholder="Edad" min="0" max="120" style="width:80px;padding:7px 10px;border:1px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:0.85rem">
        <select id="test-pac-esc" onchange="updateEscolaridad(this.value)" style="padding:7px 10px;border:1px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:0.85rem">
          <option value="0">Sin escolaridad</option>
          <option value="1">Primaria incompleta</option>
          <option value="2">Primaria completa</option>
          <option value="3">Bachillerato</option>
          <option value="4">Técnico/Tecnólogo</option>
          <option value="5" selected>Universidad o más</option>
        </select>
      </div>
      <!-- Panel de tests -->
      <div id="tests-home" class="test-screen active">
        <div class="assisted-bar">
          <label><input type="checkbox" class="toggle-cb" id="assisted-mode-toggle" onchange="toggleAssisted(this.checked)"><span class="toggle"></span><span>🔤 <strong>Modo lectura asistida</strong> — Texto grande + pictogramas para baja escolaridad</span></label>
        </div>
        <div class="test-section-label">Cognitivo</div>
        <div class="tests-grid">
          <div class="test-card" onclick="showTest('mmse')"><div class="tc-icon">🧠</div><h4>MMSE</h4><p>Tamizaje cognitivo general. Ajustado por escolaridad.</p><div class="tc-meta"><span class="tc-tag">⏱ 7–10 min</span><span class="tc-tag">30 pts</span><span class="tc-tag">⚠ Ajuste escolaridad</span></div></div>
          <div class="test-card" onclick="showTest('moca')"><div class="tc-icon">🧩</div><h4>MoCA</h4><p>Más sensible para deterioro leve y función ejecutiva.</p><div class="tc-meta"><span class="tc-tag">⏱ 10 min</span><span class="tc-tag">30 pts</span><span class="tc-tag">+1pt ≤bachillerato</span></div></div>
          <div class="test-card" onclick="showTest('cam')"><div class="tc-icon">🌀</div><h4>CAM</h4><p>Delirium en hospitalización. Algoritmo de 4 criterios.</p><div class="tc-meta"><span class="tc-tag">⏱ 3–5 min</span><span class="tc-tag">4 criterios</span></div></div>
        </div>
        <div class="test-section-label">Ánimo</div>
        <div class="tests-grid">
          <div class="test-card" onclick="showTest('phq9')"><div class="tc-icon">💙</div><h4>PHQ-9</h4><p>Depresión + ideación suicida.</p><div class="tc-meta"><span class="tc-tag">⏱ 3–5 min</span><span class="tc-tag">27 pts</span></div></div>
          <div class="test-card" onclick="showTest('gad7')"><div class="tc-icon">⚡</div><h4>GAD-7</h4><p>Ansiedad generalizada.</p><div class="tc-meta"><span class="tc-tag">⏱ 3 min</span><span class="tc-tag">21 pts</span></div></div>
          <div class="test-card" onclick="showTest('hads')"><div class="tc-icon">🏥</div><h4>HADS</h4><p>Ansiedad y depresión sin ítems somáticos. Hospitalización.</p><div class="tc-meta"><span class="tc-tag">⏱ 5–7 min</span><span class="tc-tag">42 pts</span></div></div>
        </div>
        <div class="test-section-label">Riesgo & Adherencia</div>
        <div class="tests-grid">
          <div class="test-card" onclick="showTest('cssrs')"><div class="tc-icon">🔴</div><h4>C-SSRS</h4><p>Riesgo suicida. Protocolo Columbia.</p><div class="tc-meta"><span class="tc-tag">⏱ 5 min</span><span class="tc-tag">Alta sensibilidad</span></div></div>
          <div class="test-card" onclick="showTest('mmas4')"><div class="tc-icon">💊</div><h4>MMAS-4</h4><p>Adherencia al tratamiento farmacológico.</p><div class="tc-meta"><span class="tc-tag">⏱ 2 min</span><span class="tc-tag">4 preguntas</span></div></div>
          <div class="test-card" onclick="showTest('duelo')"><div class="tc-icon">🕊️</div><h4>Duelo</h4><p>Adaptado al contexto colombiano vulnerable.</p><div class="tc-meta"><span class="tc-tag">⏱ 5 min</span><span class="tc-tag">5 preguntas</span></div></div>
        </div>
        <div class="test-section-label">Trauma & Estrés Postraumático</div>
        <div class="tests-grid">
          <div class="test-card" onclick="showTest('pcl5')"><div class="tc-icon">🌪️</div><h4>PCL-5</h4><p>Lista de verificación de TEPT — DSM-5. Evalúa síntomas en las últimas 4 semanas.</p><div class="tc-meta"><span class="tc-tag">⏱ 5–7 min</span><span class="tc-tag">20 preguntas</span><span class="tc-tag">0–80 pts</span></div></div>
        </div>
        <div style="background:var(--warning-light);border:1px solid #f0d080;border-radius:var(--radius);padding:14px 18px;margin-top:20px;font-size:0.8rem;color:#5a4000;line-height:1.6">
          💡 <strong>Adaptaciones para población vulnerable colombiana</strong> — Todos los tests usan lenguaje sencillo y cercano. Active el modo lectura asistida para texto grande. Los puntos de corte del MMSE y MoCA se ajustan automáticamente según la escolaridad.
        </div>
      </div>

      <!-- PHQ-9 -->
      <div id="test-phq9" class="test-screen">
        <div class="test-header">
          <div class="th-icon">💙</div>
          <div><h2>PHQ-9 — Preguntas sobre el ánimo</h2><p>¿Cuánto le han molestado estas cosas en las últimas 2 semanas? · 0–27 pts · 3–5 min</p></div>
          <button class="btn btn-secondary" onclick="showTest('home')">← Volver</button>
        </div>
        <div class="clinician-note">📌 <strong>Para la psicóloga:</strong> Leer cada pregunta en voz alta con calma. Si el paciente no entiende, use el ejemplo entre paréntesis.</div>
        <div id="phq9-questions"></div>
        <div style="text-align:right;margin-top:16px"><button class="btn btn-primary" onclick="calcPHQ9()">Ver resultado →</button></div>
        <div id="phq9-result" style="display:none"></div>
      </div>

      <!-- GAD-7 -->
      <div id="test-gad7" class="test-screen">
        <div class="test-header">
          <div class="th-icon">⚡</div>
          <div><h2>GAD-7 — Preguntas sobre los nervios</h2><p>¿Cuánto le han molestado estas cosas en las últimas 2 semanas? · 0–21 pts · 3 min</p></div>
          <button class="btn btn-secondary" onclick="showTest('home')">← Volver</button>
        </div>
        <div class="clinician-note">📌 <strong>Para la psicóloga:</strong> Si el paciente pregunta qué es "preocuparse demasiado", use ejemplos del contexto: la familia, la plata, la salud.</div>
        <div id="gad7-questions"></div>
        <div style="text-align:right;margin-top:16px"><button class="btn btn-primary" onclick="calcGAD7()">Ver resultado →</button></div>
        <div id="gad7-result" style="display:none"></div>
      </div>

      <!-- HADS -->
      <div id="test-hads" class="test-screen">
        <div class="test-header">
          <div class="th-icon">🏥</div>
          <div><h2>HADS — Cómo se ha sentido esta semana</h2><p>Ansiedad y depresión sin ítems somáticos · 5–7 min</p></div>
          <button class="btn btn-secondary" onclick="showTest('home')">← Volver</button>
        </div>
        <div class="clinician-note">📌 <strong>Para la psicóloga:</strong> Preguntar: <em>"¿Cómo se ha sentido durante esta semana que está aquí?"</em> No pregunta por síntomas físicos — ideal para hospitalizados.</div>
        <div id="hads-questions"></div>
        <div style="text-align:right;margin-top:16px"><button class="btn btn-primary" onclick="calcHADS()">Ver resultado →</button></div>
        <div id="hads-result" style="display:none"></div>
      </div>

      <!-- MMSE -->
      <div id="test-mmse" class="test-screen">
        <div class="test-header">
          <div class="th-icon">🧠</div>
          <div><h2>MMSE — Evaluación de la memoria y el pensamiento</h2><p>Administrar verbalmente · 0–30 pts · 7–10 min · ⚠ Ajuste por escolaridad</p></div>
          <button class="btn btn-secondary" onclick="showTest('home')">← Volver</button>
        </div>
        <div class="clinician-note">⚠ <strong>Nota clínica Colombia:</strong> En pacientes sin escolaridad o analfabetos, tolerar 3–4 pts menos. No penalizar por ítems de escritura/lectura si nunca aprendieron. Para orientación usar referencias locales (municipio, vereda, barrio).</div>
        <div id="mmse-questions"></div>
        <div style="text-align:right;margin-top:16px"><button class="btn btn-primary" onclick="calcMMSE()">Ver resultado →</button></div>
        <div id="mmse-result" style="display:none"></div>
      </div>

      <!-- MoCA -->
      <div id="test-moca" class="test-screen">
        <div class="test-header">
          <div class="th-icon">🧩</div>
          <div><h2>MoCA — Evaluación cognitiva completa</h2><p>Más sensible para deterioro leve y función ejecutiva · 0–30 pts · 10 min</p></div>
          <button class="btn btn-secondary" onclick="showTest('home')">← Volver</button>
        </div>
        <div class="clinician-note">⚠ <strong>Nota clínica Colombia:</strong> En analfabetos, omitir ítems de escritura y ajustar interpretación. Corrección automática de +1 pt si escolaridad ≤ bachillerato.</div>
        <div id="moca-questions"></div>
        <div style="text-align:right;margin-top:16px"><button class="btn btn-primary" onclick="calcMoCA()">Ver resultado →</button></div>
        <div id="moca-result" style="display:none"></div>
      </div>

      <!-- CAM -->
      <div id="test-cam" class="test-screen">
        <div class="test-header">
          <div class="th-icon">🌀</div>
          <div><h2>CAM — ¿Hay confusión mental?</h2><p>Diagnóstico de delirium · 4 criterios · 3–5 min</p></div>
          <button class="btn btn-secondary" onclick="showTest('home')">← Volver</button>
        </div>
        <div class="clinician-note">📌 <strong>Algoritmo CAM:</strong> Delirium = C1 (inicio agudo + fluctuante) <strong>Y</strong> C2 (inatención) <strong>Y</strong> (C3 ó C4)</div>
        <div id="cam-questions"></div>
        <div style="text-align:right;margin-top:16px"><button class="btn btn-primary" onclick="calcCAM()">Evaluar →</button></div>
        <div id="cam-result" style="display:none"></div>
      </div>

      <!-- C-SSRS -->
      <div id="test-cssrs" class="test-screen">
        <div class="test-header">
          <div class="th-icon">🔴</div>
          <div><h2>C-SSRS — Pensamientos de hacerse daño</h2><p>Versión corta de tamizaje · Protocolo Columbia · 5 min</p></div>
          <button class="btn btn-secondary" onclick="showTest('home')">← Volver</button>
        </div>
        <div class="clinician-note">⚠ <strong>Importante:</strong> Preguntar con calma, sin prisa y con empatía. En contexto colombiano: desplazamiento, pérdida por violencia y pobreza son factores adicionales. Positivo en ítems 4–5 requiere evaluación inmediata.</div>
        <div id="cssrs-questions"></div>
        <div style="text-align:right;margin-top:16px"><button class="btn btn-primary" onclick="calcCSSRS()">Evaluar riesgo →</button></div>
        <div id="cssrs-result" style="display:none"></div>
      </div>

      <!-- MMAS-4 -->
      <div id="test-mmas4" class="test-screen">
        <div class="test-header">
          <div class="th-icon">💊</div>
          <div><h2>MMAS-4 — ¿Está tomando bien sus pastillas?</h2><p>4 preguntas sobre adherencia al tratamiento · 2 min</p></div>
          <button class="btn btn-secondary" onclick="showTest('home')">← Volver</button>
        </div>
        <div class="clinician-note">📌 <strong>Para la psicóloga:</strong> Preguntar en relación al tratamiento actual. En pacientes vulnerables, explorar barreras: costo, acceso a farmacia, red de apoyo.</div>
        <div id="mmas4-questions"></div>
        <div style="text-align:right;margin-top:16px"><button class="btn btn-primary" onclick="calcMMAS4()">Ver resultado →</button></div>
        <div id="mmas4-result" style="display:none"></div>
      </div>

      <!-- DUELO -->
      <div id="test-duelo" class="test-screen">
        <div class="test-header">
          <div class="th-icon">🕊️</div>
          <div><h2>Duelo — ¿Cómo lleva la pérdida?</h2><p>Adaptado para población colombiana vulnerable · 5 min · 0–10 pts</p></div>
          <button class="btn btn-secondary" onclick="showTest('home')">← Volver</button>
        </div>
        <div class="clinician-note">📌 <strong>Contexto:</strong> Aplicar ante pérdida reciente (persona querida, función corporal, hogar, desplazamiento forzado). Validar con: <em>"Entiendo que ha sido muy difícil para usted…"</em></div>
        <div id="duelo-questions"></div>
        <div style="text-align:right;margin-top:16px"><button class="btn btn-primary" onclick="calcDuelo()">Ver resultado →</button></div>
        <div id="duelo-result" style="display:none"></div>
      </div>

      <!-- PCL-5 TEPT -->
      <div id="test-pcl5" class="test-screen">
        <div class="test-header">
          <div class="th-icon">🌪️</div>
          <div><h2>PCL-5 — Estrés Postraumático (TEPT)</h2><p>Lista de verificación TEPT según DSM-5 · 20 preguntas · 0–80 pts · 5–7 min</p></div>
          <button class="btn btn-secondary" onclick="showTest('home')">← Volver</button>
        </div>
        <div class="clinician-note">📌 <strong>Instrucción:</strong> "A continuación hay una lista de problemas que a veces tiene la gente en respuesta a una experiencia muy estresante. Por favor lea cada problema con cuidado y marque qué tanto le ha molestado ese problema en el <strong>último mes</strong>."<br><br>⚠️ Antes de aplicar, identifique el evento traumático de referencia con el paciente.</div>
        <div style="background:var(--accent-light);border:1px solid var(--accent2);border-radius:8px;padding:10px 14px;margin-bottom:14px;font-size:0.82rem;color:var(--accent)">
          <strong>Evento de referencia:</strong> <input type="text" id="pcl5-evento" placeholder="Ej: Accidente de tránsito, pérdida de familiar, diagnóstico…" style="background:transparent;border:none;border-bottom:1px dashed var(--accent2);outline:none;font-family:'DM Sans',sans-serif;font-size:0.82rem;color:var(--text);width:calc(100% - 160px)">
        </div>
        <div id="pcl5-questions"></div>
        <div style="text-align:right;margin-top:16px"><button class="btn btn-primary" onclick="calcPCL5()">Ver resultado →</button></div>
        <div id="pcl5-result" style="display:none"></div>
      </div>
    </div>

    <!-- CAPACIDAD DECISIONAL -->
    <div id="page-capacidad" class="page">
      <div class="section-header">
        <h2>⚖️ Valoración de Capacidad Decisional</h2>
        <div style="display:flex;gap:10px;align-items:center">
          <select id="cap-pac-sel" onchange="selectCapPaciente(this.value)" style="padding:7px 11px;border:1px solid var(--border);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:0.85rem;min-width:200px">
            <option value="">— Seleccionar paciente —</option>
          </select>
          <button class="btn btn-secondary btn-sm" onclick="limpiarCapacidad()">Nueva</button>
        </div>
      </div>

      <div style="background:var(--warning-light);border:1px solid #f0d080;border-radius:var(--radius);padding:13px 18px;margin-bottom:18px;font-size:0.82rem;color:#5a4000;line-height:1.6">
        ⚖️ <strong>Criterio legal y clínico (Colombia):</strong> La capacidad decisional no es global ni permanente — es específica para cada decisión y momento clínico. Se evalúan 4 criterios: Comprensión, Apreciación, Razonamiento y Expresión de una decisión. Todos deben estar presentes para determinar capacidad conservada.
      </div>

      <!-- Datos del paciente -->
      <div class="anamnesis-section">
        <div class="anamnesis-section-header open" onclick="toggleSection(this)"><span>🪪</span><h4>Datos de identificación</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
        <div class="anamnesis-section-body open"><div class="form-grid">
          <div class="form-group"><label>Fecha de valoración</label><input type="date" id="cap-fecha"></div>
          <div class="form-group"><label>Nombre del paciente</label><input type="text" id="cap-nombre"></div>
          <div class="form-group"><label>Edad / Sexo</label><input type="text" id="cap-edad" placeholder="Ej: 54 años, F"></div>
          <div class="form-group"><label>Habitación</label><input type="text" id="cap-hab" placeholder="Ej: 304B"></div>
          <div class="form-group full"><label>Diagnóstico médico / Situación clínica</label><input type="text" id="cap-dx" placeholder="Ej: Ca. gástrico estadio IV, decisión sobre quimioterapia paliativa"></div>
          <div class="form-group full"><label>Decisión específica a evaluar</label><textarea id="cap-decision" rows="2" placeholder="Ej: El paciente desea rechazar la quimioterapia propuesta por oncología..."></textarea></div>
          <div class="form-group full"><label>Solicitado por</label><input type="text" id="cap-solicitante" placeholder="Ej: Dr. Pérez, Medicina Interna"></div>
        </div></div>
      </div>

      <!-- Criterio 1: Comprensión -->
      <div class="anamnesis-section">
        <div class="anamnesis-section-header open" onclick="toggleSection(this)"><span>1️⃣</span><h4>Comprensión — ¿Entiende la información?</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
        <div class="anamnesis-section-body open">
          <div style="background:var(--surface2);border-radius:8px;padding:10px 14px;font-size:0.8rem;color:var(--text2);margin-bottom:12px">
            📌 <strong>Preguntar:</strong> "¿Puede contarme con sus propias palabras qué le dijeron los médicos sobre su situación?" / "¿Qué entiende que va a pasar si acepta/rechaza este tratamiento?"
          </div>
          <div class="form-grid">
            <div class="form-group full"><label>Resultado</label>
              <div class="risk-selector">
                <div class="risk-btn" style="color:var(--success);flex:1" onclick="setCapCriterio('cap-c1','CONSERVADA',this)">✅ CONSERVADA</div>
                <div class="risk-btn" style="color:var(--warning);flex:1" onclick="setCapCriterio('cap-c1','PARCIAL',this)">⚠️ PARCIAL</div>
                <div class="risk-btn" style="color:var(--danger);flex:1" onclick="setCapCriterio('cap-c1','AUSENTE',this)">❌ AUSENTE</div>
              </div>
              <input type="hidden" id="cap-c1" value="">
            </div>
            <div class="form-group full"><label>Observaciones</label><textarea id="cap-c1-obs" rows="2" placeholder="Describir qué pudo repetir el paciente, errores de comprensión, factores que la afectan..."></textarea></div>
          </div>
        </div>
      </div>

      <!-- Criterio 2: Apreciación -->
      <div class="anamnesis-section">
        <div class="anamnesis-section-header open" onclick="toggleSection(this)"><span>2️⃣</span><h4>Apreciación — ¿Aplica la información a su caso?</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
        <div class="anamnesis-section-body open">
          <div style="background:var(--surface2);border-radius:8px;padding:10px 14px;font-size:0.8rem;color:var(--text2);margin-bottom:12px">
            📌 <strong>Preguntar:</strong> "¿Cree que esta enfermedad le está afectando a usted?" / "¿Qué cree que pasará con su salud si toma esta decisión?"
          </div>
          <div class="form-grid">
            <div class="form-group full"><label>Resultado</label>
              <div class="risk-selector">
                <div class="risk-btn" style="color:var(--success);flex:1" onclick="setCapCriterio('cap-c2','CONSERVADA',this)">✅ CONSERVADA</div>
                <div class="risk-btn" style="color:var(--warning);flex:1" onclick="setCapCriterio('cap-c2','PARCIAL',this)">⚠️ PARCIAL</div>
                <div class="risk-btn" style="color:var(--danger);flex:1" onclick="setCapCriterio('cap-c2','AUSENTE',this)">❌ AUSENTE</div>
              </div>
              <input type="hidden" id="cap-c2" value="">
            </div>
            <div class="form-group full"><label>Observaciones</label><textarea id="cap-c2-obs" rows="2" placeholder="¿Reconoce que está enfermo? ¿Niega su situación? ¿Atribuye síntomas a causas externas?..."></textarea></div>
          </div>
        </div>
      </div>

      <!-- Criterio 3: Razonamiento -->
      <div class="anamnesis-section">
        <div class="anamnesis-section-header open" onclick="toggleSection(this)"><span>3️⃣</span><h4>Razonamiento — ¿Puede comparar opciones?</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
        <div class="anamnesis-section-body open">
          <div style="background:var(--surface2);border-radius:8px;padding:10px 14px;font-size:0.8rem;color:var(--text2);margin-bottom:12px">
            📌 <strong>Preguntar:</strong> "¿Por qué prefiere esta opción sobre las otras?" / "¿Qué factores tuvo en cuenta para tomar esta decisión?" / "¿Qué le preocupa más de cada opción?"
          </div>
          <div class="form-grid">
            <div class="form-group full"><label>Resultado</label>
              <div class="risk-selector">
                <div class="risk-btn" style="color:var(--success);flex:1" onclick="setCapCriterio('cap-c3','CONSERVADA',this)">✅ CONSERVADA</div>
                <div class="risk-btn" style="color:var(--warning);flex:1" onclick="setCapCriterio('cap-c3','PARCIAL',this)">⚠️ PARCIAL</div>
                <div class="risk-btn" style="color:var(--danger);flex:1" onclick="setCapCriterio('cap-c3','AUSENTE',this)">❌ AUSENTE</div>
              </div>
              <input type="hidden" id="cap-c3" value="">
            </div>
            <div class="form-group full"><label>Observaciones</label><textarea id="cap-c3-obs" rows="2" placeholder="¿Puede sopesar riesgos y beneficios? ¿El razonamiento es lógico y consistente?..."></textarea></div>
          </div>
        </div>
      </div>

      <!-- Criterio 4: Expresión -->
      <div class="anamnesis-section">
        <div class="anamnesis-section-header open" onclick="toggleSection(this)"><span>4️⃣</span><h4>Expresión — ¿Comunica una decisión estable?</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
        <div class="anamnesis-section-body open">
          <div style="background:var(--surface2);border-radius:8px;padding:10px 14px;font-size:0.8rem;color:var(--text2);margin-bottom:12px">
            📌 <strong>Evaluar:</strong> Consistencia de la decisión en el tiempo. Si cambia con cada pregunta o cada interlocutor, puede indicar incapacidad.
          </div>
          <div class="form-grid">
            <div class="form-group full"><label>Resultado</label>
              <div class="risk-selector">
                <div class="risk-btn" style="color:var(--success);flex:1" onclick="setCapCriterio('cap-c4','CONSERVADA',this)">✅ CONSERVADA</div>
                <div class="risk-btn" style="color:var(--warning);flex:1" onclick="setCapCriterio('cap-c4','PARCIAL',this)">⚠️ PARCIAL</div>
                <div class="risk-btn" style="color:var(--danger);flex:1" onclick="setCapCriterio('cap-c4','AUSENTE',this)">❌ AUSENTE</div>
              </div>
              <input type="hidden" id="cap-c4" value="">
            </div>
            <div class="form-group full"><label>Observaciones</label><textarea id="cap-c4-obs" rows="2" placeholder="¿La decisión es estable? ¿Cambia bajo presión? ¿Es coherente con sus valores previos?..."></textarea></div>
          </div>
        </div>
      </div>

      <!-- Factores que afectan -->
      <div class="anamnesis-section">
        <div class="anamnesis-section-header" onclick="toggleSection(this)"><span>🧩</span><h4>Factores que afectan la capacidad</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
        <div class="anamnesis-section-body"><div class="form-grid">
          <div class="form-group full"><label>Factores identificados</label>
            <div class="checkgroup" id="cap-factores">
              <label><input type="checkbox" value="Delirium activo"><span>Delirium activo</span></label>
              <label><input type="checkbox" value="Deterioro cognitivo"><span>Deterioro cognitivo</span></label>
              <label><input type="checkbox" value="Trastorno depresivo mayor"><span>Depresión mayor</span></label>
              <label><input type="checkbox" value="Psicosis activa"><span>Psicosis activa</span></label>
              <label><input type="checkbox" value="Ansiedad severa"><span>Ansiedad severa</span></label>
              <label><input type="checkbox" value="Dolor no controlado"><span>Dolor no controlado</span></label>
              <label><input type="checkbox" value="Sedación por medicamentos"><span>Sedación por medicamentos</span></label>
              <label><input type="checkbox" value="Presión familiar"><span>Presión familiar</span></label>
              <label><input type="checkbox" value="Barrera idiomática"><span>Barrera idiomática</span></label>
              <label><input type="checkbox" value="Bajo nivel educativo"><span>Bajo nivel educativo</span></label>
              <label><input type="checkbox" value="Ninguno identificado"><span>Ninguno identificado</span></label>
            </div>
          </div>
          <div class="form-group full"><label>Observaciones adicionales</label><textarea id="cap-factores-obs" rows="2"></textarea></div>
        </div></div>
      </div>

      <!-- Conclusión -->
      <div class="anamnesis-section">
        <div class="anamnesis-section-header open" onclick="toggleSection(this)"><span>⚖️</span><h4>Conclusión y recomendaciones</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
        <div class="anamnesis-section-body open"><div class="form-grid">
          <div class="form-group full"><label>Conclusión de capacidad decisional</label>
            <div class="risk-selector">
              <div class="risk-btn" style="color:var(--success);flex:1" onclick="setCapConclusion('CONSERVADA',this)">✅ CAPACIDAD CONSERVADA</div>
              <div class="risk-btn" style="color:var(--warning);flex:1" onclick="setCapConclusion('DISMINUIDA',this)">⚠️ CAPACIDAD DISMINUIDA</div>
              <div class="risk-btn" style="color:var(--danger);flex:1" onclick="setCapConclusion('AUSENTE',this)">❌ CAPACIDAD AUSENTE</div>
            </div>
            <input type="hidden" id="cap-conclusion" value="">
          </div>
          <div class="form-group full"><label>Recomendaciones al equipo médico</label>
            <div class="checkgroup" id="cap-recom">
              <label><input type="checkbox" value="Respetar la decisión del paciente"><span>Respetar decisión del paciente</span></label>
              <label><input type="checkbox" value="Reevaluar capacidad una vez resuelto el factor causal"><span>Reevaluar tras resolver factor causal</span></label>
              <label><input type="checkbox" value="Involucrar a la familia como red de apoyo"><span>Involucrar familia como apoyo</span></label>
              <label><input type="checkbox" value="Activar representante legal o familiar sustituto"><span>Activar representante legal/familiar</span></label>
              <label><input type="checkbox" value="Solicitar interconsulta a psiquiatría"><span>Interconsulta a psiquiatría</span></label>
              <label><input type="checkbox" value="Documentar decisión del paciente en historia clínica"><span>Documentar en historia clínica</span></label>
              <label><input type="checkbox" value="Considerar intervención de trabajo social"><span>Trabajo social</span></label>
            </div>
          </div>
          <div class="form-group full"><label>Notas clínicas adicionales</label><textarea id="cap-notas" rows="3" placeholder="Observaciones relevantes para el equipo tratante..."></textarea></div>
        </div></div>
      </div>

      <!-- Nota generada -->
      <div class="anamnesis-section">
        <div class="anamnesis-section-header open" onclick="toggleSection(this)"><span>📄</span><h4>Nota clínica generada</h4><svg class="chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
        <div class="anamnesis-section-body open">
          <div id="cap-nota-output" class="nota-output">Completa los campos y presiona "Generar nota"…</div>
          <div class="flex gap-2 mt-4" style="flex-wrap:wrap">
            <button class="btn btn-primary" onclick="generarNotaCapacidad()">✨ Generar nota</button>
            <button class="btn btn-secondary" onclick="copiarNotaCapacidad()">Copiar</button>
            <button class="btn btn-primary" onclick="guardarCapacidadFirebase()" style="margin-left:auto">💾 Guardar en Firebase</button>
          </div>
        </div>
      </div>
    </div>

    <!-- HISTORIAL TESTS -->

    <!-- HISTORIAL PACIENTES -->
    <div id="page-historial-pac" class="page">
      <div id="hpac-lista-view">
        <div class="section-header"><h2>📂 Historial de Pacientes</h2></div>
        <div style="margin-bottom:14px;position:relative">
          <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:15px;height:15px;color:var(--text3)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <input type="search" id="hpac-search" placeholder="Buscar paciente..." oninput="hpacFiltrar(this.value)" style="width:100%;padding:10px 12px 10px 36px;border:1.5px solid var(--border);border-radius:8px;background:var(--surface2);font-size:0.9rem;outline:none;font-family:'DM Sans',sans-serif;color:var(--text)">
        </div>
        <div id="hpac-lista"></div>
      </div>
      <div id="hpac-notas-view" style="display:none">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;flex-wrap:wrap">
          <button class="btn btn-secondary" onclick="hpacVolverLista()">← Volver</button>
          <div>
            <div style="font-family:'DM Serif Display',serif;font-size:1.2rem" id="hpac-pac-nombre"></div>
            <div style="font-size:0.75rem;color:var(--text3)" id="hpac-pac-info"></div>
          </div>
          <button class="btn btn-primary btn-sm" style="margin-left:auto" onclick="hpacNuevaNota()">📝 Nuevo seguimiento</button>
        </div>
        <div id="hpac-resumen-bar" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px"></div>
        <div id="hpac-notas-list"></div>
      </div>
    </div>

    <div id="page-consulta-externa" class="page">
      <div class="section-header">
        <h2>🚶 Pacientes Consulta Externa EPS</h2>
        <button class="btn btn-primary" onclick="openModal('modal-paciente');document.getElementById('p-tipo-ext').click();setPTipo('consulta-externa')">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 4v16m8-8H4"/></svg>Nuevo paciente
        </button>
      </div>
      <div style="background:var(--warning-light);border:1px solid #f0d080;border-radius:var(--radius);padding:10px 16px;margin-bottom:16px;font-size:0.82rem;color:#5a4000">
        🚶 Pacientes de consulta externa EPS — Sesiones programadas, anamnesis y seguimiento ambulatorio
      </div>
      <div style="margin-bottom:14px;position:relative">
        <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);width:15px;height:15px;color:var(--text3)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="search" id="ce-search" placeholder="Buscar por nombre o cédula…" oninput="renderConsultaExterna(this.value)" style="width:100%;padding:10px 12px 10px 36px;border:1.5px solid var(--border);border-radius:8px;background:var(--surface2);font-size:0.9rem;outline:none;font-family:'DM Sans',sans-serif;color:var(--text)">
      </div>
      <div id="ce-lista"></div>
    </div>

    
    <div id="page-historial" class="page">
      <div class="section-header"><h2>Historial de Tests</h2><button class="btn btn-danger btn-sm" onclick="clearTestHistory()">🗑 Borrar todo</button></div>
      <div id="historial-list"><div class="loading"><div class="spinner"></div><br>Cargando…</div></div>
    </div>

  </div>
</div>

<!-- PATIENT INFO SHEET -->
<div class="pac-sheet-overlay" id="pac-sheet-overlay" onclick="closePacSheet(event)">
  <div class="pac-sheet" id="pac-sheet">
    <div class="pac-sheet-handle"></div>
    <div class="pac-sheet-head">
      <div>
        <div class="pac-sheet-nombre" id="ps-nombre">—</div>
        <div class="pac-sheet-sub" id="ps-sub">—</div>
      </div>
      <button class="pac-sheet-close" onclick="closePacSheet()">✕</button>
    </div>
    <div class="pac-sheet-body">
      <div id="ps-sesiones-badge" class="pac-sesiones-badge" title="Ver historial completo del paciente">📅 0 sesiones registradas</div>
      <div class="pac-info-grid" id="ps-grid"></div>
    </div>
    <div class="pac-sheet-actions" id="ps-actions"></div>
  </div>
</div>

<!-- MODAL PACIENTE -->
<div class="modal-overlay" id="modal-paciente">
  <div class="modal">
    <div class="modal-header"><h3>Nuevo Paciente</h3><button class="modal-close" onclick="closeModal('modal-paciente')"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg></button></div>
    <div class="modal-body"><div class="form-grid">
      <div class="form-group full">
        <label>Tipo de paciente</label>
        <div style="display:flex;gap:10px;margin-top:6px">
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;background:var(--surface2);border:2px solid var(--accent2);border-radius:8px;padding:10px 16px;flex:1" id="tipo-hosp-btn" onclick="setPTipo('hospitalizado')">
            <input type="radio" name="p-tipo" value="hospitalizado" id="p-tipo-hosp" checked style="accent-color:var(--accent2)"> 🏥 <span style="font-weight:600;font-size:0.88rem">Hospitalizado</span>
          </label>
          <label style="display:flex;align-items:center;gap:8px;cursor:pointer;background:var(--surface2);border:2px solid var(--border);border-radius:8px;padding:10px 16px;flex:1" id="tipo-ext-btn" onclick="setPTipo('consulta-externa')">
            <input type="radio" name="p-tipo" value="consulta-externa" id="p-tipo-ext" style="accent-color:var(--accent2)"> 🚶 <span style="font-weight:600;font-size:0.88rem">Consulta externa</span>
          </label>
        </div>
        <input type="hidden" id="p-tipo" value="hospitalizado">
      </div>
      <div class="form-group full"><label>Nombre completo *</label><input type="text" id="p-nombre" placeholder="Apellidos, Nombres"></div>
      <div class="form-group"><label>Cédula *</label><input type="text" id="p-cedula"></div>
      <div class="form-group"><label>Edad</label><input type="number" id="p-edad" min="0" max="120"></div>
      <div class="form-group"><label>Sexo</label><select id="p-sexo"><option value="">Seleccionar...</option><option>Femenino</option><option>Masculino</option><option>No binario</option></select></div>
      <div class="form-group"><label>Fecha de ingreso</label><input type="date" id="p-fecha"></div>
      <div class="form-group" id="p-hab-group"><label>Habitación / Servicio</label><input type="text" id="p-hab" placeholder="Ej: 304B, URG-12, UCI-3, AZU-5"><div style="display:flex;gap:5px;flex-wrap:wrap;margin-top:5px"><button type="button" onclick="document.getElementById('p-hab').value='AZU-'" class="btn btn-secondary btn-sm" style="font-size:0.72rem;padding:2px 8px">🔵 Bloque Azul</button><button type="button" onclick="document.getElementById('p-hab').value='URG-'" class="btn btn-secondary btn-sm" style="font-size:0.72rem;padding:2px 8px">🟡 Urgencias</button><button type="button" onclick="document.getElementById('p-hab').value='UCI-'" class="btn btn-secondary btn-sm" style="font-size:0.72rem;padding:2px 8px">🔴 UCI</button></div></div>
      <div class="form-group full"><label id="p-motivo-label">Diagnóstico médico / Motivo de interconsulta</label><textarea id="p-motivo" rows="2" placeholder="Ej: Ca. de mama, impacto emocional dx reciente"></textarea></div>
      <div class="form-group full"><label>Impresión diagnóstica psicológica</label><textarea id="p-dxpsi" rows="2" placeholder="Ej: Trastorno adaptativo con sintomatología ansiosa"></textarea></div>
      <div class="form-group full"><label>Riesgo suicida</label>
        <div class="risk-selector" style="margin-top:4px">
          <div class="risk-btn" style="color:var(--text2)" onclick="setPRisk('SIN RIESGO',this)">SIN RIESGO</div>
          <div class="risk-btn low" onclick="setPRisk('BAJO',this)">BAJO</div>
          <div class="risk-btn med" onclick="setPRisk('MEDIO',this)">MEDIO</div>
          <div class="risk-btn high" onclick="setPRisk('ALTO',this)">ALTO</div>
        </div>
        <input type="hidden" id="p-riesgo" value="">
      </div>
      <div class="form-group full"><label>Observaciones de riesgo</label><textarea id="p-riesgo-obs" rows="2" placeholder="Ideación, plan, factores protectores..."></textarea></div>
      <div class="form-group full"><label>Estado actual</label>
        <select id="p-estado"><option value="seguimiento">Seguimiento</option><option value="nueva-interconsulta-pendiente">Nueva interconsulta pendiente</option><option value="consulta-externa">Consulta externa</option><option value="alta">Alta</option><option value="revaloracion">Revaluación</option><option value="alta-voluntaria">Alta voluntaria</option><option value="fallecido">Paciente fallecido</option></select>
      </div>
      <div class="form-group"><label>Próxima sesión</label><input type="date" id="p-proxsesion"></div>
      <div class="form-group full"><label>Notas generales del caso</label><textarea id="p-notas" rows="3" placeholder="Observaciones, evolución general, consideraciones clínicas..."></textarea></div>
    </div></div>
    <div class="modal-footer"><button class="btn btn-secondary" onclick="closeModal('modal-paciente')">Cancelar</button><button class="btn btn-primary" onclick="guardarPaciente()">Registrar</button></div>
  </div>
</div>

<!-- MODAL IC -->
<div class="modal-overlay" id="modal-ic">
  <div class="modal">
    <div class="modal-header"><h3>Nueva Interconsulta</h3><button class="modal-close" onclick="closeModal('modal-ic')"><svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg></button></div>
    <div class="modal-body"><div class="form-grid">
      <div class="form-group full"><label>Paciente *</label><select id="ic-paciente"><option value="">— Seleccionar —</option></select></div>
      <div class="form-group"><label>Especialidad *</label><select id="ic-especialidad"><option value="">Seleccionar...</option><option>Psiquiatría</option><option>Neurología</option><option>Medicina interna</option><option>Trabajo social</option><option>Nutrición</option><option>Fisioterapia</option><option>Otra</option></select></div>
      <div class="form-group"><label>Prioridad</label><select id="ic-prioridad"><option value="normal">Normal</option><option value="urgente">Urgente</option><option value="electiva">Electiva</option></select></div>
      <div class="form-group full"><label>Motivo *</label><textarea id="ic-motivo" rows="3"></textarea></div>
      <div class="form-group full"><label>Información clínica relevante</label><textarea id="ic-info" rows="2"></textarea></div>
      <div class="form-group"><label>Fecha</label><input type="date" id="ic-fecha"></div>
      <div class="form-group"><label>Médico solicitante</label><input type="text" id="ic-medico"></div>
    </div></div>
    <div class="modal-footer"><button class="btn btn-secondary" onclick="closeModal('modal-ic')">Cancelar</button><button class="btn btn-primary" onclick="guardarIC()">Enviar</button></div>
  </div>
</div>

<div id="toast"></div>

<!-- FIREBASE -->
<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, collection, addDoc, deleteDoc, doc, onSnapshot, query, orderBy, updateDoc, serverTimestamp, getDocs, where } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

const app = initializeApp({
  apiKey:"AIzaSyCsqumG_BRCWwnFEOcoNfLXtfaUlzvPqYE",
  authDomain:"seguimiento-pacientes-a842f.firebaseapp.com",
  projectId:"seguimiento-pacientes-a842f",
  storageBucket:"seguimiento-pacientes-a842f.firebasestorage.app",
  messagingSenderId:"641640192728",
  appId:"1:641640192728:web:14a1d4074e2a6fa6e3d5ad"
});
const db = getFirestore(app);
window.db=db;
window._fdb={collection,addDoc,deleteDoc,doc,updateDoc,serverTimestamp,query,orderBy};
let pacientes=[],interconsultas=[],anamnesisList=[],testHistory=[];
window.pacientes=pacientes;window.interconsultas=interconsultas;window.anamnesisList=anamnesisList;window.testHistory=testHistory;

function setSyncStatus(s){
  const dot=document.getElementById('sync-dot'),txt=document.getElementById('sync-status');
  dot.className='sync-dot'+(s==='online'?'':' '+s);
  txt.textContent=s==='online'?'Sincronizado':s==='syncing'?'Guardando…':'Sin conexión';
}

onSnapshot(query(collection(db,'pacientes'),orderBy('creado','desc')),snap=>{
  pacientes=snap.docs.map(d=>({id:d.id,...d.data()}));window.pacientes=pacientes;
  setSyncStatus('online');updateBadges();updateStats();populateAnamPacientes();populateICPacientes();
  if(document.getElementById('page-pacientes').classList.contains('active'))renderPacientes();
  if(document.getElementById('page-consulta-externa').classList.contains('active'))renderConsultaExterna();
  if(document.getElementById('page-dashboard').classList.contains('active'))renderDashboard();
});
onSnapshot(query(collection(db,'interconsultas'),orderBy('creado','desc')),snap=>{
  interconsultas=snap.docs.map(d=>({id:d.id,...d.data()}));window.interconsultas=interconsultas;
  updateBadges();updateStats();
  if(document.getElementById('page-interconsultas').classList.contains('active')||document.getElementById('page-historial-ic').classList.contains('active'))renderIC();
  if(document.getElementById('page-dashboard').classList.contains('active'))renderDashboard();
});
onSnapshot(query(collection(db,'anamnesis'),orderBy('creado','desc')),snap=>{
  anamnesisList=snap.docs.map(d=>({id:d.id,...d.data()}));window.anamnesisList=anamnesisList;
  updateStats();
  if(document.getElementById('page-dashboard').classList.contains('active'))renderDashboard();
  // Refresh historial sesiones si está abierto
  const histPanel=document.getElementById('anam-panel-historial');
  if(histPanel&&histPanel.style.display!=='none'){
    const hs=document.getElementById('seg-historial-pac-sel');
    if(hs&&hs.value&&typeof anamHistorialRender==='function')anamHistorialRender(hs.value);
  }
});
onSnapshot(query(collection(db,'test_resultados'),orderBy('creado','desc')),snap=>{
  testHistory=snap.docs.map(d=>({id:d.id,...d.data()}));window.testHistory=testHistory;
  updateStats();
  if(document.getElementById('page-historial').classList.contains('active'))renderHistorial();
  if(document.getElementById('page-dashboard').classList.contains('active'))renderDashboard();
  if(document.getElementById('page-historial-pac').classList.contains('active')){hpacRenderLista();if(window._hpacPacId)hpacRenderNotas();}
});

let capacidadList=[];window.capacidadList=capacidadList;
onSnapshot(query(collection(db,'capacidad_decisional'),orderBy('creado','desc')),snap=>{
  capacidadList=snap.docs.map(d=>({id:d.id,...d.data()}));window.capacidadList=capacidadList;
});

window.guardarPaciente=async()=>{
  const nombre=document.getElementById('p-nombre').value.trim(),cedula=document.getElementById('p-cedula').value.trim();
  if(!nombre||!cedula)return toast('⚠️ Nombre y cédula son obligatorios');
  // Verificar duplicado
  const dup=pacientes.find(p=>p.cedula===cedula);
  if(dup){
    if(!confirm(`⚠️ PACIENTE YA REGISTRADO\n\nYa existe un paciente con la cédula ${cedula}:\n"${dup.nombre}"\n\n¿Deseas editarlo en vez de crear uno nuevo?`))return;
    // Abrir edición del existente
    editarPaciente(dup.id);return;
  }
  const dupNombre=pacientes.find(p=>p.nombre.toLowerCase()===nombre.toLowerCase());
  if(dupNombre){
    if(!confirm(`⚠️ NOMBRE SIMILAR\n\nYa existe un paciente con nombre "${dupNombre.nombre}" (CC: ${dupNombre.cedula}).\n\n¿Confirmas que es un paciente diferente y deseas continuar?`))return;
  }
  setSyncStatus('syncing');
  try{
    await addDoc(collection(db,'pacientes'),{
      nombre,cedula,
      edad:document.getElementById('p-edad').value,
      sexo:document.getElementById('p-sexo').value,
      fecha:document.getElementById('p-fecha').value,
      hab:document.getElementById('p-hab').value,
      motivo:document.getElementById('p-motivo').value,
      dxpsi:document.getElementById('p-dxpsi').value,
      riesgo:document.getElementById('p-riesgo').value,
      riesgoObs:document.getElementById('p-riesgo-obs').value,
      tipo:document.getElementById('p-tipo').value||'hospitalizado',
      estado:document.getElementById('p-estado').value||'seguimiento',
      proxSesion:document.getElementById('p-proxsesion').value,
      notas:document.getElementById('p-notas').value,
      creado:serverTimestamp()
    });
    closeModal('modal-paciente');toast('✅ Paciente registrado');
    ['p-nombre','p-cedula','p-edad','p-hab','p-motivo','p-dxpsi','p-riesgo-obs','p-notas','p-proxsesion'].forEach(id=>document.getElementById(id).value='');
    document.getElementById('p-riesgo').value='';
    document.querySelectorAll('#modal-paciente .risk-btn').forEach(b=>b.classList.remove('sel'));
  }
  catch(e){setSyncStatus('offline');toast('❌ Error: '+e.message);}
};

window.renderPacientes=(lista)=>{
  const data=lista!==undefined?lista:pacientes;
  const tbody=document.getElementById('tabla-pacientes');
  if(!tbody)return;

  // Leer búsqueda: input local de la página > topbar > variable global
  const localEl=document.getElementById('pac-search-local');
  const topbarEl=document.getElementById('global-search');
  const raw=((localEl&&localEl.value.trim())||(topbarEl&&topbarEl.value.trim())||(window._searchQ||'')).trim();
  const q=raw.toLowerCase();

  const filtered=q
    ? data.filter(p=>{
        const cedula=String(p.cedula||'').replace(/\s/g,'');
        const busq=raw.replace(/\s/g,'');
        return (p.nombre||'').toLowerCase().includes(q)
          || cedula.includes(busq)
          || (p.hab||'').toLowerCase().includes(q)
          || (p.motivo||'').toLowerCase().includes(q)
          || (p.dxpsi||'').toLowerCase().includes(q);
      })
    : data;
  // Usar filtered (con búsqueda aplicada)
  if(!filtered.length){
    tbody.innerHTML=q
      ?`<tr><td colspan="8"><div class="empty"><p>🔍 Sin resultados para "<strong>${q}</strong>"</p></div></td></tr>`
      :'<tr><td colspan="8"><div class="empty"><p>No hay pacientes registrados.</p></div></td></tr>';
    return;
  }
  const getPiso=(p)=>{if(p.tipo==='consulta-externa')return'🚶 Consulta Externa';const hab=p.hab||'';if(!hab)return'Sin piso';const u=hab.toUpperCase();if(u.includes('UCI')||u.includes('UTI')||u.includes('CUIDADOS INTENSIVOS'))return'🔴 UCI';if(u.includes('URG'))return'🟡 Urgencias';if(u.includes('AZU')||u.includes('AZUL')||u.includes('BLQ')||u.includes('BLOQUE'))return'🔵 Bloque Azul';const m=hab.match(/^(\d)/);return m?'Piso '+m[1]:'Sin piso';};
  const grouped={};
  filtered.forEach(p=>{const piso=getPiso(p);if(!grouped[piso])grouped[piso]=[];grouped[piso].push(p);});
  const pisoCustomOrder=['🔵 Bloque Azul','Piso 1','Piso 6','🔴 UCI','Piso 5','Piso 4','Piso 3','Piso 2','🟡 Urgencias','🚶 Consulta Externa'];
  const pisoOrder=Object.keys(grouped).sort((a,b)=>{const ia=pisoCustomOrder.indexOf(a),ib=pisoCustomOrder.indexOf(b);if(ia!==-1&&ib!==-1)return ia-ib;if(ia!==-1)return-1;if(ib!==-1)return 1;const na=parseInt(a.replace('Piso ','')),nb=parseInt(b.replace('Piso ',''));return isNaN(na)?1:isNaN(nb)?-1:na-nb;});
  const riskBadge=(r)=>{if(!r||r==='SIN RIESGO')return'<span class="badge badge-green">Sin riesgo</span>';if(r==='BAJO')return'<span class="badge badge-green">Bajo</span>';if(r==='MEDIO')return'<span class="badge badge-yellow">Medio</span>';if(r==='ALTO')return'<span class="badge badge-red">Alto</span>';return'<span class="badge badge-gray">—</span>';};
  const estadoBadge=(e)=>{const m={'seguimiento':'badge-blue','nueva-interconsulta-pendiente':'badge-yellow','consulta-externa':'badge-purple','alta':'badge-gray','revaloracion':'badge-purple','alta-voluntaria':'badge-orange','fallecido':'badge-black'};const l={'seguimiento':'Seguimiento','nueva-interconsulta-pendiente':'IC pendiente','consulta-externa':'C. Externa','alta':'Alta','revaloracion':'Revaluación','alta-voluntaria':'⚠ Alta voluntaria','fallecido':'✝ Fallecido'};return`<span class="badge ${m[e]||'badge-gray'}">${l[e]||e||'—'}</span>`;};
  const hoyStr=new Date().toISOString().split('T')[0];
  const proxBadge=(p)=>{
    if(!p.proxSesion)return'<span style="color:var(--text3);font-size:12px">—</span>';
    const diff=Math.round((new Date(p.proxSesion)-new Date(hoyStr))/(1000*60*60*24));
    const label=formatDate(p.proxSesion);
    if(diff<0)  return`<div style="display:flex;flex-direction:column;gap:2px"><span style="background:#3d1515;color:#F87171;border-radius:6px;padding:3px 8px;font-size:11px;font-weight:700">⚠ Vencida</span><span style="font-size:11px;color:#F87171">${label}</span></div>`;
    if(diff===0)return`<div style="display:flex;flex-direction:column;gap:2px"><span style="background:#3d3015;color:#FBBF24;border-radius:6px;padding:3px 8px;font-size:11px;font-weight:700">📅 HOY</span><span style="font-size:11px;color:#FBBF24">${label}</span></div>`;
    if(diff===1)return`<div style="display:flex;flex-direction:column;gap:2px"><span style="background:#0e2d3a;color:#38BDF8;border-radius:6px;padding:3px 8px;font-size:11px;font-weight:700">Mañana</span><span style="font-size:11px;color:#38BDF8">${label}</span></div>`;
    if(diff<=7) return`<div style="display:flex;flex-direction:column;gap:2px"><span style="background:#0e2d3a;color:#38BDF8;border-radius:6px;padding:3px 8px;font-size:11px">En ${diff} días</span><span style="font-size:11px;color:#38BDF8">${label}</span></div>`;
    return`<span style="font-size:12px;color:var(--text2)">${label}</span>`;
  };
  let html=q?`<tr><td colspan="8" style="background:#1a3a2a;font-size:0.75rem;color:#34D399;padding:7px 14px;">🔍 Mostrando ${filtered.length} resultado${filtered.length>1?'s':''} para "<strong>${q}</strong>" — <a href="#" onclick="window._searchQ='';document.getElementById('global-search').value='';renderPacientes();return false;" style="color:#34D399">Limpiar</a></td></tr>`:'';
  pisoOrder.forEach(piso=>{
    if(!q)html+=`<tr><td colspan="8" style="background:var(--surface2);font-size:0.72rem;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:0.06em;padding:7px 14px;">🏢 ${piso}</td></tr>`;
    html+=grouped[piso].map(p=>`<tr><td><strong>${p.nombre}</strong><div class="td-sub">${p.hab?'Hab. '+p.hab:''} ${p.fecha?'· '+formatDate(p.fecha):''}</div></td><td>${p.cedula}</td><td>${p.edad?p.edad+' a.':''} ${p.sexo?p.sexo.charAt(0):''}</td><td>${p.motivo?p.motivo.slice(0,40)+(p.motivo.length>40?'…':''):'—'}</td><td>${riskBadge(p.riesgo)}</td><td>${estadoBadge(p.estado)}</td><td>${proxBadge(p)}</td><td><div style="display:flex;gap:5px;flex-wrap:wrap"><button class="btn btn-sm btn-secondary" onclick="nuevaAnamnesisParaPaciente('${p.id}')">📋</button><button class="btn btn-sm btn-secondary" onclick="abrirICParaPaciente('${p.id}')">💬 IC</button><button class="btn btn-sm btn-secondary" onclick="irTestsPaciente('${p.id}')">🧪</button><button class="btn btn-sm btn-secondary" onclick="verHistorialPorId('${p.id}')">📂</button><button class="btn btn-sm btn-secondary" onclick="editarPaciente('${p.id}')">✏️</button><button class="btn btn-sm btn-danger" onclick="eliminarPaciente('${p.id}')">✕</button></div></td></tr>`).join('');
  });
  tbody.innerHTML=html;
};

window.eliminarPaciente=async(id)=>{if(!confirm('¿Eliminar este paciente?'))return;try{await deleteDoc(doc(db,'pacientes',id));toast('🗑️ Paciente eliminado');}catch(e){toast('❌ '+e.message);}};

window.populateICPacientes=()=>{
  const sel=document.getElementById('ic-paciente');
  if(sel)sel.innerHTML='<option value="">— Seleccionar paciente —</option>'+pacientes.map(p=>`<option value="${p.id}">${p.nombre} (${p.cedula})</option>`).join('');
  const sel2=document.getElementById('ic-paciente-sel');
  if(sel2)sel2.innerHTML='<option value="">— Seleccionar paciente (opcional, o llenar manualmente) —</option>'+pacientes.map(p=>`<option value="${p.id}">${p.nombre}${p.hab?' — Hab. '+p.hab:''} (${p.cedula})</option>`).join('');
  const sel3=document.getElementById('test-pac-sel');
  if(sel3)sel3.innerHTML='<option value="">— Seleccionar o llenar manualmente —</option>'+pacientes.map(p=>`<option value="${p.id}">${p.nombre}${p.hab?' — Hab. '+p.hab:''} (${p.cedula})</option>`).join('');
  const sel4=document.getElementById('cap-pac-sel');
  if(sel4)sel4.innerHTML='<option value="">— Seleccionar paciente —</option>'+pacientes.map(p=>`<option value="${p.id}">${p.nombre}${p.hab?' — Hab. '+p.hab:''}</option>`).join('');
};

window.selectCapPaciente=(id)=>{
  if(!id)return;
  const p=pacientes.find(x=>x.id===id);
  if(!p)return;
  const set=(eid,v)=>{const el=document.getElementById(eid);if(el)el.value=v||'';};
  set('cap-nombre',p.nombre);
  set('cap-edad',(p.edad?p.edad+' años':'')+(p.sexo?' · '+p.sexo:''));
  set('cap-hab',p.hab);
  set('cap-dx',p.motivo);
  window._capPacienteId=p.id;
};

window.setCapCriterio=(id,valor,btn)=>{
  document.getElementById(id).value=valor;
  const parent=btn.parentElement;
  parent.querySelectorAll('.risk-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  if(valor==='CONSERVADA')btn.style.background='var(--success-light)',btn.style.borderColor='var(--success)';
  else if(valor==='PARCIAL')btn.style.background='var(--warning-light)',btn.style.borderColor='var(--warning)';
  else btn.style.background='var(--danger-light)',btn.style.borderColor='var(--danger)';
};

window.setCapConclusion=(valor,btn)=>{
  document.getElementById('cap-conclusion').value=valor;
  btn.parentElement.querySelectorAll('.risk-btn').forEach(b=>{b.style.background='';b.style.borderColor='';b.style.fontWeight='';});
  btn.style.fontWeight='800';
  if(valor==='CONSERVADA')btn.style.background='var(--success-light)',btn.style.borderColor='var(--success)';
  else if(valor==='DISMINUIDA')btn.style.background='var(--warning-light)',btn.style.borderColor='var(--warning)';
  else btn.style.background='var(--danger-light)',btn.style.borderColor='var(--danger)';
};

window.limpiarCapacidad=()=>{
  ['cap-nombre','cap-edad','cap-hab','cap-dx','cap-decision','cap-solicitante','cap-c1-obs','cap-c2-obs','cap-c3-obs','cap-c4-obs','cap-factores-obs','cap-notas'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  ['cap-c1','cap-c2','cap-c3','cap-c4','cap-conclusion'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  document.querySelectorAll('#cap-factores input, #cap-recom input').forEach(cb=>cb.checked=false);
  document.querySelectorAll('#page-capacidad .risk-btn').forEach(b=>{b.style.background='';b.style.borderColor='';b.style.fontWeight='';});
  const sel=document.getElementById('cap-pac-sel');if(sel)sel.value='';
  document.getElementById('cap-nota-output').textContent='Completa los campos y presiona "Generar nota"…';
  window._capPacienteId=null;
  const fd=document.getElementById('cap-fecha');if(fd)fd.value=new Date().toISOString().split('T')[0];
};

window.generarNotaCapacidad=()=>{
  const v=id=>document.getElementById(id)?.value||'';
  const cb=id=>Array.from(document.querySelectorAll(`#${id} input:checked`)).map(x=>x.value).join(', ')||'Ninguno';
  const crit=(id,label)=>{const val=v(id)||'No evaluado';const obs=v(id+'-obs');return`${label}: ${val}${obs?' — '+obs:''}`;};
  const nombre=v('cap-nombre')||'Paciente';
  const fecha=v('cap-fecha')||new Date().toLocaleDateString('es-CO');
  const conclusion=v('cap-conclusion')||'No determinada';
  const nota=`VALORACIÓN DE CAPACIDAD DECISIONAL
Fecha: ${fecha}
Paciente: ${nombre}${v('cap-edad')?' · '+v('cap-edad'):''}${v('cap-hab')?' · Hab. '+v('cap-hab'):''}
Situación clínica: ${v('cap-dx')||'—'}
Decisión a evaluar: ${v('cap-decision')||'—'}
Solicitado por: ${v('cap-solicitante')||'—'}

━━━ EVALUACIÓN DE LOS 4 CRITERIOS ━━━

${crit('cap-c1','1. Comprensión')}
${crit('cap-c2','2. Apreciación')}
${crit('cap-c3','3. Razonamiento')}
${crit('cap-c4','4. Expresión de la decisión')}

━━━ FACTORES QUE AFECTAN LA CAPACIDAD ━━━
${cb('cap-factores')}
${v('cap-factores-obs')?'Observaciones: '+v('cap-factores-obs'):''}

━━━ CONCLUSIÓN ━━━
CAPACIDAD DECISIONAL: ${conclusion}

Recomendaciones al equipo médico:
${cb('cap-recom')}
${v('cap-notas')?'\nNotas adicionales:\n'+v('cap-notas'):''}

Valoración realizada por: Psicología Clínica · Hospitalaria`;

  document.getElementById('cap-nota-output').textContent=nota;
  return nota;
};

window.copiarNotaCapacidad=()=>{
  const txt=document.getElementById('cap-nota-output').textContent;
  if(!txt||txt.includes('Completa los campos'))return toast('⚠️ Genera la nota primero');
  navigator.clipboard.writeText(txt).then(()=>toast('✅ Nota copiada')).catch(()=>{
    const ta=document.createElement('textarea');ta.value=txt;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);toast('✅ Nota copiada');
  });
};

window.guardarCapacidadFirebase=async()=>{
  const nombre=document.getElementById('cap-nombre')?.value?.trim();
  if(!nombre)return toast('⚠️ Ingresa el nombre del paciente');
  const nota=generarNotaCapacidad();
  const v=id=>document.getElementById(id)?.value||'';
  const cb=id=>Array.from(document.querySelectorAll(`#${id} input:checked`)).map(x=>x.value);
  setSyncStatus('syncing');
  try{
    await addDoc(collection(db,'capacidad_decisional'),{
      pacienteId:window._capPacienteId||null,
      pacienteNombre:nombre,
      fecha:v('cap-fecha'),
      hab:v('cap-hab'),
      dx:v('cap-dx'),
      decision:v('cap-decision'),
      solicitante:v('cap-solicitante'),
      c1:v('cap-c1'),c1obs:v('cap-c1-obs'),
      c2:v('cap-c2'),c2obs:v('cap-c2-obs'),
      c3:v('cap-c3'),c3obs:v('cap-c3-obs'),
      c4:v('cap-c4'),c4obs:v('cap-c4-obs'),
      factores:cb('cap-factores'),
      conclusion:v('cap-conclusion'),
      recomendaciones:cb('cap-recom'),
      notas:v('cap-notas'),
      nota,
      creado:serverTimestamp()
    });
    setSyncStatus('online');
    toast('✅ Valoración guardada en Firebase');
  }catch(e){setSyncStatus('offline');toast('❌ '+e.message);}
};

window.selectTestPaciente=(id)=>{
  if(!id)return;
  const p=pacientes.find(x=>x.id===id);
  if(!p)return;
  const nombre=document.getElementById('test-pac-nombre');
  const edad=document.getElementById('test-pac-edad');
  if(nombre)nombre.value=p.nombre;
  if(edad&&p.edad)edad.value=p.edad;
  // guardar id para asociar resultado
  window._testPacienteId=p.id;
};

window.selectICPaciente=(id)=>{
  if(!id)return;
  const p=pacientes.find(x=>x.id===id);
  if(!p)return;
  const hab=document.getElementById('ic-hab');
  const nombre=document.getElementById('ic-pnombre');
  const edad=document.getElementById('ic-edad');
  const dx=document.getElementById('ic-pdx');
  const fecha=document.getElementById('ic-pfecha');
  if(hab&&p.hab)hab.value=p.hab;
  if(nombre)nombre.value=p.nombre;
  if(edad&&(p.edad||p.sexo))edad.value=(p.edad?p.edad+' años':'')+(p.sexo?' '+p.sexo.charAt(0):'');
  if(dx&&p.motivo)dx.value=p.motivo;
  if(fecha)fecha.value=new Date().toISOString().split('T')[0];
  // Auto-set mode based on patient estado
  if(p.estado==='nueva-interconsulta-pendiente')setICMode('nueva');
  else if(p.estado==='seguimiento')setICMode('seg');
};

window.abrirICParaPaciente=(id)=>{
  goTo('interconsultas');
  setTimeout(()=>{
    const sel=document.getElementById('ic-paciente-sel');
    if(sel){sel.value=id;selectICPaciente(id);}
  },200);
};

window.editarPaciente=(id)=>{
  const p=pacientes.find(x=>x.id===id);
  if(!p)return;
  // Abrir modal primero (openModal limpia los campos), luego rellenar
  openModal('modal-paciente');
  // Pre-fill modal with patient data
  document.getElementById('p-nombre').value=p.nombre||'';
  document.getElementById('p-cedula').value=p.cedula||'';
  document.getElementById('p-edad').value=p.edad||'';
  document.getElementById('p-sexo').value=p.sexo||'';
  document.getElementById('p-fecha').value=p.fecha||'';
  document.getElementById('p-hab').value=p.hab||'';
  document.getElementById('p-motivo').value=p.motivo||'';
  document.getElementById('p-dxpsi').value=p.dxpsi||'';
  document.getElementById('p-riesgo').value=p.riesgo||'';
  document.getElementById('p-riesgo-obs').value=p.riesgoObs||'';
  document.getElementById('p-estado').value=p.estado||'seguimiento';
  document.getElementById('p-proxsesion').value=p.proxSesion||'';
  setPTipo(p.tipo||'hospitalizado');
  document.getElementById('p-notas').value=p.notas||'';
  document.querySelectorAll('#modal-paciente .risk-btn').forEach(b=>{b.classList.toggle('sel',b.textContent.trim()===p.riesgo);});
  // Change button to update
  const btn=document.querySelector('#modal-paciente .btn-primary');
  btn.textContent='Actualizar';btn.onclick=()=>actualizarPaciente(id);
};

window.actualizarPaciente=async(id)=>{
  setSyncStatus('syncing');
  try{
    await updateDoc(doc(db,'pacientes',id),{
      nombre:document.getElementById('p-nombre').value.trim(),
      cedula:document.getElementById('p-cedula').value.trim(),
      edad:document.getElementById('p-edad').value,
      sexo:document.getElementById('p-sexo').value,
      fecha:document.getElementById('p-fecha').value,
      hab:document.getElementById('p-hab').value,
      motivo:document.getElementById('p-motivo').value,
      dxpsi:document.getElementById('p-dxpsi').value,
      riesgo:document.getElementById('p-riesgo').value,
      riesgoObs:document.getElementById('p-riesgo-obs').value,
      tipo:document.getElementById('p-tipo').value||'hospitalizado',
      estado:document.getElementById('p-estado').value,
      proxSesion:document.getElementById('p-proxsesion').value,
      notas:document.getElementById('p-notas').value
    });
    closeModal('modal-paciente');toast('✅ Paciente actualizado');
    const btn=document.querySelector('#modal-paciente .btn-primary');
    btn.textContent='Registrar';btn.onclick=guardarPaciente;
  }catch(e){setSyncStatus('offline');toast('❌ '+e.message);}
};

window.guardarIC=async()=>{
  const pacId=document.getElementById('ic-paciente')?.value;
  const esp=document.getElementById('ic-especialidad')?.value||'';
  const motivo=document.getElementById('ic-motivo')?.value?.trim()||'';
  if(!pacId||!motivo)return toast('⚠️ Paciente y motivo son obligatorios');
  const pac=pacientes.find(p=>p.id===pacId);setSyncStatus('syncing');
  try{
    await addDoc(collection(db,'interconsultas'),{
      pacienteId:pacId,pacienteNombre:pac?pac.nombre:'?',pacienteCedula:pac?pac.cedula:'',
      hab:pac?pac.hab||'':'',
      especialidad:esp,
      prioridad:document.getElementById('ic-prioridad')?.value||'normal',
      motivo,
      info:document.getElementById('ic-info')?.value||'',
      fecha:document.getElementById('ic-fecha')?.value||'',
      medico:document.getElementById('ic-medico')?.value||'',
      estado:'pendiente',creado:serverTimestamp()
    });
    closeModal('modal-ic');toast('✅ Interconsulta enviada');
  }catch(e){setSyncStatus('offline');toast('❌ '+e.message);}
};

window.renderIC=()=>{
  const cont=document.getElementById('lista-ic');
  if(!cont)return;
  if(!interconsultas.length){cont.innerHTML='<div class="empty"><p>No hay interconsultas registradas.</p></div>';return;}
  cont.innerHTML=interconsultas.map(ic=>{
    const nombre=ic.pacienteNombre||'Sin nombre';
    const titulo=ic.especialidad?`${ic.especialidad} — ${nombre}`:(ic.hab?`Hab. ${ic.hab} — ${nombre}`:nombre);
    const rawDesc=ic.nota||ic.obj||ic.trat||ic.motivo||ic.dx||'—';
    const desc=rawDesc.slice(0,120)+(rawDesc.length>120?'…':'');
    const prioridad=ic.prioridad||'normal';
    const estado=ic.estado||'pendiente';
    const estadoBadgeIC=e=>e==='subida'?'<span class="badge badge-blue">📋 Subida</span>':e==='respondida'?'<span class="badge badge-green">✅ Respondida</span>':'<span class="badge badge-yellow">⏳ Pendiente</span>';
    const accionBtn=estado==='pendiente'?`<button class="btn btn-sm btn-secondary" onclick="responderIC('${ic.id}')">✅ Respondida</button>`:estado==='respondida'?`<button class="btn btn-sm btn-primary" onclick="subirIC('${ic.id}')">📋 Subir al sistema</button>`:`<span style="font-size:0.72rem;color:var(--text3)">✓ En el sistema</span>`;
    const histBtn=ic.pacienteId?`<button class="btn btn-sm btn-secondary" onclick="verHistorialPorId('${ic.pacienteId}')" title="Ver historial del paciente">📂</button>`:'';
    return`<div class="ic-card"><div class="ic-icon ${prioridad==='urgente'?'urgent':estado==='pendiente'?'pending':'done'}">${prioridad==='urgente'?'🚨':estado==='subida'?'📋':estado==='respondida'?'✅':'📤'}</div><div class="ic-body"><h4 style="cursor:${ic.pacienteId?'pointer':'default'}" onclick="${ic.pacienteId?`verHistorialPorId('${ic.pacienteId}')`:''}">${titulo}</h4><p>${desc}</p><div class="ic-meta"><span class="badge ${prioridad==='urgente'?'badge-red':prioridad==='electiva'?'badge-blue':'badge-gray'}">${prioridad}</span>${estadoBadgeIC(estado)}<span class="text-sm">${ic.fecha?ic.fecha:''}</span></div></div><div class="ic-actions">${accionBtn}${histBtn}<button class="btn btn-sm btn-danger" onclick="eliminarIC('${ic.id}')">✕</button></div></div>`;
  }).join('');
};

window.responderIC=async(id)=>{try{await updateDoc(doc(db,'interconsultas',id),{estado:'respondida'});toast('✅ Marcada como respondida');}catch(e){toast('❌ '+e.message);}};
window.subirIC=async(id)=>{try{await updateDoc(doc(db,'interconsultas',id),{estado:'subida',fechaSubida:new Date().toISOString().split('T')[0]});toast('📋 Nota subida al sistema');}catch(e){toast('❌ '+e.message);}};
window.eliminarIC=async(id)=>{if(!confirm('¿Eliminar?'))return;try{await deleteDoc(doc(db,'interconsultas',id));toast('🗑️ Eliminada');}catch(e){toast('❌ '+e.message);}};

window.guardarICFirebase=async()=>{
  const nombre=document.getElementById('ic-pnombre').value.trim()||'Sin nombre';
  const hab=document.getElementById('ic-hab').value.trim()||'—';
  const dx=document.getElementById('ic-pdx').value.trim()||'—';
  const riesgo=document.getElementById('ic-riesgo-nivel').value||'No clasificado';
  const edad=document.getElementById('ic-edad')?.value||'';
  const fecha=document.getElementById('ic-pfecha').value||new Date().toISOString().split('T')[0];
  // Buscar paciente vinculado por nombre o selector
  const selPac=document.getElementById('ic-paciente-sel');
  const pacId=selPac?.value||null;
  const pacObj=pacId?pacientes.find(p=>p.id===pacId):pacientes.find(p=>p.nombre===nombre)||null;
  // Capturar nota generada si existe
  let notaTexto='';
  try{
    if(icCurrentMode==='nueva')notaTexto=generarNotaIcNueva()||'';
    else if(icCurrentMode==='seg')notaTexto=generarNotaIcSeg()||'';
    else if(icCurrentMode==='esp'){
      generarNotaIcEsp();
      const el=document.getElementById('ic-esp-text');
      notaTexto=(el?.textContent||'').trim();
    }
  }catch(e){}
  setSyncStatus('syncing');
  let sub='',obj='',resp='',trat='';
  try{
    if(icCurrentMode==='nueva'){
      const gs=t=>{const el=document.getElementById(t);if(!el)return'';const v=el.textContent||'';return v.startsWith('Genera')?'':v;};
      sub=gs('ic-out-sub');obj=gs('ic-out-obj');resp=gs('ic-out-resp');trat=gs('ic-out-trat');
    } else if(icCurrentMode==='seg'){
      const el=document.getElementById('ic-out-seg-texto');if(el){const v=el.textContent||'';obj=v.startsWith('Genera')?'':v;}
    } else if(icCurrentMode==='esp'){
      // solo en nota para evitar duplicado al renderizar
    }
  }catch(ex){}
  try{
    await addDoc(collection(db,'interconsultas'),{
      pacienteId:pacObj?.id||pacId||null,
      pacienteNombre:nombre,
      pacienteCedula:pacObj?.cedula||'',
      hab,edad,dx,riesgo,
      modo:icCurrentMode==='nueva'?'IC Nueva':icCurrentMode==='seg'?'Seguimiento':'Nota especial',
      fecha,nota:notaTexto,sub,obj,resp,trat,
      estado:'respondida',
      creado:serverTimestamp()
    });
    toast('✅ IC guardada en Firebase');
    setSyncStatus('online');
    // Limpiar formulario después de guardar
    setTimeout(()=>limpiarFormIC(false),300);
  }catch(e){setSyncStatus('offline');toast('❌ '+e.message);}
};

window.guardarAnamnesis=async()=>{
  const nombre=document.getElementById('an-nombre').value.trim();
  if(!nombre)return toast('⚠️ Ingresa el nombre del paciente');
  const nota=generarNota();setSyncStatus('syncing');
  try{await addDoc(collection(db,'anamnesis'),{pacienteId:document.getElementById('anamnesis-paciente-sel').value||null,pacienteNombre:nombre,pacienteCedula:document.getElementById('an-cedula').value,fecha:document.getElementById('an-fecha').value,riesgo:document.getElementById('an-riesgo').value,dx:getChecked('an-dx'),nota,modo:'Anamnesis',creado:serverTimestamp()});
  toast('✅ Anamnesis guardada');
  // Limpiar formulario después de guardar
  setTimeout(()=>clearAnamnesis(),300);
  }
  catch(e){setSyncStatus('offline');toast('❌ '+e.message);}
};

window.guardarResultadoTest=async(testName,score,level,paciente,extra)=>{
  setSyncStatus('syncing');
  const nombre=paciente||document.getElementById('test-pac-nombre').value||'Sin nombre';
  const pacId=window._testPacienteId||null;
  try{
    await addDoc(collection(db,'test_resultados'),{
      test:testName,score,level,
      paciente:nombre,
      pacienteId:pacId,
      fecha:new Date().toISOString().split('T')[0],
      extra:extra||'',
      creado:serverTimestamp()
    });
    setSyncStatus('online');
    toast('✅ Resultado guardado para '+nombre);
  }
  catch(e){setSyncStatus('offline');}
};

window.renderHistorial=()=>{
  const cont=document.getElementById('historial-list');
  if(!cont)return;
  if(!testHistory.length){cont.innerHTML='<div class="empty"><p>No hay tests registrados.</p></div>';return;}
  const iconos={PHQ9:'💙',GAD7:'⚡',HADS:'🏥',MMSE:'🧠',MoCA:'🧩',CAM:'🌀','C-SSRS':'🔴','MMAS-4':'💊',Duelo:'🕊️'};
  const levelLabel={normal:'Normal',moderate:'Leve/Moderado',high:'Alto',critical:'Crítico'};
  cont.innerHTML=testHistory.map(t=>{
    const pac=t.pacienteId?pacientes.find(p=>p.id===t.pacienteId):null;
    const nombre=pac?pac.nombre:(t.paciente||'Sin nombre');
    const hab=pac&&pac.hab?` · Hab. ${pac.hab}`:'';
    return`<div class="hist-item"><div class="hist-icon">${iconos[t.test]||'📊'}</div><div class="hist-body"><h4>${t.test} — ${nombre}</h4><p>${hab?hab.trim()+' · ':''}${t.extra||''}</p></div><div class="hist-meta"><span class="badge ${t.level==='normal'?'badge-green':t.level==='moderate'?'badge-yellow':t.level==='high'||t.level==='critical'?'badge-red':'badge-gray'}">${levelLabel[t.level]||t.level||'—'}</span><span class="text-sm">${t.fecha||''}</span>${t.score!==undefined&&t.score!==null?`<strong>${t.score} pts</strong>`:''}</div></div>`;
  }).join('');
};

window.clearTestHistory=async()=>{
  if(!confirm('¿Borrar todo el historial de tests?'))return;
  for(const t of testHistory){try{await deleteDoc(doc(db,'test_resultados',t.id));}catch(e){}}
  toast('🗑️ Historial borrado');
};

// ── DASHBOARD STATE ──
let dashSoloHoy=true;
window.toggleDashView=(soloHoy)=>{
  dashSoloHoy=soloHoy;
  document.getElementById('btn-hoy-dash').style.opacity=soloHoy?'1':'0.5';
  document.getElementById('btn-todos-dash').style.opacity=soloHoy?'0.5':'1';
  document.getElementById('ronda-titulo').textContent=soloHoy?'📋 Pacientes para hoy':'🏥 Todos los pacientes — por piso';
  renderDashboard();
};

window.renderDashboard=()=>{
  const rondaCont=document.getElementById('ronda-pisos');
  const alertaCont=document.getElementById('dashboard-alertas');
  const actCont=document.getElementById('recent-activity');
  if(!rondaCont)return;

  // ── HELPERS ──
  const todayStr=()=>{const d=new Date();const y=d.getFullYear(),m=String(d.getMonth()+1).padStart(2,'0'),day=String(d.getDate()).padStart(2,'0');return`${y}-${m}-${day}`;};
  const hoy=todayStr();
  const getPiso=(p)=>{if(p.tipo==='consulta-externa')return'🚶 Consulta Externa';const hab=p.hab||'';if(!hab)return'Sin piso asignado';const u=hab.toUpperCase();if(u.includes('UCI')||u.includes('UTI')||u.includes('CUIDADOS INTENSIVOS'))return'🔴 UCI';if(u.includes('URG'))return'🟡 Urgencias';if(u.includes('AZU')||u.includes('AZUL')||u.includes('BLQ')||u.includes('BLOQUE'))return'🔵 Bloque Azul';const m=hab.match(/^(\d+)/);if(!m)return'Sin piso asignado';const n=parseInt(m[1]);if(n>=100)return'Piso '+Math.floor(n/100);return'Piso '+n;};
  const riskClass=(r)=>r==='ALTO'?'riesgo-alto':r==='MEDIO'?'riesgo-medio':r==='BAJO'?'riesgo-bajo':'riesgo-sin';
  const riskBadge=(r)=>{if(!r||r==='SIN RIESGO')return'<span class="badge badge-green">Sin riesgo</span>';if(r==='BAJO')return'<span class="badge badge-green">Riesgo bajo</span>';if(r==='MEDIO')return'<span class="badge badge-yellow">Riesgo medio</span>';if(r==='ALTO')return'<span class="badge badge-red">⚠️ Riesgo alto</span>';return'';};
  const estadoBadge=(e)=>{const m={'seguimiento':'badge-blue','nueva-interconsulta-pendiente':'badge-yellow','consulta-externa':'badge-purple','alta':'badge-gray','revaloracion':'badge-purple','alta-voluntaria':'badge-orange','fallecido':'badge-black'};const l={'seguimiento':'Seguimiento','nueva-interconsulta-pendiente':'IC pendiente','consulta-externa':'C. Externa','alta':'Alta','revaloracion':'Revaluacion','alta-voluntaria':'⚠ Alta voluntaria','fallecido':'✝ Fallecido'};return'<span class="badge '+(m[e]||'badge-gray')+'">'+( l[e]||e||'-')+'</span>';};

  // ── FILTRAR: solo hoy o todos ──
  let lista=pacientes.filter(p=>p.estado!=='alta');
  if(dashSoloHoy){
    lista=lista.filter(p=>p.proxSesion===hoy);
  }

  // ── AGRUPAR POR PISO ──
  const grouped={};
  lista.forEach(p=>{const key=getPiso(p);if(!grouped[key])grouped[key]=[];grouped[key].push(p);});

  if(!lista.length){
    rondaCont.innerHTML=dashSoloHoy
      ?`<div class="empty"><p>✅ No hay pacientes programados para hoy.<br><small>Si acabas de registrar pacientes, verifica que tengan fecha de próxima sesión igual a hoy (${hoy}).</small></p><button class="btn btn-secondary btn-sm" style="margin-top:12px" onclick="toggleDashView(false)">Ver todos los pacientes</button></div>`
      :`<div class="empty"><p>No hay pacientes activos registrados.</p></div>`;
  } else {
    const pisoCustomOrder=['🔵 Bloque Azul','Piso 1','Piso 6','🔴 UCI','Piso 5','Piso 4','Piso 3','Piso 2','🟡 Urgencias','🚶 Consulta Externa'];
    const pisoKeys=Object.keys(grouped).sort((a,b)=>{
      const ia=pisoCustomOrder.indexOf(a),ib=pisoCustomOrder.indexOf(b);
      if(ia!==-1&&ib!==-1)return ia-ib;
      if(ia!==-1)return-1;if(ib!==-1)return 1;
      const na=parseInt(a.replace('Piso ','')),nb=parseInt(b.replace('Piso ',''));
      return isNaN(na)?1:isNaN(nb)?-1:na-nb;
    });
    // Ordenar dentro de cada piso: riesgo ALTO primero
    const riskOrder={'ALTO':0,'MEDIO':1,'BAJO':2,'SIN RIESGO':3,'':4};
    pisoKeys.forEach(k=>grouped[k].sort((a,b)=>(riskOrder[a.riesgo]||4)-(riskOrder[b.riesgo]||4)));

    rondaCont.innerHTML=pisoKeys.map(piso=>{
      const ps=grouped[piso];
      const cards=ps.map(p=>`
        <div class="ronda-card ${riskClass(p.riesgo)}" onclick="abrirPacSheet('${p.id}')" style="cursor:pointer">
          <div class="rc-hab">${p.tipo==='consulta-externa'?'🚶 Consulta Externa':p.hab&&p.hab.toUpperCase().match(/AZU|AZUL|BLQ|BLOQUE/)?'🔵 '+p.hab:`🚪 ${p.hab?'Hab. '+p.hab:'Sin hab.'}`}</div>
          <div class="rc-nombre">${p.nombre}</div>
          ${p.cedula?`<div style="font-size:0.68rem;color:var(--text3);margin-bottom:2px">CC: ${p.cedula}</div>`:''}
          <div class="rc-dx">${p.motivo?p.motivo.slice(0,70)+(p.motivo.length>70?'…':''):'Sin diagnóstico registrado'}</div>
          <div class="rc-badges">${riskBadge(p.riesgo)} ${estadoBadge(p.estado)}</div>
          ${p.proxSesion?`<div class="rc-proxima">📅 Próx. sesión: ${formatDate(p.proxSesion)}</div>`:''}
          <div style="display:flex;gap:5px;margin-top:8px;flex-wrap:wrap" onclick="event.stopPropagation()">
            <button class="btn btn-sm btn-secondary" onclick="abrirICParaPaciente('${p.id}')">💬 IC</button>
            <button class="btn btn-sm btn-secondary" onclick="irTestsPaciente('${p.id}')">🧪 Test</button>
            <button class="btn btn-sm btn-secondary" onclick="editarPaciente('${p.id}')">✏️ Editar</button>
            <button class="btn btn-sm btn-secondary" onclick="verHistorialPorId('${p.id}')">📂 Historial IC</button>
          </div>
        </div>`).join('');
      return`<div class="piso-group">
        <div class="piso-header">🏢 ${piso}<span class="piso-count">${ps.length} paciente${ps.length>1?'s':''}</span></div>
        <div class="ronda-cards">${cards}</div>
      </div>`;
    }).join('');
  }

  // ── ALERTAS ──
  const alertas=[];
  pacientes.filter(p=>p.riesgo==='ALTO'&&p.estado!=='alta').forEach(p=>alertas.push({tipo:'rojo',icon:'🔴',titulo:`Riesgo ALTO — ${p.nombre}`,desc:`Hab. ${p.hab||'—'} · ${p.motivo||'Sin diagnóstico'}`}));
  pacientes.filter(p=>p.estado==='nueva-interconsulta-pendiente').forEach(p=>alertas.push({tipo:'amarillo',icon:'📋',titulo:`IC pendiente — ${p.nombre}`,desc:`Hab. ${p.hab||'—'}`}));
  pacientes.filter(p=>p.riesgo==='MEDIO'&&p.estado!=='alta').forEach(p=>alertas.push({tipo:'amarillo',icon:'⚠️',titulo:`Riesgo MEDIO — ${p.nombre}`,desc:`Hab. ${p.hab||'—'}`}));
  if(alertaCont){
    alertaCont.innerHTML=alertas.length
      ?alertas.map(a=>`<div class="alerta-card alerta-${a.tipo}"><div class="al-icon">${a.icon}</div><div class="al-body"><h4>${a.titulo}</h4><p>${a.desc}</p></div></div>`).join('')
      :'<div class="empty" style="padding:16px"><p>✅ Sin alertas activas.</p></div>';
  }

  // ── ACTIVIDAD RECIENTE ──
  if(actCont){
    const all=[
      ...interconsultas.map(ic=>({tipo:'IC',txt:`${ic.hab?'Hab. '+ic.hab+' · ':''}${ic.pacienteNombre||''}`,badge:'badge-blue',ts:ic.creado?.toDate?.()??new Date()})),
      ...anamnesisList.map(a=>({tipo:'Anamnesis',txt:a.pacienteNombre,badge:'badge-yellow',ts:a.creado?.toDate?.()??new Date()})),
      ...testHistory.map(t=>({tipo:t.test,txt:t.paciente,badge:'badge-gray',ts:t.creado?.toDate?.()??new Date()}))
    ].sort((a,b)=>b.ts-a.ts).slice(0,8);
    actCont.innerHTML=all.length
      ?'<div class="table-wrap"><table><thead><tr><th>Tipo</th><th>Descripción</th><th>Fecha</th></tr></thead><tbody>'+all.map(a=>`<tr><td><span class="badge ${a.badge}">${a.tipo}</span></td><td>${a.txt}</td><td class="td-sub">${a.ts.toLocaleString('es-CO',{dateStyle:'short',timeStyle:'short'})}</td></tr>`).join('')+'</tbody></table></div>'
      :'<div class="empty"><p>Sin actividad reciente.</p></div>';
  }
};
window.updateStats=()=>{
  const set=(id,v)=>{const el=document.getElementById(id);if(el)el.textContent=v;};
  set('stat-pac',pacientes.filter(p=>p.estado!=='alta').length);
  const icPendIC=interconsultas.filter(x=>x.estado==='pendiente').length;const icPendPac=pacientes.filter(x=>x.estado==='nueva-interconsulta-pendiente').length;set('stat-ic',icPendIC+icPendPac);
  set('stat-riesgo',pacientes.filter(p=>p.riesgo==='ALTO').length);
  const hoy=new Date().toISOString().split('T')[0];
  set('stat-tests',testHistory.filter(t=>t.fecha===hoy).length);
  set('stat-altas',pacientes.filter(p=>p.estado==='alta').length);
};
window.toggleAltasPanel=()=>{
  const panel=document.getElementById('altas-panel');
  if(!panel)return;
  const visible=panel.style.display!=='none';
  panel.style.display=visible?'none':'block';
  if(!visible)renderAltasList();
};
window.renderAltasList=()=>{
  const list=document.getElementById('altas-list');
  if(!list)return;
  const altas=pacientes.filter(p=>p.estado==='alta');
  if(!altas.length){list.innerHTML='<p style="color:var(--text3);padding:12px">No hay pacientes con alta registrada.</p>';return;}
  list.innerHTML=altas.map(p=>`<div class="patient-row" style="display:flex;justify-content:space-between;align-items:center;padding:12px 16px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:8px">
    <div>
      <div style="font-weight:600">${p.nombre}</div>
      <div style="font-size:0.75rem;color:var(--text3)">Hab. ${p.hab||'—'} · Céd. ${p.cedula||'—'} · ${p.dx||'Sin diagnóstico'}</div>
      <div style="font-size:0.75rem;color:var(--text3)">Ingreso: ${p.ingreso||'—'}</div>
    </div>
    <span class="badge badge-gray">Alta</span>
  </div>`).join('');
};
window.updateBadges=()=>{
  const bp=document.getElementById('badge-pac'),bi=document.getElementById('badge-ic'),bce=document.getElementById('badge-ce');
  if(bp)bp.textContent=pacientes.length;
  const biVal=interconsultas.filter(x=>x.estado==='pendiente').length+pacientes.filter(x=>x.estado==='nueva-interconsulta-pendiente').length;if(bi)bi.textContent=biVal;
  if(bce)bce.textContent=pacientes.filter(p=>p.tipo==='consulta-externa'&&p.estado!=='alta').length;
};
window.renderConsultaExterna=(q)=>{
  const cont=document.getElementById('ce-lista');if(!cont)return;
  const q2=(typeof q==='string'?q:(document.getElementById('ce-search')?.value||'')).toLowerCase().trim();
  let lista=(window.pacientes||[]).filter(p=>p.tipo==='consulta-externa'&&p.estado!=='alta');
  if(q2)lista=lista.filter(p=>(p.nombre||'').toLowerCase().includes(q2)||(p.cedula||'').includes(q2));
  const rBadge=r=>{if(!r||r==='SIN RIESGO')return'<span class="badge badge-green">Sin riesgo</span>';if(r==='BAJO')return'<span class="badge badge-green">Riesgo bajo</span>';if(r==='MEDIO')return'<span class="badge badge-yellow">Riesgo medio</span>';if(r==='ALTO')return'<span class="badge badge-red">⚠️ Riesgo alto</span>';return'';};
  const hoy=new Date().toISOString().split('T')[0];
  if(!lista.length){cont.innerHTML='<div class="empty"><p>No hay pacientes de consulta externa registrados.<br><small>Crea un paciente y selecciona "Consulta externa" como tipo.</small></p></div>';return;}
  cont.innerHTML='<div class="table-wrap"><table><thead><tr><th>Paciente</th><th>Cédula</th><th>Dx / Motivo</th><th>Riesgo</th><th>Próxima cita</th><th>Acciones</th></tr></thead><tbody>'+lista.map(p=>{
    const diff=p.proxSesion?Math.round((new Date(p.proxSesion)-new Date(hoy))/(86400000)):null;
    const citaBadge=p.proxSesion?(diff<0?'<span style="background:#3d1515;color:#F87171;border-radius:6px;padding:2px 7px;font-size:11px;font-weight:700">⚠ Vencida</span>':diff===0?'<span style="background:#3d3015;color:#FBBF24;border-radius:6px;padding:2px 7px;font-size:11px;font-weight:700">📅 HOY</span>':''):'';
    return`<tr>
      <td><div style="font-weight:600">${p.nombre}</div><div class="td-sub">${p.edad?p.edad+' años':''}${p.sexo?' · '+p.sexo:''}</div></td>
      <td>${p.cedula||'—'}</td>
      <td style="max-width:200px"><div style="font-size:0.82rem;line-height:1.4">${(p.motivo||'').slice(0,80)}</div></td>
      <td>${rBadge(p.riesgo)}</td>
      <td>${p.proxSesion?`<div>${citaBadge}</div><div style="font-size:0.78rem;color:var(--text2)">${formatDate(p.proxSesion)}</div>`:'<span style="color:var(--text3)">—</span>'}</td>
      <td><div style="display:flex;gap:5px;flex-wrap:wrap">
        <button class="btn btn-sm btn-secondary" onclick="nuevaAnamnesisParaPaciente('${p.id}')">📋 Anamnesis</button>
        <button class="btn btn-sm btn-secondary" onclick="irTestsPaciente('${p.id}')">🧪 Tests</button>
        <button class="btn btn-sm btn-secondary" onclick="goTo('historial-pac');setTimeout(()=>hpacAbrirPaciente('${p.id}'),200)">📂 Historial</button>
        <button class="btn btn-sm btn-secondary" onclick="editarPaciente('${p.id}')">✏️ Editar</button>
      </div></td>
    </tr>`;
  }).join('')+'</tbody></table></div>';
};

window.populateAnamPacientes=()=>{
  const opts='<option value="">— Seleccionar paciente —</option>'+pacientes.map(p=>`<option value="${p.id}">${p.nombre} (${p.cedula})</option>`).join('');
  ['anamnesis-paciente-sel','seg-pac-sel','seg-historial-pac-sel'].forEach(id=>{const sel=document.getElementById(id);if(!sel)return;const cur=sel.value;sel.innerHTML=opts;if(cur)sel.value=cur;});
};

setSyncStatus('syncing');
['p-fecha','ic-fecha','an-fecha','ic-pfecha'].forEach(id=>{try{document.getElementById(id).value=new Date().toISOString().split('T')[0];}catch(e){}});

// ── NOTA EDITAR/GUARDAR (dentro del módulo para acceder a Firebase) ───
window.mneCerrar=()=>{const m=document.getElementById('modal-nota-edit');if(m)m.style.display='none';};

window.mneGuardar=async()=>{
  const v=id=>document.getElementById(id)?.value||'';
  const sub=v('mne-sub'),obj=v('mne-obj'),resp=v('mne-resp'),trat=v('mne-trat'),nota=v('mne-nota');
  const fecha=v('mne-fecha'),modo=v('mne-tipo'),riesgo=v('mne-riesgo'),estado=v('mne-estado');
  if(!fecha){toast('⚠️ Ingresa una fecha');return;}
  setSyncStatus('syncing');
  try{
    if(window._mneId){
      await updateDoc(doc(db,window._mneCol,window._mneId),{fecha,modo,riesgo,estado,sub,obj,resp,trat,nota,editado:serverTimestamp()});
      toast('✅ Nota actualizada');
    } else {
      const pac=pacientes.find(p=>p.id===window._hPacId);
      await addDoc(collection(db,'interconsultas'),{
        pacienteId:window._hPacId||null,
        pacienteNombre:window._hPacNombre||'',
        pacienteCedula:pac?.cedula||'',
        hab:pac?.hab||'',
        dx:pac?.motivo||'',
        fecha,modo,riesgo,estado,sub,obj,resp,trat,nota,
        creado:serverTimestamp()
      });
      toast('✅ Nota guardada');
    }
    setSyncStatus('online');
    window.mneCerrar();
    const cb=window._mneOnSave;window._mneOnSave=null;
    if(cb)cb();else setTimeout(()=>{if(typeof hpacRenderNotas==='function')hpacRenderNotas();if(typeof mhicRender==='function')mhicRender();},500);
  }catch(ex){setSyncStatus('offline');toast('❌ '+ex.message);}
};

window.mneEliminar=async()=>{
  if(!window._mneId||!confirm('¿Eliminar esta nota permanentemente?'))return;
  try{
    await deleteDoc(doc(db,window._mneCol,window._mneId));
    toast('🗑️ Nota eliminada');
    window.mneCerrar();
    const cb=window._mneOnSave;window._mneOnSave=null;
    if(cb)cb();else setTimeout(()=>{if(typeof hpacRenderNotas==='function')hpacRenderNotas();},500);
  }catch(ex){toast('❌ '+ex.message);}
};

window.hpacResponder=async(ni)=>{
  const m=(window._hMap||{})[ni];if(!m)return;
  try{
    await updateDoc(doc(db,m.col,m.id),{estado:'respondida'});
    toast('✅ Marcada como respondida');
    setTimeout(()=>{if(typeof hpacRenderNotas==='function')hpacRenderNotas();},400);
  }catch(ex){toast('❌ '+ex.message);}
};
</script>

<script>
// ── SAFE STUBS (evitan ReferenceError antes de que cargue el módulo Firebase) ──
// El módulo ES reemplaza window.fn con la función real al cargar.
// Estos stubs capturan clics tempranos y los reintenta hasta que el módulo esté listo.
(function(){
  function makeStub(name){
    window[name]=function stub(...args){
      // Si el módulo ya reemplazó el stub, llamar la versión real
      if(window[name]!==stub)return window[name](...args);
      // Si no, reintentar en 200ms
      setTimeout(()=>{if(window[name]!==stub)window[name](...args);else window[name](...args);},200);
    };
  }
  ['guardarPaciente','editarPaciente','eliminarPaciente','guardarIC','eliminarIC',
   'verHistorialPorId','nuevaAnamnesisParaPaciente','abrirICParaPaciente','irTestsPaciente',
   'guardarICFirebase','generarNotaIC','guardarCapacidadFirebase','limpiarCapacidad',
   'guardarAnamnesis','generarNotaAnamnesis','mhicNuevaNota','mhicCerrar',
   'mneCerrar','mneGuardar','mneEliminar','hpacNuevaNota','hpacVolverLista',
   'calcPHQ9','calcGAD7','calcHADS','calcMMSE','calcMoCA','calcCAM',
   'calcCSSRS','calcMMAS4','calcDuelo','calcPCL5','renderConsultaExterna'
  ].forEach(makeStub);
})();
// ── UI & NAVIGATION ──────────────────────────────────────────
const pages=['dashboard','pacientes','consulta-externa','interconsultas','historial-ic','anamnesis','tests','capacidad','historial','historial-pac'];
const titles={dashboard:'Inicio',pacientes:'Registro de Pacientes','consulta-externa':'Consulta Externa EPS',interconsultas:'Interconsultas','historial-ic':'Historial de Interconsultas',anamnesis:'Nueva Anamnesis',tests:'Tests Clínicos',capacidad:'Valoración de Capacidad Decisional',historial:'Historial de Tests','historial-pac':'Historial de Pacientes'};

window.goTo=(page)=>{
  pages.forEach(p=>document.getElementById('page-'+p).classList.toggle('active',p===page));
  document.querySelectorAll('.nav-item').forEach(el=>el.classList.remove('active'));
  document.getElementById('topbar-title').textContent=titles[page]||page;
  if(page==='pacientes'&&typeof renderPacientes==='function')renderPacientes();
  if(page==='consulta-externa'&&typeof renderConsultaExterna==='function')renderConsultaExterna();
  if(page==='interconsultas'){populateICPacientes();if(typeof renderIC==='function')renderIC();}
  if(page==='historial-ic'&&typeof renderIC==='function')renderIC();
  if(page==='tests')populateICPacientes();
  if(page==='capacidad'){populateICPacientes();const fd=document.getElementById('cap-fecha');if(fd&&!fd.value)fd.value=new Date().toISOString().split('T')[0];}
  if(page==='dashboard'&&typeof renderDashboard==='function')renderDashboard();
  if(page==='historial'&&typeof renderHistorial==='function')renderHistorial();
  if(page==='historial-pac')hpacRenderLista();
  // Cerrar sidebar en móvil al navegar
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebar-overlay').classList.remove('open');
  // Cerrar buscador
  closeSrDrop();
  const gs=document.getElementById('global-search');if(gs)gs.blur();
};

window.toggleSidebar=()=>{
  const isMobile=window.innerWidth<=1024;
  if(isMobile){
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('sidebar-overlay').classList.toggle('open');
  } else {
    const sb=document.getElementById('sidebar');
    const mn=document.querySelector('.main');
    const collapsed=sb.classList.toggle('collapsed');
    mn.style.marginLeft=collapsed?'0':'240px';
  }
};
window.openModal=(id)=>{document.getElementById(id).classList.add('open');if(id==='modal-ic')populateICPacientes();if(id==='modal-paciente'){setPTipo('hospitalizado');document.getElementById('p-estado').value='seguimiento';['p-nombre','p-cedula','p-edad','p-hab','p-motivo','p-dxpsi','p-riesgo-obs','p-notas','p-proxsesion'].forEach(fid=>{const el=document.getElementById(fid);if(el)el.value='';});document.getElementById('p-riesgo').value='';document.getElementById('p-sexo').value='';document.getElementById('p-fecha').value=new Date().toISOString().split('T')[0];document.querySelectorAll('#modal-paciente .risk-btn').forEach(b=>b.classList.remove('sel'));const btn=document.querySelector('#modal-paciente .btn-primary');if(btn){btn.textContent='Registrar';btn.onclick=guardarPaciente;}}};
window.closeModal=(id)=>document.getElementById(id).classList.remove('open');
document.querySelectorAll('.modal-overlay').forEach(el=>el.addEventListener('click',e=>{if(e.target===el)el.classList.remove('open')}));
window.nuevaAnamnesisParaPaciente=(id)=>{goTo('anamnesis');setTimeout(()=>{document.getElementById('anamnesis-paciente-sel').value=id;selectAnamPaciente(id);},200);};
window.nuevaICParaPaciente=(id)=>{abrirICParaPaciente(id);};
window.irTestsPaciente=(id)=>{
  const p=pacientes.find(x=>x.id===id);
  if(p){
    document.getElementById('test-pac-nombre').value=p.nombre;
    if(p.edad)document.getElementById('test-pac-edad').value=p.edad;
    window._testPacienteId=p.id;
  }
  goTo('tests');
  setTimeout(()=>{
    const sel=document.getElementById('test-pac-sel');
    if(sel)sel.value=id;
  },200);
};
window.abrirCapacidadPaciente=(id)=>{
  goTo('capacidad');
  setTimeout(()=>{
    const sel=document.getElementById('cap-pac-sel');
    if(sel){sel.value=id;selectCapPaciente(id);}
  },200);
};
window.selectAnamPaciente=(id)=>{if(!id||typeof pacientes==='undefined')return;const p=pacientes.find(x=>x.id===id);if(!p)return;document.getElementById('an-nombre').value=p.nombre;document.getElementById('an-cedula').value=p.cedula;if(p.edad)document.getElementById('an-edad').value=p.edad;if(p.motivo)document.getElementById('an-motivo').value=p.motivo;};
window.clearAnamnesis=()=>{document.getElementById('form-anamnesis').reset();document.getElementById('anamnesis-paciente-sel').value='';document.getElementById('an-riesgo').value='';document.querySelectorAll('.risk-btn').forEach(b=>b.classList.remove('sel'));document.getElementById('nota-output').textContent='Completa los campos y presiona "Generar nota clínica"…';document.getElementById('an-intens-val').textContent='5';};

// ── ANAMNESIS TABS & SESIONES ────────────────────────────────
window.anamSwitchTab=function(tab){
  // Update tab styles
  ['primera','sesion','historial'].forEach(t=>{
    const btn=document.getElementById('anam-tab-'+t);
    if(!btn)return;
    btn.style.color=t===tab?'var(--accent)':'var(--text2)';
    btn.style.borderBottomColor=t===tab?'var(--accent)':'transparent';
    btn.style.fontWeight=t===tab?'600':'500';
  });
  // Show/hide panels
  const form=document.getElementById('form-anamnesis');
  const panelSeg=document.getElementById('anam-panel-sesion');
  const panelHist=document.getElementById('anam-panel-historial');
  const timerBar=document.querySelector('#page-anamnesis .timer-bar');
  if(form)form.style.display=tab==='primera'?'':'none';
  if(timerBar)timerBar.style.display=tab==='primera'?'':'none';
  if(panelSeg)panelSeg.style.display=tab==='sesion'?'':'none';
  if(panelHist){
    panelHist.style.display=tab==='historial'?'':'none';
    if(tab==='historial'){
      const sel=document.getElementById('seg-historial-pac-sel');
      if(sel&&sel.value)anamHistorialRender(sel.value);
    }
  }
  // Auto-sync patient selection across tabs
  if(tab==='sesion'){
    const mainSel=document.getElementById('anamnesis-paciente-sel');
    const segSel=document.getElementById('seg-pac-sel');
    if(mainSel&&segSel&&mainSel.value&&!segSel.value)segSel.value=mainSel.value;
    // Set today's date if empty
    const fd=document.getElementById('seg-fecha');
    if(fd&&!fd.value)fd.value=new Date().toISOString().split('T')[0];
    // Auto-set session number
    anamSegAutoNum();
  }
  if(tab==='historial'){
    const mainSel=document.getElementById('anamnesis-paciente-sel');
    const histSel=document.getElementById('seg-historial-pac-sel');
    if(mainSel&&histSel&&mainSel.value&&!histSel.value){
      histSel.value=mainSel.value;
      anamHistorialRender(mainSel.value);
    }
  }
};

window.anamSegSelectPac=function(id){
  if(!id)return;
  anamSegAutoNum();
};

window.anamSegAutoNum=function(){
  const sel=document.getElementById('seg-pac-sel');
  const numEl=document.getElementById('seg-num');
  if(!sel||!sel.value||!numEl||numEl.value)return;
  const pacId=sel.value;
  const pacNombre=(window.pacientes||[]).find(p=>p.id===pacId)?.nombre||'';
  const prevSesiones=(window.anamnesisList||[]).filter(a=>
    (a.pacienteId===pacId||a.pacienteNombre===pacNombre)&&a.modo==='Seguimiento'
  );
  numEl.value=prevSesiones.length+2; // +1 for anamnesis inicial, +1 for this
};

window.anamSegLimpiar=function(){
  const ids=['seg-num','seg-eventos','seg-dificultades','seg-pensamiento','seg-ajustes',
    'seg-obj-corto','seg-obj-largo','seg-tec-psico-tema','seg-tec-otras-cual','seg-tec-reest-ef',
    'seg-tec-expos-nivel','seg-tarea-dbt2-cual','seg-tarea-otra2-cual','seg-dist-otra-cual',
    'seg-riesgo-otro-cual','seg-humor-escala','seg-phq-ini','seg-phq-act','seg-gad-ini',
    'seg-gad-act','seg-impuls','seg-proxcita'];
  ids.forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  const cbs=['seg-humor-estable','seg-humor-ansioso','seg-humor-depresivo','seg-humor-irritable',
    'seg-tarea-completa','seg-tarea-parcial','seg-tarea-no','seg-tec-reest','seg-tec-expos',
    'seg-tec-dbt','seg-tec-dbt-tol','seg-tec-dbt-reg','seg-tec-psico','seg-tec-otras',
    'seg-dist-catas','seg-dist-person','seg-dist-polar','seg-dist-sobre','seg-dist-filtr',
    'seg-dist-otra','seg-tarea-reg','seg-tarea-dbt2','seg-tarea-otra2','seg-riesgo-ideacion',
    'seg-riesgo-autolesion','seg-riesgo-otro','seg-rec-insight','seg-rec-motiv','seg-rec-apoyo'];
  cbs.forEach(id=>{const el=document.getElementById(id);if(el)el.checked=false;});
  document.querySelectorAll('input[name="seg-modalidad"]').forEach(r=>r.checked=false);
  const rEl=document.getElementById('seg-riesgo');if(rEl)rEl.value='';
  const fd=document.getElementById('seg-fecha');if(fd)fd.value=new Date().toISOString().split('T')[0];
};

window.anamSegGuardar=async function(){
  const pacId=document.getElementById('seg-pac-sel').value;
  if(!pacId)return toast('⚠️ Selecciona un paciente');
  const pac=(window.pacientes||[]).find(p=>p.id===pacId);
  if(!pac)return toast('⚠️ Paciente no encontrado');
  const gv=id=>{const el=document.getElementById(id);return el?el.value.trim():'';};
  const gc=id=>{const el=document.getElementById(id);return el?el.checked:false;};
  // Build structured summary fields
  const humor=[gc('seg-humor-estable')&&'Estable',gc('seg-humor-ansioso')&&'Ansioso',
    gc('seg-humor-depresivo')&&'Depresivo',gc('seg-humor-irritable')&&'Irritable'].filter(Boolean);
  const humorEsc=gv('seg-humor-escala');
  const subParts=[];
  if(humor.length)subParts.push('Humor: '+humor.join(', ')+(humorEsc?' ('+humorEsc+'/5)':''));
  if(gv('seg-eventos'))subParts.push('Eventos desde última sesión: '+gv('seg-eventos'));
  const tareaRev=[gc('seg-tarea-completa')&&'Completa',gc('seg-tarea-parcial')&&'Parcial',gc('seg-tarea-no')&&'No realizada'].filter(Boolean);
  if(tareaRev.length)subParts.push('Revisión de tarea: '+tareaRev.join(', '));
  if(gv('seg-dificultades'))subParts.push('Dificultades: '+gv('seg-dificultades'));
  const tecnicas=[];
  if(gc('seg-tec-reest'))tecnicas.push('Reestructuración cognitiva'+(gv('seg-tec-reest-ef')?' (ef. '+gv('seg-tec-reest-ef')+'/5)':''));
  if(gc('seg-tec-expos'))tecnicas.push('Exposición gradual'+(gv('seg-tec-expos-nivel')?' (ansiedad máx. '+gv('seg-tec-expos-nivel')+'/10)':''));
  if(gc('seg-tec-dbt')){let dbt='Habilidades DBT';const sub2=[];if(gc('seg-tec-dbt-tol'))sub2.push('Tolerancia al malestar');if(gc('seg-tec-dbt-reg'))sub2.push('Regulación emocional');if(sub2.length)dbt+=' ('+sub2.join(', ')+')';tecnicas.push(dbt);}
  if(gc('seg-tec-psico')&&gv('seg-tec-psico-tema'))tecnicas.push('Psicoeducación: '+gv('seg-tec-psico-tema'));
  if(gc('seg-tec-otras')&&gv('seg-tec-otras-cual'))tecnicas.push(gv('seg-tec-otras-cual'));
  const resp=tecnicas.length?'Técnicas: '+tecnicas.join(' | '):'' ;
  const cogParts=[];
  if(gv('seg-pensamiento'))cogParts.push('Pensamiento automático: "'+gv('seg-pensamiento')+'"');
  const dist=[gc('seg-dist-catas')&&'Catastrofismo',gc('seg-dist-person')&&'Personalización',
    gc('seg-dist-polar')&&'Pensamiento polarizado',gc('seg-dist-sobre')&&'Sobregeneralización',
    gc('seg-dist-filtr')&&'Filtro mental',gc('seg-dist-otra')&&gv('seg-dist-otra-cual')].filter(Boolean);
  if(dist.length)cogParts.push('Distorsiones: '+dist.join(', '));
  const objParts=[];
  const tareas=[];
  if(gc('seg-tarea-reg'))tareas.push('Registro de pensamientos');
  if(gc('seg-tarea-dbt2')&&gv('seg-tarea-dbt2-cual'))tareas.push('Práctica DBT: '+gv('seg-tarea-dbt2-cual'));
  if(gc('seg-tarea-otra2')&&gv('seg-tarea-otra2-cual'))tareas.push(gv('seg-tarea-otra2-cual'));
  if(tareas.length)objParts.push('Tareas: '+tareas.join(' | '));
  if(gv('seg-obj-corto'))objParts.push('Corto plazo: '+gv('seg-obj-corto'));
  if(gv('seg-obj-largo'))objParts.push('Largo plazo: '+gv('seg-obj-largo'));
  const notasParts=[];
  const riesgosD=[gc('seg-riesgo-ideacion')&&'Ideación suicida',gc('seg-riesgo-autolesion')&&'Autolesiones',
    gc('seg-riesgo-otro')&&gv('seg-riesgo-otro-cual')].filter(Boolean);
  if(riesgosD.length)notasParts.push('Riesgos: '+riesgosD.join(', '));
  const recursos=[gc('seg-rec-insight')&&'Insight',gc('seg-rec-motiv')&&'Motivación',gc('seg-rec-apoyo')&&'Apoyo social'].filter(Boolean);
  if(recursos.length)notasParts.push('Recursos: '+recursos.join(', '));
  if(gv('seg-ajustes'))notasParts.push('Ajustes terapéuticos: '+gv('seg-ajustes'));
  const escalasParts=[];
  if(gv('seg-phq-ini')||gv('seg-phq-act'))escalasParts.push('PHQ-9: inicial='+gv('seg-phq-ini')+' actual='+gv('seg-phq-act'));
  if(gv('seg-gad-ini')||gv('seg-gad-act'))escalasParts.push('GAD-7: inicial='+gv('seg-gad-ini')+' actual='+gv('seg-gad-act'));
  if(gv('seg-impuls'))escalasParts.push('Impulsividad TLP: '+gv('seg-impuls')+'/10');
  if(escalasParts.length)notasParts.push('Escalas: '+escalasParts.join(' | '));
  const modalidad=document.querySelector('input[name="seg-modalidad"]:checked')?.value||'';
  const proxcita=gv('seg-proxcita');
  if(proxcita)notasParts.push('Próxima cita: '+proxcita+(modalidad?' ('+modalidad+')':''));
  const sub=subParts.join('\n');
  const obj=cogParts.join('\n');
  const trat=objParts.join('\n');
  const nota=notasParts.join('\n');
  if(!sub&&!obj&&!resp&&!trat&&!nota)return toast('⚠️ Completa al menos un campo de la sesión');
  const riesgo=document.getElementById('seg-riesgo').value;
  const numSesion=gv('seg-num');
  const fecha=gv('seg-fecha')||new Date().toISOString().split('T')[0];
  setSyncStatus('syncing');
  try{
    const {collection,addDoc,serverTimestamp}=window._fdb||{};
    await addDoc(collection(window.db,'anamnesis'),{
      pacienteId:pac.id,pacienteNombre:pac.nombre,pacienteCedula:pac.cedula||'',
      fecha,numSesion:numSesion?parseInt(numSesion):null,modo:'Seguimiento',
      riesgo:riesgo||'',sub,obj,resp,trat,nota,
      creado:serverTimestamp()
    });
    toast('✅ Nota de sesión guardada');setSyncStatus('online');
    anamSegLimpiar();anamSegAutoNum();
  }catch(e){setSyncStatus('offline');toast('❌ '+e.message);}
};

window.anamHistorialRender=function(pacId){
  const cont=document.getElementById('seg-historial-lista');
  const countEl=document.getElementById('seg-historial-count');
  if(!cont)return;
  if(!pacId){cont.innerHTML='';if(countEl)countEl.textContent='';return;}
  const pac=(window.pacientes||[]).find(p=>p.id===pacId);
  const nombre=pac?.nombre||'';
  // Get all anamnesis records for this patient (initial + sessions)
  const todos=(window.anamnesisList||[]).filter(a=>
    a.pacienteId===pacId||a.pacienteNombre===nombre
  ).sort((a,b)=>_sk(b)-_sk(a));
  if(countEl)countEl.textContent=todos.length+' registro'+(todos.length!==1?'s':'');
  if(!todos.length){
    cont.innerHTML='<div class="empty"><p>Sin sesiones registradas para este paciente.</p></div>';return;
  }
  const modoColor={Seguimiento:'#1a56db',Anamnesis:'#7b1fa2'};
  const modoIcon={Seguimiento:'📝',Anamnesis:'📋'};
  const noNA=v=>v&&!v.startsWith('N/A')&&!v.startsWith('Genera');
  cont.innerHTML=todos.map((e,i)=>{
    const col=modoColor[e.modo]||'var(--accent2)';
    const ico=modoIcon[e.modo]||'📄';
    const modo=e.modo||'Nota';
    const sesLabel=e.numSesion?'Sesión '+e.numSesion:'';
    const riesgo=e.riesgo;
    const rColor=riesgo==='ALTO'?'var(--danger)':riesgo==='MEDIO'?'var(--warning)':'var(--success)';
    const rBadge=(riesgo&&riesgo!=='No clasificado'&&riesgo!=='SIN RIESGO'&&riesgo!=='')?
      `<span style="background:${rColor}22;color:${rColor};padding:2px 8px;border-radius:20px;font-size:0.68rem;font-weight:600">${riesgo}</span>`:'';
    const campos=[];
    const labelSeg={sub:'I. Estado del paciente / Datos de sesión',obj:'II. Cogniciones identificadas',resp:'II. Técnicas aplicadas',trat:'III. Plan de acción',nota:'IV. Notas clínicas'};
    const labelGen={sub:'Análisis Subjetivo',obj:'Análisis Objetivo',resp:'Respuesta / Impresión clínica',trat:'Tratamiento / Plan',nota:'Notas adicionales'};
    const isSeg=e.modo==='Seguimiento';
    const lMap=isSeg?labelSeg:labelGen;
    if(noNA(e.sub))campos.push({l:lMap.sub,v:e.sub});
    if(noNA(e.obj))campos.push({l:lMap.obj,v:e.obj});
    if(noNA(e.resp))campos.push({l:lMap.resp,v:e.resp});
    if(noNA(e.trat))campos.push({l:lMap.trat,v:e.trat});
    if(noNA(e.nota))campos.push({l:lMap.nota,v:e.nota});
    if(!campos.length&&e.nota)campos.push({l:'Nota clínica',v:e.nota});
    const camposHtml=campos.length
      ?campos.map(c=>`<div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px;margin-bottom:6px">
          <div style="font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--text3);margin-bottom:4px">${c.l}</div>
          <div style="font-size:0.8rem;line-height:1.6;white-space:pre-wrap">${c.v}</div></div>`).join('')
      :'<p style="color:var(--text3);font-size:0.8rem;font-style:italic">Sin texto guardado.</p>';
    return `<div style="background:var(--surface2);border:1px solid var(--border);border-left:4px solid ${col};border-radius:10px;padding:14px 16px;margin-bottom:12px">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;margin-bottom:10px">
        <div>
          <span style="font-weight:700;font-size:0.88rem">${ico} ${modo}</span>
          ${sesLabel?`<span style="margin-left:8px;background:var(--accent-light);color:var(--accent);padding:1px 8px;border-radius:20px;font-size:0.72rem;font-weight:600">${sesLabel}</span>`:''}
          <span style="font-size:0.82rem;color:var(--text2);margin-left:8px">${e.fecha||'Sin fecha'}</span>
        </div>
        <div style="display:flex;gap:6px;align-items:center">${rBadge}</div>
      </div>
      ${camposHtml}
    </div>`;
  }).join('');
};
window.setRisk=(level,el)=>{document.querySelectorAll('.risk-btn').forEach(b=>b.classList.remove('sel'));el.classList.add('sel');document.getElementById('an-riesgo').value=level;};
window.setPRisk=(level,el)=>{document.querySelectorAll('#modal-paciente .risk-btn').forEach(b=>b.classList.remove('sel'));el.classList.add('sel');document.getElementById('p-riesgo').value=level;};
window.getChecked=(id)=>[...document.querySelectorAll(`#${id} input:checked`)].map(i=>i.value).join(', ');
window.getRadio=(name)=>{const el=document.querySelector(`input[name="${name}"]:checked`);return el?el.value:'';};
window.generarNota=()=>{
  const v=id=>document.getElementById(id)?.value||'';
  const nota=`NOTA CLÍNICA · PSICOLOGÍA · CONSULTA EXTERNA EPS
Fecha: ${v('an-fecha')||new Date().toLocaleDateString('es-CO')}
${'━'.repeat(40)}

DATOS DE IDENTIFICACIÓN
Paciente: ${v('an-nombre')}${v('an-cedula')?' · CC: '+v('an-cedula'):''}${v('an-edad')?' · '+v('an-edad')+' años':''}
${v('an-ecivil')?'Estado civil: '+v('an-ecivil'):''}${v('an-esc')?' · Escolaridad: '+v('an-esc'):''}
${v('an-ocupacion')?'Ocupación: '+v('an-ocupacion'):''}
${v('an-remitido')?'Remitido por: '+v('an-remitido'):''}

MOTIVO DE CONSULTA
${v('an-motivo')||'[No registrado]'}

HISTORIA DEL PROBLEMA ACTUAL
Inicio: ${getRadio('an-inicio')||'—'} | Evolución: ${v('an-evolucion')||'—'} | Intensidad: ${v('an-intens')}/10
Desencadenantes: ${getChecked('an-desenc')||'—'}
Síntomas: ${getChecked('an-sint')||'—'}
Impacto: ${getChecked('an-impacto')||'—'}
${v('an-descripcion')?'Descripción: '+v('an-descripcion'):''}

ANTECEDENTES DE SALUD MENTAL
Tto. psicológico: ${getRadio('an-tpsi')||'—'}${v('an-tpsi-cuando')?' ('+v('an-tpsi-cuando')+')':''} | Tto. psiquiátrico: ${getRadio('an-tpsiq')||'—'}${v('an-tpsiq-dx')?' ('+v('an-tpsiq-dx')+')':''}
Dx. previos: ${getChecked('an-dx-previos')||'—'}
Hosp. psiquiátricas: ${getRadio('an-hosp-psiq')||'—'}${v('an-hosp-psiq-det')?' — '+v('an-hosp-psiq-det'):''}
IS previos: ${getRadio('an-is-prev')||'—'} | Intentos de suicidio: ${getRadio('an-is')||'—'}${v('an-is-det')?' ('+v('an-is-det')+')':''}
Autolesiones: ${getChecked('an-autolesion')||'—'}
${v('an-meds')?'Medicación psiquiátrica actual: '+v('an-meds'):''}${v('an-meds-prev')?'\nMedicación previa: '+v('an-meds-prev'):''}${v('an-enf')?'\nEnfermedades médicas: '+v('an-enf'):''}
Red de apoyo: ${getRadio('an-red')||'—'}

HISTORIA DE VIOLENCIA (TAMIZAJE)
${getChecked('an-violencia')||'—'}${v('an-violencia-obs')?'\nObservaciones: '+v('an-violencia-obs'):''}

ANTECEDENTES FAMILIARES
Trastorno mental familiar: ${getRadio('an-fam-tmh')||'—'}${v('an-fam-quien')?' · '+v('an-fam-quien'):''}
Suicidio familiar: ${getRadio('an-fam-suicidio')||'—'}${v('an-fam-suicidio-quien')?' · '+v('an-fam-suicidio-quien'):''}

HISTORIA PERSONAL Y SOCIAL
Vive con: ${v('an-convive')||'—'} | Dinámica: ${getChecked('an-dinamica')||'—'}
Relaciones interpersonales: ${getRadio('an-relaciones')||'—'} | Pareja: ${getRadio('an-pareja')||'—'}
Rendimiento escolar/laboral: ${getRadio('an-rendimiento')||'—'}

HÁBITOS — ALIMENTACIÓN, SUEÑO Y SUSTANCIAS
Alimentación: ${getChecked('an-alimentacion')||'—'}
Sueño: ${getChecked('an-sueno')||'—'}${v('an-horas-sueno')?' · '+v('an-horas-sueno')+' horas':''}${v('an-calidad-sueno')?' · Calidad: '+v('an-calidad-sueno')+'/10':''}
Sustancias: ${getChecked('an-sustancias')||'—'}${getRadio('an-freq-sust')&&getRadio('an-freq-sust')!=='N/A'?' · '+getRadio('an-freq-sust'):''}

EXAMEN MENTAL
Orientación: ${getChecked('an-orient')||'—'}
Afecto: ${getChecked('an-afecto')||'—'}
Pensamiento — Curso: ${getRadio('an-pcurso')||'—'}
Insight: ${getChecked('an-insight')||'—'}
Memoria y atención: ${getRadio('an-mem')||'—'}

RIESGO SUICIDA
Ideación: ${getRadio('an-ideacion')||'—'} | Clasificación: ${v('an-riesgo')||'—'}
${v('an-riesgo-notas')?'Notas: '+v('an-riesgo-notas'):''}

IMPRESIÓN DIAGNÓSTICA
${getChecked('an-dx')||'—'}${v('an-cie')?' ('+v('an-cie')+')':''}
${v('an-dx-obs')||''}

PLAN TERAPÉUTICO
Enfoque: ${getChecked('an-enfoque')||'—'}
Remisiones: ${getChecked('an-remisiones')||'—'}
Próxima cita: ${v('an-proxcita')||'—'}

${'━'.repeat(40)}
${new Date().toLocaleString('es-CO')}`;
  document.getElementById('nota-output').textContent=nota;return nota;
};
window.copiarNota=()=>{const t=document.getElementById('nota-output').textContent;if(t.startsWith('Completa'))return toast('⚠️ Genera la nota primero');navigator.clipboard.writeText(t).then(()=>toast('📋 Nota copiada')).catch(()=>toast('❌ No se pudo copiar'));};
window.toggleSection=(header)=>{header.classList.toggle('open');header.nextElementSibling.classList.toggle('open');};
window.closeSrDrop=()=>{const d=document.getElementById('sr-drop');if(d)d.style.display='none';};

window.globalSearch=(q)=>{
  window._searchQ=q.trim();
  const drop=document.getElementById('sr-drop');
  // Si vacío, ocultar dropdown
  if(!q.trim()){if(drop)drop.style.display='none';return;}
  // Filtrar pacientes
  const ql=q.trim().toLowerCase();
  const matches=(window.pacientes||[]).filter(p=>
    (p.nombre||'').toLowerCase().includes(ql)||
    (p.cedula||'').toLowerCase().includes(ql)||
    (p.hab||'').toLowerCase().includes(ql)
  ).slice(0,6);
  if(drop){
    if(!matches.length){
      drop.style.display='';
      drop.innerHTML=`<div style="padding:14px 16px;font-size:0.82rem;color:var(--text3)">Sin resultados para "<strong>${q}</strong>"</div>`;
    } else {
      const riskDot=r=>r==='ALTO'?'🔴':r==='MEDIO'?'🟡':r==='BAJO'?'🟢':'⚪';
      drop.style.display='';
      drop.innerHTML=matches.map(p=>`
        <div style="padding:10px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;cursor:pointer;transition:background 0.1s" onmouseenter="this.style.background='var(--surface2)'" onmouseleave="this.style.background=''">
          <div style="flex:1;min-width:0" onclick="closeSrDrop();document.getElementById('global-search').value='';abrirPacSheet('${p.id}')">
            <div style="font-weight:600;font-size:0.85rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${riskDot(p.riesgo)} ${p.nombre}</div>
            <div style="font-size:0.72rem;color:var(--text3)">${p.cedula?'CC: '+p.cedula+' · ':''}${p.hab?'Hab. '+p.hab:''}</div>
          </div>
          <div style="display:flex;gap:5px;flex-shrink:0">
            <button class="btn btn-sm btn-secondary" style="padding:3px 8px;font-size:0.72rem" onclick="closeSrDrop();document.getElementById('global-search').value='';verHistorialPorId('${p.id}')">📂</button>
            <button class="btn btn-sm btn-secondary" style="padding:3px 8px;font-size:0.72rem" onclick="closeSrDrop();document.getElementById('global-search').value='';abrirICParaPaciente('${p.id}')">💬</button>
          </div>
        </div>`).join('')+
        `<div style="padding:9px 14px;font-size:0.73rem;color:var(--text3);text-align:center;cursor:pointer;background:var(--surface2)" onclick="closeSrDrop();goTo('pacientes')">Ver todos los pacientes →</div>`;
    }
  }
};

window.buscarPacientesLocal=(q)=>{
  window._searchQ=q.trim();
  const topbar=document.getElementById('global-search');
  if(topbar)topbar.value=q;
  renderPacientes();
};
window.formatDate=(d)=>{if(!d)return'';const[y,m,day]=d.split('-');return`${day}/${m}/${y}`;};
window.toast=(msg)=>{const el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),3200);};

// ── HISTORIAL IC POR PACIENTE ──
window.verHistorialIC=(pacId,pacNombre)=>{
  const ics=interconsultas.filter(ic=>ic.pacienteId===pacId||ic.pacienteNombre===pacNombre);
  // Crear/reusar modal historial
  let modal=document.getElementById('modal-historial-ic');
  if(!modal){
    modal=document.createElement('div');
    modal.id='modal-historial-ic';
    modal.className='modal-overlay';
    modal.innerHTML=`
      <div class="modal" style="max-width:680px;max-height:85vh;overflow-y:auto">
        <div class="modal-header">
          <h3 id="mhic-title">Historial IC</h3>
          <button class="modal-close" onclick="closeModal('modal-historial-ic')">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="modal-body" id="mhic-body"></div>
      </div>`;
    document.body.appendChild(modal);
  }
  document.getElementById('mhic-title').textContent=`📂 Historial IC — ${pacNombre}`;
  const body=document.getElementById('mhic-body');
  if(!ics.length){
    body.innerHTML='<div class="empty"><p>No hay interconsultas registradas para este paciente.</p></div>';
  } else {
    const sorted=[...ics].sort((a,b)=>_sk(b)-_sk(a));
    const riskBadge=(r)=>{if(!r||r==='No clasificado')return'';const c=r==='ALTO'?'badge-red':r==='MEDIO'?'badge-yellow':'badge-green';return`<span class="badge ${c}">⚠ ${r}</span>`;};
    body.innerHTML=sorted.map((ic,i)=>`
      <div style="background:var(--surface2);border:1px solid var(--border);border-left:3px solid var(--primary);border-radius:10px;padding:14px;margin-bottom:10px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;flex-wrap:wrap;gap:6px">
          <div style="font-family:'Syne',sans-serif;font-weight:700;font-size:14px">${ic.modo||'IC'} — ${ic.fecha||'Sin fecha'}</div>
          <div style="display:flex;gap:5px">${riskBadge(ic.riesgo)}<span class="badge ${ic.estado==='pendiente'?'badge-yellow':'badge-green'}">${ic.estado||'pendiente'}</span></div>
        </div>
        <div style="font-size:12px;color:var(--text2);margin-bottom:6px">🏥 ${ic.hab||'—'} · ${ic.dx||'Sin dx'}</div>
        ${ic.nota?`<details style="margin-top:6px"><summary style="font-size:12px;cursor:pointer;color:var(--primary)">Ver nota clínica completa</summary><pre style="white-space:pre-wrap;font-size:11px;color:var(--text2);margin-top:8px;background:var(--surface);padding:10px;border-radius:6px;border:1px solid var(--border)">${ic.nota}</pre></details>`:'<div style="font-size:12px;color:var(--text3)">Sin nota guardada</div>'}
      </div>`).join('');
  }
  openModal('modal-historial-ic');
};

// ── ESCOLARIDAD ──────────────────────────────────────────────

// ── TIPO PACIENTE ────────────────────────────────────────────
window.setPTipo=(tipo)=>{
  document.getElementById('p-tipo').value=tipo;
  const hosp=document.getElementById('p-tipo-hosp');
  const ext=document.getElementById('p-tipo-ext');
  if(hosp)hosp.checked=(tipo==='hospitalizado');
  if(ext)ext.checked=(tipo==='consulta-externa');
  const habGroup=document.getElementById('p-hab-group');
  const motivoLabel=document.getElementById('p-motivo-label');
  const estadoSel=document.getElementById('p-estado');
  const tipoHospBtn=document.getElementById('tipo-hosp-btn');
  const tipoExtBtn=document.getElementById('tipo-ext-btn');
  if(tipo==='consulta-externa'){
    if(habGroup)habGroup.style.display='none';
    if(motivoLabel)motivoLabel.textContent='Motivo de consulta';
    if(estadoSel&&(estadoSel.value===''||estadoSel.value==='nueva-interconsulta-pendiente'))estadoSel.value='consulta-externa';
    if(tipoExtBtn)tipoExtBtn.style.borderColor='var(--accent2)';
    if(tipoHospBtn)tipoHospBtn.style.borderColor='var(--border)';
  } else {
    if(habGroup)habGroup.style.display='';
    if(motivoLabel)motivoLabel.textContent='Diagnóstico médico / Motivo de interconsulta';
    if(estadoSel&&estadoSel.value==='consulta-externa')estadoSel.value='seguimiento';
    if(tipoHospBtn)tipoHospBtn.style.borderColor='var(--accent2)';
    if(tipoExtBtn)tipoExtBtn.style.borderColor='var(--border)';
  }
};

// ── HISTORIAL MODAL ───────────────────────────────────────────
let _hPacId=null,_hPacNombre='';
window._hPacId=null;window._hPacNombre='';
const _hMap={};window._hMap=_hMap;

window.verHistorialIC=(pacId,pacNombre)=>{
  const p=(window.pacientes||[]).find(x=>x.id===pacId)||{nombre:pacNombre||''};
  _hPacId=pacId;window._hPacId=pacId;
  _hPacNombre=p.nombre;window._hPacNombre=p.nombre;
  document.getElementById('mhic-title').textContent='Historial — '+p.nombre;
  document.getElementById('mhic-sub').textContent=(p.cedula?'CC: '+p.cedula+' · ':'')+'Hab. '+(p.hab||'—');
  mhicRender();
  document.getElementById('modal-historial-ic').style.display='flex';
};
window.mhicCerrar=()=>{document.getElementById('modal-historial-ic').style.display='none';};
window.mhicNuevaNota=()=>{
  const pacId=_hPacId||window._hPacId;
  if(!pacId)return;
  // Cerrar modal historial
  document.getElementById('modal-historial-ic').style.display='none';
  // Ir al formulario IC con el paciente ya seleccionado en modo Seguimiento
  goTo('interconsultas');
  setTimeout(()=>{
    const sel=document.getElementById('ic-paciente-sel');
    if(sel){sel.value=pacId;selectICPaciente(pacId);}
    setICMode('seg');
    const form=document.getElementById('ic-form-view');
    if(form)form.scrollIntoView({behavior:'smooth',block:'start'});
    toast('📝 Formulario listo — Modo Seguimiento');
  },200);
};

function _pf(s){if(!s)return 0;s=String(s).trim();var p;if(s.length>=10&&s[4]==="-"){p=s.slice(0,10).split("-");return new Date(+p[0],+p[1]-1,+p[2]).getTime()||0;}if(s.indexOf("/")>-1){p=s.split("/");if(p.length===3){var y=p[2].length<=2?"20"+p[2]:p[2];return new Date(+y,+p[1]-1,+p[0]).getTime()||0;}}return 0;}function _pt(v){if(!v)return 0;if(v.toMillis)return v.toMillis();if(v.seconds)return v.seconds*1000;if(v.toDate)return v.toDate().getTime();return 0;}function _sk(x){return _pf(x.fecha)||_pt(x.creado)||0;}
function mhicRender(){
  const body=document.getElementById('mhic-body');if(!body)return;
  const pacientes=window.pacientes||[];const interconsultas=window.interconsultas||[];const anamnesisList=window.anamnesisList||[];
  const p=pacientes.find(x=>x.id===_hPacId);const nombre=p?p.nombre:_hPacNombre;
  const ics=interconsultas.filter(ic=>ic.pacienteId===_hPacId||ic.pacienteNombre===nombre);
  const anas=anamnesisList.filter(a=>a.pacienteId===_hPacId||a.pacienteNombre===nombre);
  const all=[...ics.map(x=>Object.assign({},x,{_col:'interconsultas'})),...anas.map(x=>Object.assign({},x,{_col:'anamnesis',modo:x.modo||'Anamnesis'}))].sort((a,b)=>_sk(b)-_sk(a));
  for(const k in _hMap)delete _hMap[k];
  if(!all.length){body.innerHTML='<div class="empty" style="padding:30px"><p>Sin notas. Usa "Nuevo seguimiento" para agregar.</p></div>';return;}
  const tc={'IC Nueva':'var(--accent2)','Seguimiento':'#1a56db','Anamnesis':'#7b1fa2','Nota especial':'var(--warning)'};
  const partes=[];
  for(let ni=0;ni<all.length;ni++){
    const e=all[ni];
    _hMap[ni]={id:e.id,col:e._col};
    const col=tc[e.modo]||'var(--accent)';
    const riesgo=e.riesgo||'';
    const rColor=riesgo==='ALTO'?'var(--danger)':riesgo==='MEDIO'?'var(--warning)':'var(--success)';
    const rBadgeHtml=(riesgo&&riesgo!=='No clasificado'&&riesgo!=='SIN RIESGO')?'<span style="background:'+rColor+'22;color:'+rColor+';padding:2px 7px;border-radius:20px;font-size:0.68rem;font-weight:600">'+riesgo+'</span>':'';
    const respondidaBtn=(e.estado||'respondida')==='pendiente'?'<button class="btn btn-sm btn-secondary" style="padding:3px 9px;font-size:0.72rem" onclick="hpacResponder('+ni+')">Respondida</button>':'';
    const editarBtn='<button class="btn btn-sm btn-secondary" style="padding:3px 9px;font-size:0.72rem" onclick="mhicEditar('+ni+')">Editar</button>';
    const subInfo=(e.hab||e.dx)?'<div style="font-size:0.72rem;color:var(--text3);margin-top:2px">'+(e.hab?'Hab. '+e.hab+' - ':'')+( e.dx||'')+'</div>':'';
    let camposHtml='<div style="font-size:0.78rem;color:var(--text3);font-style:italic;margin-top:8px">Sin texto guardado</div>';
    const cv=[];
    const _noNA=v=>v&&v.trim()&&!v.startsWith('N/A')&&!v.startsWith('Genera');
    if(_noNA(e.sub))cv.push({l:'Subjetivo',v:e.sub});
    if(_noNA(e.obj))cv.push({l:'Objetivo',v:e.obj});
    if(_noNA(e.resp))cv.push({l:'Respuesta',v:e.resp});
    if(_noNA(e.trat))cv.push({l:'Tratamiento',v:e.trat});
    if(_noNA(e.nota))cv.push({l:cv.length?'Notas adicionales':'Nota clínica',v:e.nota});
    if(!cv.length){const any=e.nota||e.trat||e.obj||e.sub||e.resp||'';if(any)cv.push({l:'Nota clínica',v:any});}
    if(cv.length){
      let cHtml='';
      for(let j=0;j<cv.length;j++){
        cHtml+='<div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:6px">'
          +'<div style="font-size:0.63rem;font-weight:700;text-transform:uppercase;color:var(--text3);margin-bottom:5px">'+cv[j].l+'</div>'
          +'<div style="font-size:0.78rem;line-height:1.55;white-space:pre-wrap">'+cv[j].v+'</div></div>';
      }
      camposHtml='<div style="margin-top:10px">'+cHtml+'</div>';
    }
    partes.push('<div style="background:var(--surface2);border:1px solid var(--border);border-left:4px solid '+col+';border-radius:10px;padding:14px 16px;margin-bottom:12px">'
      +'<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;flex-wrap:wrap">'
      +'<div><div style="font-weight:700;font-size:0.88rem">'+(e.modo||'Nota')+' - '+'<span style="color:'+col+'">'+(e.fecha||'Sin fecha')+'</span></div>'+subInfo+'</div>'
      +'<div style="display:flex;gap:5px;align-items:center;flex-wrap:wrap">'+rBadgeHtml+respondidaBtn+editarBtn+'</div>'
      +'</div>'+camposHtml+'</div>');
  }
  body.innerHTML=partes.join('');
}
window.mhicEditar=(ni)=>{
  const m=_hMap[ni];if(!m)return;
  const interconsultas=window.interconsultas||[];const anamnesisList=window.anamnesisList||[];
  const e=m.col==='interconsultas'?interconsultas.find(x=>x.id===m.id):anamnesisList.find(x=>x.id===m.id);
  if(!e)return;
  document.getElementById('mne-title').textContent='Editar nota';
  document.getElementById('mne-fecha').value=e.fecha||'';
  document.getElementById('mne-tipo').value=e.modo||'IC Nueva';
  document.getElementById('mne-riesgo').value=e.riesgo||'';
  document.getElementById('mne-estado').value=e.estado||'respondida';
  document.getElementById('mne-sub').value=e.sub||'';
  document.getElementById('mne-obj').value=e.obj||'';
  document.getElementById('mne-resp').value=e.resp||'';
  document.getElementById('mne-trat').value=e.trat||'';
  document.getElementById('mne-nota').value=e.nota||'';
  document.getElementById('mne-del-btn').style.display='';
  window._mneId=m.id;window._mneCol=m.col;
  window._mneOnSave=()=>setTimeout(mhicRender,500);
  document.getElementById('modal-nota-edit').style.display='flex';
};

// ── HISTORIAL PACIENTES (página) ──────────────────────────────
let _hpacPacId=null;window._hpacPacId=null;

window.hpacRenderLista=()=>{
  const cont=document.getElementById('hpac-lista');if(!cont)return;
  const pacientes=window.pacientes||[];const interconsultas=window.interconsultas||[];
  const anamnesisList=window.anamnesisList||[];const testHistory=window.testHistory||[];
  const cnt={};const lastMod={};
  const toMs=v=>{if(!v)return 0;if(v&&v.toMillis)return v.toMillis();if(v&&v.seconds)return v.seconds*1000;return new Date(v).getTime()||0;};
  interconsultas.forEach(ic=>{const id=ic.pacienteId||'_'+ic.pacienteNombre;cnt[id]=(cnt[id]||0)+1;const t=toMs(ic.creado||ic.fecha);if(t>(lastMod[id]||0))lastMod[id]=t;});
  anamnesisList.forEach(a=>{const id=a.pacienteId||'_'+a.pacienteNombre;cnt[id]=(cnt[id]||0)+1;const t=toMs(a.creado||a.fecha);if(t>(lastMod[id]||0))lastMod[id]=t;});
  testHistory.forEach(t=>{const id=t.pacienteId||'_'+t.paciente;cnt[id]=(cnt[id]||0)+1;const ts=toMs(t.creado||t.fecha);if(ts>(lastMod[id]||0))lastMod[id]=ts;});
  pacientes.forEach(p=>{const t=toMs(p.creado);if(t>(lastMod[p.id]||0))lastMod[p.id]=t;});
  const todos=[...pacientes].sort((a,b)=>(lastMod[b.id]||0)-(lastMod[a.id]||0));
  if(!todos.length){cont.innerHTML='<div class="empty"><p>No hay pacientes registrados.</p></div>';return;}
  const rBadge=r=>{if(!r||r==='SIN RIESGO')return'<span class="badge badge-green">Sin riesgo</span>';if(r==='BAJO')return'<span class="badge badge-green">Riesgo bajo</span>';if(r==='MEDIO')return'<span class="badge badge-yellow">Riesgo medio</span>';if(r==='ALTO')return'<span class="badge badge-red">Riesgo alto</span>';return'';};
  cont.innerHTML=todos.map(p=>{
    const n=cnt[p.id]||cnt['_'+p.nombre]||0;
    const lm=lastMod[p.id]||0;
    const lmLabel=lm?new Date(lm).toLocaleDateString('es-CO',{day:'2-digit',month:'short',year:'numeric'}):'—';
    return`<div class="hpac-card" onclick="hpacAbrirPaciente('${p.id}')">
      <div style="width:40px;height:40px;border-radius:10px;background:var(--accent-light);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0">${p.sexo==='Femenino'?'👩':'👨'}</div>
      <div style="flex:1;min-width:0">
        <div style="font-weight:700;font-size:0.92rem">${p.nombre}</div>
        <div style="font-size:0.73rem;color:var(--text3);margin-top:2px">${p.cedula?'CC: '+p.cedula+' · ':''}${p.tipo==='consulta-externa'?'🚶 C.Ext · ':''}${p.hab?'Hab. '+p.hab+' · ':''}${p.motivo?p.motivo.slice(0,55):''}</div>
        <div style="margin-top:5px;display:flex;gap:6px;align-items:center">${rBadge(p.riesgo)}<span style="font-size:0.68rem;color:var(--text3)">🕐 Últ. actividad: ${lmLabel}</span></div>
      </div>
      <div style="font-size:0.72rem;font-weight:600;background:var(--accent-light);color:var(--accent);padding:3px 10px;border-radius:20px;flex-shrink:0">${n} ${n===1?'registro':'registros'}</div>
    </div>`;
  }).join('');
};

window.hpacFiltrar=(q)=>{
  document.querySelectorAll('#hpac-lista .hpac-card').forEach(c=>{
    c.style.display=(!q||c.textContent.toLowerCase().includes(q.toLowerCase()))?'':'none';
  });
};

window.hpacAbrirPaciente=(pacId)=>{
  _hpacPacId=pacId;window._hpacPacId=pacId;
  window._hPacId=pacId;
  const p=(window.pacientes||[]).find(x=>x.id===pacId)||{};
  window._hPacNombre=p.nombre||'';
  document.getElementById('hpac-pac-nombre').textContent=p.nombre||'Paciente';
  document.getElementById('hpac-pac-info').textContent=(p.cedula?'CC: '+p.cedula+' · ':'')+((p.tipo==='consulta-externa'?'🚶 Consulta externa · ':'')+(p.hab?'Hab. '+p.hab+' · ':'')+((p.motivo||'').slice(0,70)));
  document.getElementById('hpac-lista-view').style.display='none';
  document.getElementById('hpac-notas-view').style.display='block';
  hpacRenderNotas();
};

window.hpacVolverLista=()=>{
  _hpacPacId=null;window._hpacPacId=null;
  document.getElementById('hpac-notas-view').style.display='none';
  document.getElementById('hpac-lista-view').style.display='block';
};

window.hpacRenderNotas=()=>{
  const cont=document.getElementById('hpac-notas-list');if(!cont||!_hpacPacId)return;
  const pacientes=window.pacientes||[];const interconsultas=window.interconsultas||[];
  const anamnesisList=window.anamnesisList||[];const testHistory=window.testHistory||[];
  const p=pacientes.find(x=>x.id===_hpacPacId)||{};const nombre=p.nombre||'';
  const ics=interconsultas.filter(ic=>ic.pacienteId===_hpacPacId||ic.pacienteNombre===nombre);
  const anas=anamnesisList.filter(a=>a.pacienteId===_hpacPacId||a.pacienteNombre===nombre);
  const tests=testHistory.filter(t=>t.pacienteId===_hpacPacId||t.paciente===nombre);
  // Summary bar
  const rb=document.getElementById('hpac-resumen-bar');
  if(rb){
    const badge=(icon,label,count,color)=>count?`<span style="display:inline-flex;align-items:center;gap:5px;background:${color}22;color:${color};border-radius:20px;padding:4px 12px;font-size:0.75rem;font-weight:700">${icon} ${count} ${label}</span>`:'';
    rb.innerHTML=
      badge('💬','IC',ics.length,'var(--accent2)')+
      badge('📋','Anamnesis',anas.length,'#7b1fa2')+
      badge('🧪','Tests',tests.length,'var(--warning)')+
      `<span style="display:inline-flex;align-items:center;gap:5px;background:var(--surface2);color:var(--text2);border-radius:20px;padding:4px 12px;font-size:0.75rem;font-weight:700">📅 ${ics.length+anas.length+tests.length} registros totales</span>`;
  }
  const notas=[].concat(
    ics.map(x=>Object.assign({},x,{_col:'interconsultas'})),
    anas.map(x=>Object.assign({},x,{_col:'anamnesis',modo:x.modo||'Anamnesis'}))
  ).sort((a,b)=>_sk(b)-_sk(a));
  const testsSorted=[].concat(tests).sort((a,b)=>_sk(b)-_sk(a));
  for(var k in _hMap)delete _hMap[k];
  if(!notas.length&&!testsSorted.length){
    cont.innerHTML='<div class="empty" style="padding:36px"><p>Sin registros para este paciente.</p></div>';return;
  }
  var tc={'IC Nueva':'tipo-ic','Seguimiento':'tipo-seg','Anamnesis':'tipo-anam','Nota especial':'tipo-esp'};
  var tcol={'IC Nueva':'var(--accent2)','Seguimiento':'#1a56db','Anamnesis':'#7b1fa2','Nota especial':'var(--warning)'};

  // Build notas HTML with for loop (no nested template literals)
  var notasParts=[];
  if(notas.length){
    notasParts.push('<div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text2);margin-bottom:10px">Notas clinicas ('+notas.length+')</div>');
    for(var ni=0;ni<notas.length;ni++){
      var e=notas[ni];
      _hMap[ni]={id:e.id,col:e._col};
      var modo=e.modo||'Nota';
      var cls=tc[modo]||'tipo-ic';
      var col=tcol[modo]||'var(--accent)';
      var riesgo=e.riesgo||'';
      var rColor=riesgo==='ALTO'?'var(--danger)':riesgo==='MEDIO'?'var(--warning)':'var(--success)';
      var rBadgeHtml=(riesgo&&riesgo!=='No clasificado'&&riesgo!=='SIN RIESGO')
        ?'<span style="background:'+rColor+'22;color:'+rColor+';padding:2px 8px;border-radius:20px;font-size:0.68rem;font-weight:600">'+riesgo+'</span>':'';
      var respondidaBtn=(e.estado||'respondida')==='pendiente'
        ?'<button class="btn btn-sm btn-secondary" style="padding:3px 9px;font-size:0.72rem" onclick="hpacResponder('+ni+')">Respondida</button>':'';
      var cv=[];
      // Mostrar todos los campos que tengan contenido real (sin importar el modo)
      // Esto garantiza que siempre se vea todo lo guardado
      var hasNAVal=function(v){return !v||v.trim()===''||v.startsWith('N/A')||v.startsWith('Genera');};
      if(modo==='Seguimiento'){
        // Seguimiento: texto principal en obj, fallback a nota o sub
        var segTexto=e.obj||e.nota||e.sub||'';
        if(!hasNAVal(segTexto))cv.push({label:'Nota de seguimiento',text:segTexto});
        // También mostrar campos adicionales si existen
        if(!hasNAVal(e.sub)&&e.sub!==segTexto)cv.push({label:'Análisis Subjetivo',text:e.sub});
        if(!hasNAVal(e.resp))cv.push({label:'Respuesta / Impresión clínica',text:e.resp});
        if(!hasNAVal(e.trat))cv.push({label:'Tratamiento / Plan',text:e.trat});
      } else {
        // IC Nueva, Nota especial, Anamnesis y cualquier otro modo:
        // mostrar todos los campos con contenido real
        if(!hasNAVal(e.sub))cv.push({label:'Análisis Subjetivo',text:e.sub});
        if(!hasNAVal(e.obj))cv.push({label:'Análisis Objetivo',text:e.obj});
        if(!hasNAVal(e.resp))cv.push({label:'Respuesta / Impresión clínica',text:e.resp});
        if(!hasNAVal(e.trat))cv.push({label:'Tratamiento / Plan',text:e.trat});
        // nota: mostrar siempre si tiene contenido (puede ser la nota completa o complementaria)
        if(!hasNAVal(e.nota))cv.push({label:cv.length?'Notas adicionales':'Nota clínica',text:e.nota});
        // Si absolutamente nada se encontró, intentar cualquier campo
        if(!cv.length){
          var any=e.nota||e.trat||e.obj||e.sub||e.resp||'';
          if(any)cv.push({label:'Nota clínica',text:any});
        }
      }
      var camposHtml='';
      if(cv.length){
        for(var j=0;j<cv.length;j++){
          camposHtml+='<div class="hpac-campo">'
            +'<div class="hpac-campo-label">'+cv[j].label+'</div>'
            +'<div class="hpac-campo-text">'+cv[j].text+'</div>'
            +'</div>';
        }
      } else {
        camposHtml='<p style="color:var(--text3);font-size:0.82rem;font-style:italic">Sin texto guardado.</p>';
      }
      notasParts.push(
        '<div class="hpac-nota">'
        +'<div class="hpac-nota-head '+cls+'">'
        +'<div>'
        +'<span style="font-weight:700;font-size:0.88rem;color:'+col+'">'+modo+'</span>'
        +'<span style="font-size:0.82rem;color:var(--text2);margin-left:8px">'+(e.fecha||'Sin fecha')+'</span>'
        +'</div>'
        +'<div style="display:flex;gap:5px;align-items:center;flex-wrap:wrap">'
        +rBadgeHtml+respondidaBtn
        +'<button class="btn btn-sm btn-secondary" style="padding:3px 9px;font-size:0.72rem" onclick="hpacEditar('+ni+')">Editar</button>'
        +'<button class="btn btn-sm btn-secondary" style="padding:3px 9px;font-size:0.72rem" onclick="hpacCopiar('+ni+')">Copiar</button>'
        +'</div></div>'
        +'<div class="hpac-nota-body">'+camposHtml+'</div>'
        +'</div>'
      );
    }
  }

  // Build tests HTML
  var testParts=[];
  if(testsSorted.length){
    testParts.push('<div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text2);margin-bottom:10px;margin-top:'+(notas.length?'24':'4')+'px">🧪 Tests aplicados ('+testsSorted.length+')</div>');
    var lc={normal:'var(--success)',moderate:'var(--warning)',high:'var(--danger)',critical:'#7b1fa2'};
    var ll={normal:'Normal / Sin clínica',moderate:'Leve / Moderado',high:'Alto / Clínicamente significativo',critical:'Crítico / Severo'};
    var testIconos={PHQ9:'💙',GAD7:'⚡',HADS:'🏥',MMSE:'🧠',MoCA:'🧩',CAM:'🌀','C-SSRS':'🔴','MMAS-4':'💊',Duelo:'🕊️','PCL-5':'🌪️'};
    for(var ti=0;ti<testsSorted.length;ti++){
      var t=testsSorted[ti];
      var tc2=lc[t.level]||'var(--text2)';
      var tl=ll[t.level]||t.level||'—';
      var ticon=testIconos[t.test]||'📊';
      var scoreHtml=t.score!=null
        ?'<div style="font-size:2rem;font-weight:800;color:'+tc2+';line-height:1">'+t.score+'<span style="font-size:0.72rem;font-weight:400;color:var(--text3);margin-left:2px">pts</span></div>'
        :'';
      testParts.push(
        '<div style="background:var(--surface);border:1.5px solid var(--border);border-left:5px solid '+tc2+';border-radius:var(--radius);padding:14px 16px;margin-bottom:10px">'
        +'<div style="display:flex;align-items:flex-start;gap:12px">'
        +'<div style="font-size:1.8rem;flex-shrink:0;line-height:1;margin-top:2px">'+ticon+'</div>'
        +'<div style="flex:1">'
        +'<div style="font-weight:700;font-size:0.95rem;color:var(--text)">'+t.test+'</div>'
        +'<div style="font-size:0.73rem;color:var(--text3);margin-top:2px">📅 '+( t.fecha||'Sin fecha')+'</div>'
        +'<div style="margin-top:6px"><span style="background:'+tc2+'22;color:'+tc2+';padding:3px 10px;border-radius:20px;font-size:0.72rem;font-weight:700">'+tl+'</span></div>'
        +(t.extra?'<div style="font-size:0.78rem;color:var(--text2);margin-top:6px;line-height:1.5;border-top:1px solid var(--border);padding-top:6px">'+t.extra+'</div>':'')
        +'</div>'
        +'<div style="text-align:right;flex-shrink:0">'+scoreHtml+'</div>'
        +'</div></div>'
      );
    }
  }

  cont.innerHTML=notasParts.join('')+testParts.join('');
};

window.hpacNuevaNota=()=>{
  if(!_hpacPacId)return;
  // Cerrar modal historial si está abierto
  const mh=document.getElementById('modal-historial-ic');
  if(mh)mh.style.display='none';
  // Ir al formulario IC con el paciente ya seleccionado en modo Seguimiento
  goTo('interconsultas');
  setTimeout(()=>{
    const sel=document.getElementById('ic-paciente-sel');
    if(sel){sel.value=_hpacPacId;selectICPaciente(_hpacPacId);}
    setICMode('seg');
    // Scroll al top del formulario
    const form=document.getElementById('ic-form-view');
    if(form)form.scrollIntoView({behavior:'smooth',block:'start'});
    toast('📝 Formulario listo — Modo Seguimiento');
  },200);
};

window.hpacEditar=(ni)=>{
  const m=_hMap[ni];if(!m)return;
  const interconsultas=window.interconsultas||[];const anamnesisList=window.anamnesisList||[];
  const e=m.col==='interconsultas'?interconsultas.find(x=>x.id===m.id):anamnesisList.find(x=>x.id===m.id);
  if(!e)return;
  window._hPacId=_hpacPacId;
  const p=(window.pacientes||[]).find(x=>x.id===_hpacPacId);
  window._hPacNombre=p?p.nombre:(e.pacienteNombre||'');
  document.getElementById('mne-title').textContent='Editar nota';
  document.getElementById('mne-fecha').value=e.fecha||'';
  document.getElementById('mne-tipo').value=e.modo||'IC Nueva';
  document.getElementById('mne-riesgo').value=e.riesgo||'';
  document.getElementById('mne-estado').value=e.estado||'respondida';
  document.getElementById('mne-sub').value=e.sub||'';
  document.getElementById('mne-obj').value=e.obj||'';
  document.getElementById('mne-resp').value=e.resp||'';
  document.getElementById('mne-trat').value=e.trat||'';
  document.getElementById('mne-nota').value=e.nota||'';
  document.getElementById('mne-del-btn').style.display='';
  window._mneId=m.id;window._mneCol=m.col;
  window._mneOnSave=()=>setTimeout(hpacRenderNotas,500);
  document.getElementById('modal-nota-edit').style.display='flex';
};

window.hpacCopiar=(ni)=>{
  const m=_hMap[ni];if(!m)return;
  const interconsultas=window.interconsultas||[];const anamnesisList=window.anamnesisList||[];
  const e=m.col==='interconsultas'?interconsultas.find(x=>x.id===m.id):anamnesisList.find(x=>x.id===m.id);
  if(!e)return;
  const parts=[];
  if(e.sub)parts.push('ANÁLISIS SUBJETIVO\n'+e.sub);
  if(e.obj)parts.push('ANÁLISIS OBJETIVO\n'+e.obj);
  if(e.resp)parts.push('RESPUESTA\n'+e.resp);
  if(e.trat)parts.push('TRATAMIENTO\n'+e.trat);
  if(e.nota)parts.push('NOTAS\n'+e.nota);
  const txt=parts.length?parts.join('\n\n---\n\n'):(e.nota||'Sin nota');
  navigator.clipboard.writeText(txt).then(()=>toast('📋 Nota copiada')).catch(()=>toast('Error al copiar'));
};

// ── HISTORIAL IC en dashboard/pacientes ──────────────────────
window.verHistorialPorId=(pacId)=>verHistorialIC(pacId,'');

// ── PATIENT INFO SHEET ──────────────────────────────────────
window.abrirPacSheet=async(id)=>{
  const p=pacientes.find(x=>x.id===id);
  if(!p)return;
  // Contar sesiones desde datos ya en memoria (instantáneo, sin fallo de red)
  const sesiones=(window.interconsultas||[]).filter(ic=>ic.pacienteId===id||ic.pacienteNombre===p.nombre).length
    + (window.anamnesisList||[]).filter(a=>a.pacienteId===id||a.pacienteNombre===p.nombre).length;

  const riskColor={'ALTO':'#F87171','MEDIO':'#FBBF24','BAJO':'#34D399','SIN RIESGO':'#34D399'};
  const estadoLabel={'seguimiento':'Seguimiento','nueva-interconsulta-pendiente':'IC pendiente','consulta-externa':'Consulta Externa','alta':'Alta','revaloracion':'Revaluación'};

  document.getElementById('ps-nombre').textContent=p.nombre||'Sin nombre';
  document.getElementById('ps-sub').textContent=(p.cedula?'CC: '+p.cedula:'')+(p.cedula&&(p.edad||p.sexo)?' · ':'')+( p.edad?p.edad+' años':'')+( p.sexo?' · '+p.sexo:'');
  const badgeEl=document.getElementById('ps-sesiones-badge');
  badgeEl.textContent='📅 '+sesiones+' sesión'+(sesiones!==1?'es':'')+' registrada'+(sesiones!==1?'s':'');
  badgeEl.onclick=null;
  badgeEl.style.cursor='default';
  badgeEl.title='';

  const capRecord=(window.capacidadList||[]).find(c=>c.pacienteId===id||c.pacienteNombre===p.nombre);
  const capColorMap={"CONSERVADA":"var(--success)","DISMINUIDA":"var(--warning)","SIN CAPACIDAD":"var(--danger)"};
  const capIconMap={"CONSERVADA":"✅","DISMINUIDA":"⚠️","SIN CAPACIDAD":"🚫"};
  const capVal=capRecord&&capRecord.conclusion;
  const capText=capVal?((capIconMap[capVal]||"")+" "+capVal+(capRecord.fecha?" · "+capRecord.fecha:"")):null;
  const ri=item=>`<div class="pac-info-item${item.full?' pac-info-full':''}"><div class="pac-info-label">${item.l}</div><div class="pac-info-value" style="${item.color?'color:'+item.color:''}">${item.v||'—'}</div></div>`;
  const grid=[
    {l:'Habitación',v:p.hab||(p.tipo==='consulta-externa'?'Consulta Externa':'—')},
    {l:'Fecha ingreso',v:p.fecha?formatDate(p.fecha):'—'},
    {l:'Edad',v:p.edad?p.edad+' años':'—'},
    {l:'Sexo',v:p.sexo||'—'},
    {l:'Riesgo suicida',v:p.riesgo||'Sin clasificar',color:riskColor[p.riesgo]||'var(--text2)'},
    {l:'Estado',v:estadoLabel[p.estado]||p.estado||'—'},
    capText?{l:'Capacidad decisional',v:capText,color:capColorMap[capVal]}:null,
    {l:'Próxima sesión',v:p.proxSesion?formatDate(p.proxSesion):'No programada'},
    {l:'Dx médico / Motivo IC',v:p.motivo,full:true},
    {l:'Impresión psicológica',v:p.dxpsi,full:true},
    {l:'Observaciones de riesgo',v:p.riesgoObs,full:true},
    {l:'Notas generales',v:p.notas,full:true},
  ].filter(x=>x&&x.v);
  document.getElementById('ps-grid').innerHTML=grid.map(ri).join('');
  document.getElementById('ps-actions').innerHTML=`
    <button class="btn btn-primary btn-sm" onclick="abrirICParaPaciente('${id}');closePacSheet()">💬 IC</button>
    <button class="btn btn-secondary btn-sm" onclick="irTestsPaciente('${id}');closePacSheet()">🧪 Test</button>
    <button class="btn btn-secondary btn-sm" onclick="abrirCapacidadPaciente('${id}');closePacSheet()">⚖️ Capacidad</button>
    <button class="btn btn-secondary btn-sm" onclick="editarPaciente('${id}');closePacSheet()">✏️ Editar</button>
    <button class="btn btn-secondary btn-sm" onclick="verHistorialPorId('${id}');closePacSheet()">📂 Historial</button>
  `;
  document.getElementById('pac-sheet-overlay').classList.add('open');
  document.body.style.overflow='hidden';
};

window.closePacSheet=(e)=>{
  if(e&&e.target!==document.getElementById('pac-sheet-overlay'))return;
  document.getElementById('pac-sheet-overlay').classList.remove('open');
  document.body.style.overflow='';
};

// ── IC ENRIQUECIDA ────────────────────────────────────────────
let icCurrentMode='nueva';
let icCurrentEsp=null;

window.setICMode=function(m){
  icCurrentMode=m;
  ['nueva','seg','esp'].forEach(function(x){
    var el=document.getElementById('ic-btn-'+x);
    if(el)el.classList.toggle('active',x===m);
  });
  var mnueva=document.getElementById('ic-mode-nueva');
  var mesp=document.getElementById('ic-mode-esp');
  if(mnueva)mnueva.style.display=(m==='nueva'||m==='seg')?'':'none';
  if(mesp)mesp.style.display=m==='esp'?'':'none';
  document.querySelectorAll('.ic-only-nueva').forEach(function(el){el.style.display=m==='seg'?'none':'';});
  var f4=document.getElementById('ic-out-4campos');
  var seg=document.getElementById('ic-out-seg');
  if(f4)f4.style.display=m==='seg'?'none':'';
  if(seg)seg.style.display=m==='seg'?'':'none';
};

window.toggleICView=function(){goTo('historial-ic');};

window.icTog=function(el){el.classList.toggle('on');};
window.icTogR=function(el){el.classList.toggle('on-r');};
window.icTogG=function(el){el.classList.toggle('on-g');};
window.icTogA=function(el){el.classList.toggle('on-a');};

window.setICSev=function(el,nivel,isHigh){
  document.querySelectorAll('.sev-btn').forEach(function(s){s.classList.remove('on');});
  el.classList.add('on');
  document.getElementById('ic-riesgo-nivel').value=nivel;
  var alert=document.getElementById('ic-risk-alert');
  if(alert)alert.classList.toggle('show',!!isHigh);
};

var icEspNotes={
  intubado:'Paciente bajo sedación y ventilación mecánica, sin respuesta a estímulos verbales, por lo que no es posible establecer contacto ni realizar exploración del estado mental en este momento; se mantiene en observación y se difiere la valoración psicológica hasta que las condiciones médicas lo permitan.',
  dolor:'Paciente refiere dolor agudo que limita su disposición para la entrevista, imposibilitando la exploración de su esfera emocional y cognitiva en el día de hoy; se suspende el intento de valoración y se acuerda reagendar la intervención una vez que el síntoma físico se encuentre controlado.',
  nodisponible:'Al acudir a la unidad para valoración, el paciente no se encuentra en su habitación, por lo que no es posible realizar la entrevista ni la observación conductual programada; se solicita al personal de enfermería informar cuando el paciente esté localizable para retomar la intervención.',
  fuga:'Se constata la ausencia del paciente del servicio al momento de la valoración programada, imposibilitando la intervención psicológica y el acompañamiento emocional; queda pendiente la valoración para cuando el paciente se encuentre nuevamente disponible en la unidad.',
  repetida:'Se recibe nueva interconsulta para valoración psicológica, sin embargo, al acudir no se observan cambios en la conducta del paciente ni nuevos elementos que requieran intervención distinta a lo ya indicado en atenciones previas; se mantienen las recomendaciones generales de apoyo emocional por parte del personal tratante.',
  seguimiento:'Paciente ya se encuentra en protocolo de seguimiento psicológico dentro del contexto hospitalario; en la presente interconsulta no se evidencian criterios de cambios afectivos o conductuales que requieran una valoración adicional, por lo que la evaluación correspondiente se realizará en la fecha programada y registrada en la historia clínica, continuando con las intervenciones previamente establecidas.',
  niega:'Paciente manifiesta su negativa a recibir atención psicológica en el momento actual, ejerciendo su derecho a rechazar la intervención; se respeta su decisión y se deja constancia, quedando a disposición para futuras ocasiones si el paciente lo solicita.',
  nocolaborativo:'Durante el intento de entrevista, el paciente no muestra disposición para el diálogo ni para participar en la exploración de su estado emocional, dificultando la intervención; se suspende el intento y se mantiene una actitud de apertura para cuando el paciente se encuentre más receptivo.',
  sincapacidad:'Al momento de la valoración, el paciente presenta compromiso cognitivo significativo que impide llevar a cabo una intervención psicológica estructurada: se observan alteraciones en orientación, atención, coherencia del discurso y/o contacto con la realidad, compatibles con cuadro de delirium / déficit cognitivo severo / deterioro neurocognitivo mayor. Dado que el paciente no cuenta con las condiciones cognitivas mínimas para participar en el proceso de evaluación ni para procesar intervenciones terapéuticas, se difiere la valoración psicológica. Se notifica al equipo tratante sobre el estado observado y se recomienda valoración por neurología o psiquiatría si aún no se ha realizado. Se mantiene disponibilidad para reevaluar una vez que el cuadro se estabilice o remita.',
  somnoliento:'El paciente se encuentra en estado de somnolencia marcada al momento de la valoración, con respuesta mínima a estímulos verbales y escasa capacidad de mantener la atención sostenida durante el intento de entrevista. Dicho estado dificulta la evaluación del funcionamiento emocional, cognitivo y conductual, por lo que no es posible realizar una intervención psicológica efectiva en el momento actual. Se suspende la sesión y se programa reevaluación cuando el nivel de conciencia y alerta del paciente lo permita. Se sugiere al equipo médico revisar posibles causas del estado hipoactivo (medicación, factores metabólicos, progresión de la enfermedad).'
};

window.setIcEsp=function(type,el){
  icCurrentEsp=type;
  document.querySelectorAll('#ic-mode-esp .ic-chip').forEach(function(c){c.classList.remove('on');});
  el.classList.add('on');
  var preview=document.getElementById('ic-esp-preview');
  var text=document.getElementById('ic-esp-text');
  if(preview)preview.style.display='';
  if(text)text.textContent=icEspNotes[type]||'';
};

function icChipsFrom(container){
  if(!container)return[];
  return Array.from(container.querySelectorAll('.ic-chip.on,.ic-chip.on-r,.ic-chip.on-g,.ic-chip.on-a'))
    .map(function(c){return c.textContent.trim();}).filter(Boolean);
}
function icChipsBySubLabel(labelText){
  var sublabels=document.querySelectorAll('.ic-sublabel');
  for(var i=0;i<sublabels.length;i++){
    if(sublabels[i].textContent.includes(labelText)){
      return icChipsFrom(sublabels[i].parentElement);
    }
  }
  return[];
}
function icv(id){var el=document.getElementById(id);return el?el.value.trim():'';}
function icList(arr){
  if(!arr||!arr.length)return null;
  if(arr.length===1)return arr[0];
  return arr.slice(0,-1).join(', ')+' y '+arr[arr.length-1];
}

window.generarNotaIC=function(){
  var wrap=document.getElementById('ic-output-wrap');
  if(wrap)wrap.style.display='';
  if(icCurrentMode==='esp'){generarNotaIcEsp();return;}
  if(icCurrentMode==='seg'){generarNotaIcSeg();return;}
  generarNotaIcNueva();
};

function generarNotaIcNueva(){
  var nombre=icv('ic-pnombre')||'el/la paciente';
  var pn=nombre.split(' ')[0];
  var edad=icv('ic-edad');
  var dx=icv('ic-pdx')||'[diagnóstico médico]';
  var hab=icv('ic-hab')||'[habitación]';
  var sev=icv('ic-riesgo-nivel')||'No clasificado';

  var estadoEmoc=icList(icChipsBySubLabel('Estado emocional referido'))||'variable';
  var preocup=icChipsBySubLabel('Principales preocupaciones');
  var pensamientos=icChipsBySubLabel('Pensamientos automáticos');
  var cita=icv('ic-sub-cita');
  var intensidad=icv('ic-sub-intensidad');

  var subjetivo=nombre+(edad?', '+edad:'')+', hospitalizado/a en hab. '+hab+' por '+dx+', es valorado/a por psicología a solicitud del equipo tratante.\n\nDurante la entrevista, '+pn+' refiere encontrarse emocionalmente '+estadoEmoc+'.';
  if(intensidad)subjetivo+=' '+intensidad+'.';
  if(preocup.length)subjetivo+='\n\nLas principales preocupaciones referidas incluyen: '+icList(preocup)+'.';
  if(pensamientos.length)subjetivo+='\n\nDesde una perspectiva cognitivo-conductual, se identifican los siguientes pensamientos automáticos: '+icList(pensamientos)+', los cuales generan un impacto significativo en su estado emocional y conducta durante la hospitalización.';
  if(cita)subjetivo+='\n\n'+pn+' expresa textualmente: "'+cita+'"';

  var colabora=icChipsBySubLabel('Conciencia / Colaboración').filter(function(c){return c==='Consciente'||c==='Colaborador/a';});
  var conducta=icChipsBySubLabel('Conducta');
  var afecto=icChipsBySubLabel('Afecto');
  var pensamiento=icChipsBySubLabel('Pensamiento');
  var lenguaje=icChipsBySubLabel('Lenguaje / Insight');
  var orientChips=icChipsBySubLabel('Orientación');
  var desorient=orientChips.includes('Desorientado/a');
  var regulacion=icChipsBySubLabel('Regulación emocional');
  var afrontamiento=icChipsBySubLabel('Estrategias de afrontamiento');
  var comprension=icChipsBySubLabel('Comprensión del Dx');
  var interferenciaAll=icChipsBySubLabel('Factores de interferencia');
  var interferencia=interferenciaAll.filter(function(c){return c!=='Sin interferencia identificada';});

  var objetivo='Al momento de la interconsulta, '+pn+' se presenta '+(icList(colabora)||'consciente y colaborador/a')+', con conducta '+(icList(conducta)||'adecuada al contexto hospitalario')+'.';
  if(!desorient)objetivo+=' Orientado/a en las tres esferas (tiempo, espacio y persona).';
  else objetivo+=' Con alteración en la orientación.';
  objetivo+='\n\nEn el examen mental: afecto '+(icList(afecto)||'observable')+'. Lenguaje '+(icList(lenguaje)||'coherente')+'. Pensamiento de curso '+(icList(pensamiento)||'organizado')+'.';
  if(regulacion.length)objetivo+='\n\nRegulación emocional: '+icList(regulacion)+'.';
  if(afrontamiento.length)objetivo+=' Estrategias de afrontamiento presentes: '+icList(afrontamiento)+'.';
  if(comprension.length)objetivo+='\n\nComprensión del Dx/pronóstico: '+icList(comprension)+'.';
  if(interferencia.length)objetivo+='\n\nFactores de interferencia con el manejo médico: '+icList(interferencia)+'.';

  var habAlim=icChipsBySubLabel('Alimentación');
  var habSueno=icChipsBySubLabel('Sueño');
  var habSust=icChipsBySubLabel('Consumo de sustancias');
  var sustNotas=icv('ic-sustancias-notas');
  if(habAlim.length||habSueno.length||habSust.length){
    objetivo+='\n\nHábitos:';
    if(habAlim.length)objetivo+=' Alimentación: '+icList(habAlim)+'.';
    if(habSueno.length)objetivo+=' Sueño: '+icList(habSueno)+'.';
    if(habSust.length)objetivo+=' Sustancias psicoactivas: '+icList(habSust)+(sustNotas?'. '+sustNotas:'')+'.';
    else if(sustNotas)objetivo+=' Sustancias: '+sustNotas+'.';
  }

  var ideacion=icChipsBySubLabel('Ideación actual');
  var protectores=icChipsBySubLabel('Factores protectores');
  var riesgoNotas=icv('ic-riesgo-notas');
  objetivo+='\n\nEvaluación de riesgo suicida/autolesivo: ideación '+(icList(ideacion)||'evaluada')+'. Riesgo clasificado como: '+sev+'.';
  if(protectores.length)objetivo+=' Factores protectores: '+icList(protectores)+'.';
  if(riesgoNotas)objetivo+=' '+riesgoNotas;

  var tipoResp=icList(icChipsBySubLabel('Tipo de respuesta emocional'))||'una respuesta contextualizada al proceso de hospitalización y enfermedad';
  var impresion=icChipsBySubLabel('Impresión clínica');
  var red=icChipsBySubLabel('Red de apoyo funcional');
  var protectores=icChipsBySubLabel('Factores protectores');
  var analisis=icv('ic-resp-analisis');

  var intervencion=icChipsBySubLabel('Intervención realizada hoy');
  var planAll=icChipsBySubLabel('Plan');
  var plan=planAll.filter(function(c){return['Continúa seguimiento por psicología','Remisión a psiquiatría','Orientación a trabajo social','Alta de psicología','Reinterconsulta si hay cambios'].includes(c);});
  var frecuencia=icChipsBySubLabel('Frecuencia de seguimiento');
  var tratNotas=icv('ic-trat-notas');

  // RESPUESTA — incluye síntesis de notas al final
  var respuesta='Desde la valoración psicológica con enfoque cognitivo-conductual, la respuesta emocional de '+pn+' se comprende como '+tipoResp+'.';
  if(impresion.length)respuesta+='\n\nImpresión clínica: '+icList(impresion)+'.';
  if(analisis)respuesta+='\n\n'+analisis;
  if(red.length)respuesta+='\n\nEn cuanto a red de apoyo: '+icList(red)+'.';
  respuesta+='\n\nSe realiza intervención psicológica que incluye '+(icList(intervencion)||'valoración clínica pertinente al caso')+'.';
  if(protectores.length)respuesta+=' Se refuerzan factores protectores: '+icList(protectores)+'.';
  if(plan.length){
    respuesta+='\n\nComo plan se indica: '+icList(plan);
    if(frecuencia.length)respuesta+='. Frecuencia de seguimiento: '+icList(frecuencia);
    respuesta+='.';
  }
  if(tratNotas)respuesta+='\n\n'+tratNotas;

  var tratamiento='Se realiza intervención psicológica hospitalaria que incluye: '+(icList(intervencion)||'valoración clínica pertinente al caso')+'.';
  if(plan.length)tratamiento+='\n\nPlan: '+icList(plan)+'.';
  if(frecuencia.length)tratamiento+=' Frecuencia de seguimiento: '+icList(frecuencia)+'.';

  setIcOut('ic-out-sub',subjetivo);
  setIcOut('ic-out-obj',objetivo);
  setIcOut('ic-out-resp',respuesta);
  setIcOut('ic-out-trat',tratamiento);
  var wrap=document.getElementById('ic-output-wrap');
  if(wrap)wrap.scrollIntoView({behavior:'smooth',block:'start'});
}

function generarNotaIcSeg(){
  var nombre=icv('ic-pnombre')||'el/la paciente';
  var pn=nombre.split(' ')[0];
  var sev=icv('ic-riesgo-nivel')||'No clasificado';
  var colabora=icChipsBySubLabel('Conciencia / Colaboración').filter(function(c){return c==='Consciente'||c==='Colaborador/a';});
  var conducta=icChipsBySubLabel('Conducta');
  var afecto=icChipsBySubLabel('Afecto');
  var pensamiento=icChipsBySubLabel('Pensamiento');
  var lenguaje=icChipsBySubLabel('Lenguaje / Insight');
  var ideacion=icChipsBySubLabel('Ideación actual');
  var sinIdeacion=ideacion.includes('Ninguna');
  var ideacionActiva=ideacion.filter(function(c){return['Pasiva — deseo de que termine','Activa','Con plan estructurado'].includes(c);});
  var intervencion=icChipsBySubLabel('Intervención realizada hoy');
  var planAll=icChipsBySubLabel('Plan');
  var plan=planAll.filter(function(c){return['Continúa seguimiento por psicología','Remisión a psiquiatría','Orientación a trabajo social','Alta de psicología','Reinterconsulta si hay cambios'].includes(c);});
  var analisis=icv('ic-resp-analisis');
  var tratNotas=icv('ic-trat-notas');
  var riesgoNotas=icv('ic-riesgo-notas');
  var orientChips=icChipsBySubLabel('Orientación');
  var desorient=orientChips.includes('Desorientado/a');
  var lsi=lenguaje.filter(function(c){return!['Insight conservado','Insight parcial','Sin insight'].includes(c);});

  var p=pn+' se muestra '+(icList(colabora)||'consciente y colaborador/a')+' durante la entrevista, con conducta '+(icList(conducta)||'adecuada')+'. ';
  if(!desorient)p+='Orientado/a en las tres esferas. ';
  else p+='Con alteración en la orientación. ';
  p+='Afecto '+(icList(afecto)||'observable')+(afecto.includes('Congruente')?', congruente con el discurso':'')+'. Lenguaje '+(icList(lsi)||'coherente')+', pensamiento '+(icList(pensamiento)||'organizado')+', sin alteraciones del contenido ni de la percepción. ';
  if(lenguaje.includes('Insight conservado'))p+='Juicio conservado e insight adecuado. ';
  else if(lenguaje.includes('Insight parcial'))p+='Insight parcial. ';
  else if(lenguaje.includes('Sin insight'))p+='Sin insight para la situación actual. ';
  if(sinIdeacion)p+='Niega ideación suicida, heteroagresiva o síntomas psicóticos. ';
  else if(ideacionActiva.length)p+='Refiere '+icList(ideacionActiva).toLowerCase()+'. Riesgo clasificado como '+sev+'. '+(riesgoNotas?riesgoNotas+' ':'');
  if(analisis)p+=analisis+' ';
  if(intervencion.length)p+='Se realiza '+icList(intervencion)+'. ';
  if(plan.length)p+=icList(plan)+'. ';
  if(tratNotas)p+=tratNotas+' ';
  p=p.trim();

  setIcOut('ic-out-seg-texto',p);
  var wrap=document.getElementById('ic-output-wrap');
  if(wrap)wrap.scrollIntoView({behavior:'smooth',block:'start'});
}

function generarNotaIcEsp(){
  if(!icCurrentEsp||!icEspNotes[icCurrentEsp]){
    if(typeof toast==='function')toast('⚠️ Selecciona el tipo de nota especial');
    return;
  }
  setIcOut('ic-out-trat',icEspNotes[icCurrentEsp]);
  setIcOut('ic-out-sub','N/A — Ver tratamiento.');
  setIcOut('ic-out-obj','N/A — Ver tratamiento.');
  setIcOut('ic-out-resp','N/A — Ver tratamiento.');
  var f4=document.getElementById('ic-out-4campos');
  var seg=document.getElementById('ic-out-seg');
  if(f4)f4.style.display='';
  if(seg)seg.style.display='none';
  var wrap=document.getElementById('ic-output-wrap');
  if(wrap)wrap.scrollIntoView({behavior:'smooth',block:'start'});
}

function setIcOut(id,text){
  var el=document.getElementById(id);
  if(!el)return;
  el.textContent=text;
  el.classList.remove('ph');
}

window.copiarCampoIC=function(id,btn){
  var el=document.getElementById(id);
  if(!el)return;
  navigator.clipboard.writeText(el.textContent).then(function(){
    btn.textContent='✓ Copiado';btn.classList.add('done');
    setTimeout(function(){btn.textContent='Copiar';btn.classList.remove('done');},2000);
  });
};

window.copiarTodoIC=function(){
  var text;
  if(icCurrentMode==='seg'){
    var el=document.getElementById('ic-out-seg-texto');
    text=el?el.textContent:'';
  }else{
    var labels=['ANÁLISIS SUBJETIVO','ANÁLISIS OBJETIVO','RESPUESTA','TRATAMIENTO'];
    var ids=['ic-out-sub','ic-out-obj','ic-out-resp','ic-out-trat'];
    text=ids.map(function(id,i){
      var el=document.getElementById(id);
      return labels[i]+'\n'+(el?el.textContent:'');
    }).join('\n\n---\n\n');
  }
  navigator.clipboard.writeText(text).then(function(){if(typeof toast==='function')toast('📋 Nota copiada al portapapeles');});
};

window.limpiarFormIC=function(confirm_=true){
  if(confirm_!==false&&!confirm('¿Limpiar el formulario?'))return;
  document.querySelectorAll('#ic-form-view input[type=text], #ic-form-view textarea').forEach(function(i){i.value='';});
  document.querySelectorAll('#ic-form-view .ic-chip').forEach(function(c){c.classList.remove('on','on-r','on-g','on-a');});
  document.querySelectorAll('.sev-btn').forEach(function(s){s.classList.remove('on');});
  var rn=document.getElementById('ic-riesgo-nivel');if(rn)rn.value='';
  var ra=document.getElementById('ic-risk-alert');if(ra)ra.classList.remove('show');
  var wrap=document.getElementById('ic-output-wrap');if(wrap)wrap.style.display='none';
  icCurrentEsp=null;
  var ep=document.getElementById('ic-esp-preview');if(ep)ep.style.display='none';
  var sel=document.getElementById('ic-paciente-sel');if(sel)sel.value='';
  var pf=document.getElementById('ic-pfecha');if(pf)pf.value=new Date().toISOString().split('T')[0];
  setICMode('nueva');
};

let escolaridadLevel=5;
window.updateEscolaridad=(v)=>{escolaridadLevel=parseInt(v);};

// ── MODO LECTURA ASISTIDA ────────────────────────────────────
window.toggleAssisted=(on)=>{document.getElementById('page-tests').classList.toggle('assisted-mode',on);};

// ── TEST NAVIGATION ──────────────────────────────────────────
window.showTest=(id)=>{
  document.querySelectorAll('.test-screen').forEach(s=>s.classList.remove('active'));
  const el=document.getElementById(id==='home'?'tests-home':`test-${id}`);
  if(el)el.classList.add('active');
  if(id!=='home'){
    if(id==='pcl5'){renderPCL5Questions();}else{renderTestQuestions(id);}
    const res=document.getElementById(`${id}-result`);
    if(res)res.style.display='none';
  }
  // Keep topbar title as "Tests Clínicos" regardless of which test
  document.getElementById('topbar-title').textContent='Tests Clínicos';
};

