// ── CALCULAR RESULTADOS ──────────────────────────────────────
function getScore(name,count){let s=0;for(let i=0;i<count;i++){const el=document.querySelector(`input[name="${name}_q${i}"]:checked`);if(el)s+=parseFloat(el.value)||0;}return s;}

function showResult(divId,score,maxScore,level,interpretation,extra){
  const colors={normal:'var(--success)',moderate:'var(--warning)',high:'var(--danger)',critical:'#7b1fa2'};
  const el=document.getElementById(divId);
  if(!el)return;
  el.style.display='block';
  el.innerHTML=`<div class="test-result ${level}"><div class="result-score" style="color:${colors[level]||'var(--text)'}">${score}${maxScore?' / '+maxScore:''}</div><div class="result-label" style="color:${colors[level]||'var(--text)'}">${interpretation.split('—')[0].trim()}</div><div class="result-interpretation">${interpretation}</div>${extra?`<div style="margin-top:12px;font-size:0.82rem;color:var(--text2)">${extra}</div>`:''}<div class="result-actions"><button class="btn btn-primary" onclick="guardarResultadoTest('${divId.replace('-result','')}',${score},'${level}',document.getElementById('test-pac-nombre').value,'${interpretation.split('—')[0].trim()}')">💾 Guardar resultado</button><button class="btn btn-secondary" onclick="showTest('home')">← Nuevo test</button></div></div>`;
  el.scrollIntoView({behavior:'smooth',block:'center'});
}

window.calcPHQ9=()=>{
  const s=getScore('phq9',9);
  const q8=document.querySelector('input[name="phq9_q8"]:checked');
  const suicide=q8&&parseFloat(q8.value)>0;
  let level,interp;
  if(s<=4){level='normal';interp='Normal — Sin depresión significativa';}
  else if(s<=9){level='moderate';interp='Leve — Seguimiento, considerar psicoeducación';}
  else if(s<=14){level='high';interp='Moderado — Iniciar intervención, considerar remisión a psiquiatría';}
  else if(s<=19){level='high';interp='Moderadamente grave — Remitir a psiquiatría';}
  else{level='critical';interp='Grave — Remisión urgente a psiquiatría';}
  const extra=suicide?'⚠️ <strong>ALERTA: Ideación suicida presente (ítem 9 positivo)</strong> — Evaluar con C-SSRS inmediatamente':'';
  showResult('phq9-result',s,27,level,interp,extra);
};

window.calcGAD7=()=>{
  const s=getScore('gad7',7);
  let level,interp;
  if(s<=4){level='normal';interp='Normal — Sin ansiedad significativa';}
  else if(s<=9){level='moderate';interp='Leve — Psicoeducación y técnicas de relajación';}
  else if(s<=14){level='high';interp='Moderado — Intervención psicológica estructurada';}
  else{level='critical';interp='Grave — Considerar remisión a psiquiatría';}
  showResult('gad7-result',s,21,level,interp,'');
};

window.calcHADS=()=>{
  let a=0,d=0;
  hadsQs.forEach((item,i)=>{const el=document.querySelector(`input[name="hads_q${i}"]:checked`);if(el){const v=parseFloat(el.value)||0;if(item.type==='A')a+=v;else d+=v;}});
  const total=a+d;
  const levelA=a<=7?'normal':a<=10?'moderate':'high';
  const levelD=d<=7?'normal':d<=10?'moderate':'high';
  const level=levelA==='high'||levelD==='high'?'high':levelA==='moderate'||levelD==='moderate'?'moderate':'normal';
  const interp=`Ansiedad: ${a}/21 (${levelA==='normal'?'Normal':levelA==='moderate'?'Límite':'Caso probable'}) | Depresión: ${d}/21 (${levelD==='normal'?'Normal':levelD==='moderate'?'Límite':'Caso probable'})`;
  showResult('hads-result',total,42,level,interp,'');
};

window.calcMMSE=()=>{
  let s=0;mmseQs.forEach((item,i)=>{const el=document.querySelector(`input[name="mmse_q${i}"]:checked`);if(el)s+=parseFloat(el.value)||0;});
  const cutoffs=[17,20,24];const cutoff=cutoffs[Math.min(escolaridadLevel,2)]??24;
  let level,interp;
  if(s>=cutoff){level='normal';interp=`Normal para su escolaridad — Sin deterioro cognitivo sugerido (corte: ${cutoff})`;}
  else if(s>=18){level='moderate';interp=`Deterioro leve-moderado — Corte ajustado por escolaridad: ${cutoff}`;}
  else if(s>=10){level='high';interp='Deterioro moderado — Evaluación neuropsicológica recomendada';}
  else{level='critical';interp='Deterioro grave — Remitir a neurología o psiquiatría';}
  const extra=escolaridadLevel<=1?'⚠️ Nota: paciente con baja escolaridad — tolerar 3–4 pts menos. No penalizar ítems de escritura/lectura si nunca aprendió.':'';
  showResult('mmse-result',s,30,level,interp,extra);
};

window.calcMoCA=()=>{
  let s=0;mocaQs.forEach((item,i)=>{if(item.pts>0){const el=document.querySelector(`input[name="moca_q${i}"]:checked`);if(el)s+=parseFloat(el.value)||0;}});
  if(escolaridadLevel<=3)s=Math.min(s+1,30);
  let level,interp;
  if(s>=26){level='normal';interp='Normal — Sin deterioro cognitivo';}
  else if(s>=22){level='moderate';interp='Deterioro leve — Seguimiento clínico';}
  else if(s>=18){level='high';interp='Deterioro moderado — Evaluación neuropsicológica';}
  else{level='critical';interp='Deterioro grave — Remitir a neurología';}
  const extra=escolaridadLevel<=3?'✅ +1 punto aplicado por escolaridad ≤ bachillerato':'';
  showResult('moca-result',s,30,level,interp,extra);
};

window.calcCAM=()=>{
  const c1=document.querySelector('input[name="cam_q0"]:checked')?.value==='Sí';
  const c2=document.querySelector('input[name="cam_q1"]:checked')?.value==='Sí';
  const c3=document.querySelector('input[name="cam_q2"]:checked')?.value==='Sí';
  const c4val=document.querySelector('input[name="cam_q3"]:checked')?.value;
  const c4=c4val&&c4val!=='Normal';
  const delirium=c1&&c2&&(c3||c4);
  const level=delirium?'critical':'normal';
  const interp=delirium?'⚠️ DELIRIUM POSITIVO — Requiere evaluación médica urgente':'Sin criterios de delirium según algoritmo CAM';
  showResult('cam-result','',null,level,interp,`C1 (inicio agudo): ${c1?'✅':'❌'} | C2 (inatención): ${c2?'✅':'❌'} | C3 (pensamiento desorg.): ${c3?'✅':'❌'} | C4 (conciencia alterada): ${c4?'✅':'❌'}`);
};

window.calcCSSRS=()=>{
  const resp=[];for(let i=0;i<6;i++){const el=document.querySelector(`input[name="cssrs_q${i}"]:checked`);resp.push(el?.value==='Sí');}
  let level,interp;
  if(resp[4]||resp[5]){level='critical';interp='RIESGO CRÍTICO — Ítems 5–6 positivos. Evaluación inmediata y protocolo de crisis';}
  else if(resp[3]){level='critical';interp='RIESGO ALTO — Ítem 4 positivo (plan suicida). Intervención urgente';}
  else if(resp[2]){level='high';interp='RIESGO MODERADO — Ítem 3 positivo (método). Evaluación detallada hoy';}
  else if(resp[1]){level='moderate';interp='RIESGO LEVE-MODERADO — Ideación activa sin plan. Seguimiento estrecho';}
  else if(resp[0]){level='moderate';interp='RIESGO BAJO-MODERADO — Deseos pasivos de muerte. Psicoeducación y seguimiento';}
  else{level='normal';interp='Sin ideación suicida activa reportada';}
  showResult('cssrs-result','',null,level,interp,'');
};

window.calcMMAS4=()=>{
  const s=getScore('mmas4',4);
  let level,interp;
  if(s===0){level='normal';interp='Alta adherencia — Continuar reforzando';}
  else if(s<=1){level='moderate';interp='Adherencia media — Psicoeducación sobre importancia del tratamiento';}
  else{level='high';interp='Baja adherencia — Explorar barreras: costo, olvidos, efectos secundarios, red de apoyo';}
  showResult('mmas4-result',s,4,level,interp,'');
};

window.calcDuelo=()=>{
  let s=0;dueloQs.forEach((item,i)=>{const el=document.querySelector(`input[name="duelo_q${i}"]:checked`);if(el)s+=parseFloat(el.value)||0;});
  let level,interp;
  if(s<=3){level='normal';interp='Duelo normal — Validación emocional y seguimiento';}
  else if(s<=6){level='moderate';interp='Duelo complicado probable — Intervención psicológica recomendada';}
  else{level='critical';interp='Duelo complicado severo — Intervención urgente. Evaluar ideación suicida con C-SSRS';}
  const extra=s>=8?'⚠️ Puntaje alto — Aplicar C-SSRS por posible riesgo suicida asociado al duelo':'';
  showResult('duelo-result',s,10,level,interp,extra);
};

// ── PCL-5 PTSD ──────────────────────────────────────────────
const pcl5Qs=[
  {q:'Tener recuerdos repetitivos, angustiantes e involuntarios de la experiencia estresante'},
  {q:'Tener sueños perturbadores de la experiencia estresante'},
  {q:'Sentirse o actuar de repente como si la experiencia estresante estuviera ocurriendo de nuevo (como si estuviera reviviéndola)'},
  {q:'Sentirse muy perturbado/a cuando algo le recuerda la experiencia estresante'},
  {q:'Tener reacciones físicas intensas (corazón acelerado, dificultad para respirar, sudoración) cuando algo le recuerda la experiencia estresante'},
  {q:'Evitar memorias, pensamientos o sentimientos relacionados con la experiencia estresante'},
  {q:'Evitar cosas externas que le recuerdan la experiencia estresante (personas, lugares, conversaciones, actividades, objetos o situaciones)'},
  {q:'Tener problemas para recordar partes importantes de la experiencia estresante'},
  {q:'Tener creencias negativas fuertes sobre usted mismo/a, otras personas o el mundo (por ej. "Soy malo/a", "Nadie es de confianza", "El mundo es completamente peligroso")'},
  {q:'Culparse a sí mismo/a o culpar a otros por la experiencia estresante o lo que sucedió después'},
  {q:'Tener sentimientos negativos fuertes como miedo, horror, enojo, culpa o vergüenza'},
  {q:'Perder el interés en actividades que antes disfrutaba'},
  {q:'Sentirse distante o alejado/a de otras personas'},
  {q:'Tener dificultad para experimentar sentimientos positivos (por ej. no poder sentir felicidad o amor por personas cercanas)'},
  {q:'Comportamiento irritable, explosiones de enojo o actuar de manera agresiva'},
  {q:'Asumir demasiados riesgos o hacer cosas que podrían causarle daño'},
  {q:'Estar "súper alerta" o en guardia, como si necesitara vigilar lo que está alrededor'},
  {q:'Sobresaltarse o asustarse fácilmente'},
  {q:'Tener dificultad para concentrarse'},
  {q:'Tener problemas para dormir'}
];
const pcl5Opts=[{v:0,l:'Para nada'},{v:1,l:'Un poco'},{v:2,l:'Moderadamente'},{v:3,l:'Bastante'},{v:4,l:'Extremadamente'}];

window.renderPCL5Questions=()=>{
  const cont=document.getElementById('pcl5-questions');if(!cont)return;
  const clusters=[
    {name:'B — Reexperimentación',range:[0,4],color:'#1a56db'},
    {name:'C — Evitación',range:[5,6],color:'#7b1fa2'},
    {name:'D — Alteraciones cognitivas y del ánimo',range:[7,13],color:'var(--warning)'},
    {name:'E — Alteraciones de la reactividad',range:[14,19],color:'var(--danger)'}
  ];
  let html='';
  pcl5Qs.forEach((item,i)=>{
    const cluster=clusters.find(c=>i>=c.range[0]&&i<=c.range[1]);
    if(cluster&&i===cluster.range[0])html+=`<div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:${cluster.color};margin:14px 0 6px;padding:4px 10px;background:${cluster.color}18;border-radius:5px">${cluster.name}</div>`;
    html+=`<div class="test-question"><div class="test-question-num">Ítem ${i+1} de 20</div><div class="test-question-text">${item.q}</div><div class="test-options-row">`;
    pcl5Opts.forEach(o=>html+=`<label class="test-option"><input type="radio" name="pcl5_q${i}" value="${o.v}"><span class="test-option-label">${o.v} — ${o.l}</span></label>`);
    html+='</div></div>';
  });
  cont.innerHTML=html;
};

window.calcPCL5=()=>{
  let s=0;let answered=0;
  pcl5Qs.forEach((_,i)=>{const el=document.querySelector(`input[name="pcl5_q${i}"]:checked`);if(el){s+=parseInt(el.value)||0;answered++;}});
  if(answered<20){toast('⚠️ Por favor responda todas las preguntas');return;}
  // Cluster scores
  const clB=Array.from({length:5},(_,i)=>parseInt(document.querySelector(`input[name="pcl5_q${i}"]:checked`)?.value||0)).reduce((a,b)=>a+b,0);
  const clC=Array.from({length:2},(_,i)=>parseInt(document.querySelector(`input[name="pcl5_q${i+5}"]:checked`)?.value||0)).reduce((a,b)=>a+b,0);
  const clD=Array.from({length:7},(_,i)=>parseInt(document.querySelector(`input[name="pcl5_q${i+7}"]:checked`)?.value||0)).reduce((a,b)=>a+b,0);
  const clE=Array.from({length:6},(_,i)=>parseInt(document.querySelector(`input[name="pcl5_q${i+14}"]:checked`)?.value||0)).reduce((a,b)=>a+b,0);
  let level,interp;
  if(s>=33){level='critical';interp='Probable TEPT — Puntaje ≥33. Evaluación diagnóstica completa y plan de tratamiento urgente (TCC-TEPT, EMDR)';}
  else if(s>=20){level='high';interp='Síntomas moderados de estrés postraumático — Seguimiento estrecho. Considerar derivación a psicología especializada';}
  else if(s>=10){level='moderate';interp='Síntomas leves — Psicoeducación sobre reacciones normales al trauma. Monitorear evolución';}
  else{level='normal';interp='Sin síntomas significativos de TEPT';}
  const extra=`Clusters — B (Reexperimentación): ${clB}/20 | C (Evitación): ${clC}/8 | D (Cognición/ánimo): ${clD}/28 | E (Reactividad): ${clE}/24`;
  showResult('pcl5-result',s,80,level,interp,extra);
  guardarResultadoTest('PCL-5',s,level,document.getElementById('test-pac-nombre').value,`Evento: ${document.getElementById('pcl5-evento')?.value||'—'} · ${extra}`);
};


// ── INIT ────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded',()=>{
  renderTestQuestions('phq9');renderTestQuestions('gad7');renderTestQuestions('hads');
  renderTestQuestions('mmse');renderTestQuestions('moca');renderTestQuestions('cam');
  renderTestQuestions('cssrs');renderTestQuestions('mmas4');renderTestQuestions('duelo');
  renderPCL5Questions();
  try{document.getElementById('an-fecha').value=new Date().toISOString().split('T')[0];}catch(e){}
});
</script>

<!-- MODAL HISTORIAL PACIENTE -->
<div id="modal-historial-ic" style="display:none;position:fixed;inset:0;background:rgba(26,23,20,0.5);z-index:300;align-items:flex-start;justify-content:center;padding:20px;overflow-y:auto">
  <div style="background:var(--surface);border-radius:16px;width:100%;max-width:740px;margin:auto;box-shadow:0 8px 40px rgba(26,23,20,0.18)">
    <div style="padding:18px 22px 14px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;justify-content:space-between;gap:12px;position:sticky;top:0;background:var(--surface);border-radius:16px 16px 0 0;z-index:1">
      <div>
        <div style="font-family:'DM Serif Display',serif;font-size:1.1rem" id="mhic-title">Historial del Paciente</div>
        <div style="font-size:0.73rem;color:var(--text3);margin-top:3px" id="mhic-sub"></div>
      </div>
      <div style="display:flex;gap:8px;align-items:center;flex-shrink:0">
        <button class="btn btn-primary btn-sm" onclick="mhicNuevaNota()">📝 Nuevo seguimiento</button>
        <button style="background:var(--surface2);border:none;border-radius:7px;padding:5px;cursor:pointer;display:flex" onclick="mhicCerrar()">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
    </div>
    <div id="mhic-body" style="padding:18px 22px;max-height:72vh;overflow-y:auto"></div>
  </div>
</div>

<!-- MODAL EDITAR/NUEVA NOTA -->
<div id="modal-nota-edit" style="display:none;position:fixed;inset:0;background:rgba(26,23,20,0.5);z-index:400;align-items:flex-start;justify-content:center;padding:20px;overflow-y:auto">
  <div style="background:var(--surface);border-radius:16px;width:100%;max-width:660px;margin:auto;box-shadow:0 8px 40px rgba(26,23,20,0.18)">
    <div style="padding:18px 22px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
      <div style="font-family:'DM Serif Display',serif;font-size:1.05rem" id="mne-title">Editar nota</div>
      <button style="background:var(--surface2);border:none;border-radius:7px;padding:5px;cursor:pointer;display:flex" onclick="mneCerrar()">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div style="padding:18px 22px">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px">
        <div class="form-group"><label>Fecha</label><input type="date" id="mne-fecha"></div>
        <div class="form-group"><label>Tipo</label>
          <select id="mne-tipo"><option value="IC Nueva">IC Nueva</option><option value="Seguimiento">Seguimiento</option><option value="Anamnesis">Anamnesis</option><option value="Nota especial">Nota especial</option></select>
        </div>
        <div class="form-group"><label>Riesgo suicida</label>
          <select id="mne-riesgo"><option value="">Sin clasificar</option><option value="BAJO">BAJO</option><option value="MEDIO">MEDIO</option><option value="ALTO">ALTO</option></select>
        </div>
        <div class="form-group"><label>Estado</label>
          <select id="mne-estado"><option value="respondida">Completada</option><option value="pendiente">Pendiente</option></select>
        </div>
      </div>
      <div class="form-group" style="margin-bottom:10px"><label>Análisis Subjetivo</label><textarea id="mne-sub" rows="3" placeholder="Estado emocional, preocupaciones, citas textuales..."></textarea></div>
      <div class="form-group" style="margin-bottom:10px"><label>Análisis Objetivo</label><textarea id="mne-obj" rows="3" placeholder="Examen mental, hábitos, evaluación de riesgo..."></textarea></div>
      <div class="form-group" style="margin-bottom:10px"><label>Respuesta / Impresión clínica</label><textarea id="mne-resp" rows="3" placeholder="Impresión diagnóstica, análisis CC..."></textarea></div>
      <div class="form-group" style="margin-bottom:10px"><label>Tratamiento / Plan</label><textarea id="mne-trat" rows="3" placeholder="Intervenciones realizadas, plan..."></textarea></div>
      <div class="form-group"><label>Nota libre / Complementaria</label><textarea id="mne-nota" rows="3" placeholder="Nota en formato libre..."></textarea></div>
    </div>
    <div style="padding:12px 22px 18px;border-top:1px solid var(--border);display:flex;gap:10px;justify-content:flex-end;align-items:center">
      <button class="btn btn-danger btn-sm" id="mne-del-btn" onclick="mneEliminar()" style="display:none;margin-right:auto">🗑 Eliminar</button>
      <button class="btn btn-secondary" onclick="mneCerrar()">Cancelar</button>
      <button class="btn btn-primary" onclick="mneGuardar()">💾 Guardar</button>
    </div>
  </div>
</div>

</body>
</html>
