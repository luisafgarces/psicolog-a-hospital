  cont.innerHTML=mocaQs.map((item,i)=>`<div class="test-question"><div class="test-question-num">Ítem ${i+1}${item.pts>0?' · '+item.pts+' pt'+(item.pts>1?'s':''):' · No puntúa'}</div><div class="test-question-text">${item.q}</div>${item.pts>0?`<div class="test-options"><div class="test-option"><input type="radio" name="moca_q${i}" id="moca_q${i}_1" value="${item.pts}"><label class="test-option-label" for="moca_q${i}_1">✅ Correcto</label></div><div class="test-option"><input type="radio" name="moca_q${i}" id="moca_q${i}_0" value="0"><label class="test-option-label" for="moca_q${i}_0">❌ Incorrecto</label></div>${item.pts===3?`<div class="test-option"><input type="radio" name="moca_q${i}" id="moca_q${i}_p1" value="1"><label class="test-option-label" for="moca_q${i}_p1">⚠️ 1 pt</label></div><div class="test-option"><input type="radio" name="moca_q${i}" id="moca_q${i}_p2" value="2"><label class="test-option-label" for="moca_q${i}_p2">⚠️ 2 pts</label></div>`:''}</div>`:''}</div>`).join('');
}
