                <div class="ic-field"><div class="ic-sublabel">Intensidad malestar (1–10) / Desde el ingreso</div><input type="text" id="ic-sub-intensidad" placeholder="Ej: 8/10 — Desde el ingreso describe..."></div>
              </div>
