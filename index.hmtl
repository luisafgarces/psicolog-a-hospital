              <div class="ic-g2">
                <div class="ic-field"><div class="ic-sublabel">Principales preocupaciones</div><div class="ic-chips"><span class="ic-chip" onclick="icTog(this)">Pronóstico incierto</span><span class="ic-chip" onclick="icTog(this)">Dolor / malestar físico</span><span class="ic-chip" onclick="icTog(this)">Familia / hijos</span><span class="ic-chip" onclick="icTog(this)">Rol laboral / económico</span><span class="ic-chip" onclick="icTog(this)">Dependencia / autonomía</span><span class="ic-chip" onclick="icTog(this)">Miedo a morir</span><span class="ic-chip" onclick="icTog(this)">Proceso diagnóstico</span><span class="ic-chip" onclick="icTog(this)">Aislamiento</span><span class="ic-chip" onclick="icTogA(this)">Demoras del alta</span><span class="ic-chip" onclick="icTogA(this)">Demoras en procesos hospitalarios</span><span class="ic-chip" onclick="icTogA(this)">Inconformidad con la atención</span><span class="ic-chip" onclick="icTogA(this)">Demoras en procesos de la EPS</span><span class="ic-chip" onclick="icTogA(this)">Sensación de estancamiento</span><span class="ic-chip on-g" onclick="icTogG(this)">Ninguna</span></div></div>
                <div class="ic-field"><div class="ic-sublabel">Pensamientos automáticos (CC)</div><div class="ic-chips"><span class="ic-chip" onclick="icTogR(this)">No voy a mejorar</span><span class="ic-chip" onclick="icTogR(this)">Soy una carga</span><span class="ic-chip" onclick="icTogR(this)">No puedo con esto</span><span class="ic-chip" onclick="icTogR(this)">Lo peor está por venir</span><span class="ic-chip" onclick="icTogR(this)">Nunca volveré a ser el mismo/a</span><span class="ic-chip" onclick="icTogA(this)">Catastrofización</span><span class="ic-chip" onclick="icTogA(this)">Pensamiento todo-o-nada</span><span class="ic-chip" onclick="icTogA(this)">Minimización de recursos propios</span><span class="ic-chip on-g" onclick="icTogG(this)">Ninguno</span></div></div>
              </div>
